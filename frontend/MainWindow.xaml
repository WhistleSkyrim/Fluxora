                           Foreground="{StaticResource SubtleTextBrush}"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding HasProgressDisplay}" Value="True">
                    <Setter TargetName="ProgressContent" Property="Visibility" Value="Visible" />
                    <Setter TargetName="NoProgressText" Property="Visibility" Value="Collapsed" />
                </DataTrigger>
                <DataTrigger Binding="{Binding HasProgressHeader}" Value="True">
                    <Setter TargetName="ProgressHeader" Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding HasProgressCaption}" Value="True">
                    <Setter TargetName="ProgressCaption" Property="Visibility" Value="Visible" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate x:Key="DownloadSizeCellTemplate">
            <TextBlock Text="{Binding SizeText}"
