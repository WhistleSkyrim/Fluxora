        <Style x:Key="DownloadProgressBarStyle" TargetType="{x:Type ProgressBar}">
            <Setter Property="Height" Value="9" />
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="100" />
            <Setter Property="Background" Value="#0B0913" />
            <Setter Property="Foreground" Value="{StaticResource AccentHoverBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ProgressBar}">
                        <Grid x:Name="Root"
                              Height="{TemplateBinding Height}"
                              ClipToBounds="True">
                            <Border x:Name="PART_Track"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{StaticResource LineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="5" />
                            <Border x:Name="PulseLayer"
                                    BorderBrush="#9D7BFF"
                                    BorderThickness="1"
                                    CornerRadius="5"
                                    Opacity="0" />
                            <Decorator x:Name="PART_Indicator"
                                       HorizontalAlignment="Left"
                                       ClipToBounds="True">
                                <Grid ClipToBounds="True">
                                    <Border Background="{StaticResource AccentGradientBrush}"
                                            CornerRadius="5" />
                                    <Border x:Name="ProgressSheen"
                                            Width="72"
                                            HorizontalAlignment="Left"
                                            Opacity="0"
                                            CornerRadius="5">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                                <GradientStop Color="#00FFFFFF" Offset="0" />
                                                <GradientStop Color="#78FFFFFF" Offset="0.48" />
                                                <GradientStop Color="#00FFFFFF" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Border.RenderTransform>
                                            <TranslateTransform x:Name="ProgressSheenTranslate" X="-82" />
                                        </Border.RenderTransform>
                                    </Border>
                                </Grid>
                            </Decorator>
                            <Border x:Name="IndeterminateLayer"
                                    Width="76"
                                    HorizontalAlignment="Left"
                                    Background="{StaticResource AccentGradientBrush}"
                                    CornerRadius="5"
                                    Opacity="0.72"
                                    Visibility="Collapsed">
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="IndeterminateTranslate" X="-84" />
                                </Border.RenderTransform>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="services:ProgressAnimationService.IsActive" Value="True">
                                <Setter TargetName="ProgressSheen" Property="Opacity" Value="0.28" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard x:Name="ProgressSheenStoryboard">
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetName="PulseLayer"
                                                             Storyboard.TargetProperty="Opacity"
                                                             From="0.08"
                                                             To="0.32"
                                                             AutoReverse="True"
                                                             Duration="0:0:1.8" />
                                            <DoubleAnimation Storyboard.TargetName="ProgressSheenTranslate"
                                                             Storyboard.TargetProperty="X"
                                                             From="-82"
                                                             To="340"
                                                             Duration="0:0:2.45" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <RemoveStoryboard BeginStoryboardName="ProgressSheenStoryboard" />
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsIndeterminate" Value="True">
                                <Setter TargetName="PART_Indicator" Property="Visibility" Value="Collapsed" />
                                <Setter TargetName="IndeterminateLayer" Property="Visibility" Value="Visible" />
                                <Setter TargetName="IndeterminateLayer" Property="Opacity" Value="0.56" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard x:Name="IndeterminateProgressStoryboard">
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetName="IndeterminateTranslate"
                                                             Storyboard.TargetProperty="X"
                                                             From="-84"
                                                             To="320"
                                                             Duration="0:0:1.9" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <RemoveStoryboard BeginStoryboardName="IndeterminateProgressStoryboard" />
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="DownloadNameCellTemplate">
            <TextBlock Text="{Binding Name}"
