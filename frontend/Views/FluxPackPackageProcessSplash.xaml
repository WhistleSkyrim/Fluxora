<UserControl x:Class="Fluxora.App.Views.FluxPackPackageProcessSplash"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:services="clr-namespace:Fluxora.App.Services"
             xmlns:controls="clr-namespace:Fluxora.App.Controls"
             IsHitTestVisible="{Binding IsVisible}"
             FontFamily="{StaticResource FluxoraFontBody}"
             FontWeight="Medium"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             TextOptions.TextHintingMode="Fixed"
             RenderOptions.ClearTypeHint="Enabled"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <SolidColorBrush x:Key="PackageTextBrush" Color="#F7F4FF" />
        <SolidColorBrush x:Key="PackageSecondaryTextBrush" Color="#D6F4EE" />
        <SolidColorBrush x:Key="PackageMutedTextBrush" Color="#93B4AD" />
        <SolidColorBrush x:Key="PackageSubtleTextBrush" Color="#6F8B86" />
        <SolidColorBrush x:Key="PackageErrorBrush" Color="#FB7185" />
        <SolidColorBrush x:Key="PackageSuccessBrush" Color="#5EEAD4" />

        <LinearGradientBrush x:Key="PackageCoreBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F7F4FF" Offset="0" />
            <GradientStop Color="#5EEAD4" Offset="0.42" />
            <GradientStop Color="#8B5CF6" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="PackageProgressBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#5EEAD4" Offset="0" />
            <GradientStop Color="#7DD3FC" Offset="0.48" />
            <GradientStop Color="#A78BFA" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="PackageProgressBarStyle" TargetType="{x:Type ProgressBar}">
            <Setter Property="Height" Value="9" />
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="100" />
            <Setter Property="Foreground" Value="{StaticResource PackageProgressBrush}" />
            <Setter Property="Background" Value="#101A1E" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ProgressBar}">
                        <Grid Height="{TemplateBinding Height}"
                              ClipToBounds="True">
                            <Border x:Name="PART_Track"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="#25454C"
                                    BorderThickness="1"
                                    CornerRadius="5" />
                            <Border x:Name="PulseLayer"
                                    BorderBrush="#5EEAD4"
                                    BorderThickness="1"
                                    CornerRadius="5"
                                    Opacity="0" />
                            <Decorator x:Name="PART_Indicator"
                                       HorizontalAlignment="Left"
                                       ClipToBounds="True">
                                <Grid ClipToBounds="True">
                                    <Border Background="{TemplateBinding Foreground}"
                                            CornerRadius="5" />
                                    <Border x:Name="ProgressSheen"
                                            Width="84"
                                            HorizontalAlignment="Left"
                                            Opacity="0"
                                            CornerRadius="5">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                                <GradientStop Color="#00FFFFFF" Offset="0" />
                                                <GradientStop Color="#80FFFFFF" Offset="0.5" />
                                                <GradientStop Color="#00FFFFFF" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Border.RenderTransform>
                                            <TranslateTransform x:Name="ProgressSheenTranslate" X="-90" />
                                        </Border.RenderTransform>
                                    </Border>
                                </Grid>
                            </Decorator>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="services:ProgressAnimationService.IsActive" Value="True">
                                <Setter TargetName="ProgressSheen" Property="Opacity" Value="0.26" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard x:Name="PackageProgressStoryboard">
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetName="PulseLayer"
                                                             Storyboard.TargetProperty="Opacity"
                                                             From="0.08"
                                                             To="0.28"
                                                             AutoReverse="True"
                                                             Duration="0:0:1.7" />
                                            <DoubleAnimation Storyboard.TargetName="ProgressSheenTranslate"
                                                             Storyboard.TargetProperty="X"
                                                             From="-90"
                                                             To="560"
                                                             Duration="0:0:1.95" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <RemoveStoryboard BeginStoryboardName="PackageProgressStoryboard" />
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PackageButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="20,0" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource PackageSecondaryTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="#142228"
                                BorderBrush="#2F5960"
                                BorderThickness="1"
                                CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"
                                              TextElement.FontWeight="{TemplateBinding FontWeight}"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#193138" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#5EEAD4" />
                                <Setter Property="Foreground" Value="{StaticResource PackageTextBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.42" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PackageStepCardStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="#111C21" />
            <Setter Property="BorderBrush" Value="#263B43" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Opacity" Value="0.72" />
        </Style>

        <Style x:Key="PackageStepIconShellStyle" TargetType="{x:Type Border}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="Background" Value="#17252B" />
            <Setter Property="BorderBrush" Value="#31515A" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </UserControl.Resources>

    <UserControl.Style>
        <Style TargetType="{x:Type UserControl}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsVisible}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Style>

    <Grid>
        <Grid.Triggers>
            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                <BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever">
                        <DoubleAnimation Storyboard.TargetName="MainArcRotate"
                                         Storyboard.TargetProperty="Angle"
                                         From="-24"
                                         To="696"
                                         Duration="0:0:3.7" />
                        <DoubleAnimation Storyboard.TargetName="EchoArcRotate"
                                         Storyboard.TargetProperty="Angle"
                                         From="42"
                                         To="-678"
                                         Duration="0:0:3.7" />
                        <DoubleAnimation Storyboard.TargetName="MainArc"
                                         Storyboard.TargetProperty="StrokeDashOffset"
                                         From="0"
                                         To="-43.2"
                                         Duration="0:0:3.7" />
                        <DoubleAnimation Storyboard.TargetName="EchoArc"
                                         Storyboard.TargetProperty="StrokeDashOffset"
                                         From="0"
                                         To="23.6"
                                         Duration="0:0:3.7" />
                        <DoubleAnimation Storyboard.TargetName="CoreRotate"
                                         Storyboard.TargetProperty="Angle"
                                         From="0"
                                         To="360"
                                         Duration="0:0:3.7" />

                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CoreScale"
                                                       Storyboard.TargetProperty="ScaleX">
                            <SplineDoubleKeyFrame KeyTime="0:0:0" Value="0.82" />
                            <SplineDoubleKeyFrame KeyTime="0:0:0.92" Value="1.28" KeySpline="0.26,0 0.14,1" />
                            <SplineDoubleKeyFrame KeyTime="0:0:1.91" Value="0.9" KeySpline="0.42,0 0.16,1" />
                            <SplineDoubleKeyFrame KeyTime="0:0:2.83" Value="1.12" KeySpline="0.2,0 0.12,1" />
                            <SplineDoubleKeyFrame KeyTime="0:0:3.7" Value="0.82" KeySpline="0.26,0 0.16,1" />
                        </DoubleAnimationUsingKeyFrames>
                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CoreScale"
                                                       Storyboard.TargetProperty="ScaleY">
                            <SplineDoubleKeyFrame KeyTime="0:0:0" Value="0.82" />
                            <SplineDoubleKeyFrame KeyTime="0:0:0.92" Value="0.78" KeySpline="0.26,0 0.14,1" />
                            <SplineDoubleKeyFrame KeyTime="0:0:1.91" Value="1.18" KeySpline="0.42,0 0.16,1" />
                            <SplineDoubleKeyFrame KeyTime="0:0:2.83" Value="0.94" KeySpline="0.2,0 0.12,1" />
                            <SplineDoubleKeyFrame KeyTime="0:0:3.7" Value="0.82" KeySpline="0.26,0 0.16,1" />
                        </DoubleAnimationUsingKeyFrames>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Grid.Triggers>

        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F7080711" Offset="0" />
                <GradientStop Color="#F30B141A" Offset="0.5" />
                <GradientStop Color="#F5101922" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <Border Width="620"
                MaxWidth="620"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Margin="28"
                Padding="26"
                Background="#E8111C21"
                BorderBrush="#31515A"
                BorderThickness="1"
                CornerRadius="16">
            <Border.Effect>
                <DropShadowEffect Color="#03090B"
                                  BlurRadius="34"
                                  ShadowDepth="14"
                                  Opacity="0.45" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="22" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="22" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid Width="110"
                          Height="110"
                          HorizontalAlignment="Left">
                        <Ellipse Width="94"
                                 Height="94"
                                 Stroke="#244047"
                                 StrokeThickness="7"
                                 Opacity="0.95" />

                        <Grid x:Name="SpinnerLayer">
                            <Ellipse x:Name="MainArc"
                                     Width="94"
                                     Height="94"
                                     Stroke="#5EEAD4"
                                     StrokeThickness="7"
                                     StrokeStartLineCap="Round"
                                     StrokeEndLineCap="Round"
                                     StrokeDashCap="Round"
                                     StrokeDashArray="6.4 15.2"
                                     RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <RotateTransform x:Name="MainArcRotate" />
                                </Ellipse.RenderTransform>
                            </Ellipse>

                            <Ellipse x:Name="EchoArc"
                                     Width="62"
                                     Height="62"
                                     Stroke="#F7F4FF"
                                     StrokeThickness="4"
                                     StrokeStartLineCap="Round"
                                     StrokeEndLineCap="Round"
                                     StrokeDashCap="Round"
                                     StrokeDashArray="2.2 9.6"
                                     Opacity="0.42"
                                     RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <RotateTransform x:Name="EchoArcRotate" />
                                </Ellipse.RenderTransform>
                            </Ellipse>

                            <Border Width="28"
                                    Height="28"
                                    CornerRadius="14"
                                    Background="{StaticResource PackageCoreBrush}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform x:Name="CoreScale" />
                                        <RotateTransform x:Name="CoreRotate" />
                                    </TransformGroup>
                                </Border.RenderTransform>
                            </Border>
                        </Grid>

                        <Grid x:Name="DoneLayer"
                              Opacity="0">
                            <Ellipse Width="94"
                                     Height="94"
                                     Stroke="#5EEAD4"
                                     StrokeThickness="7"
                                     Opacity="0.92" />
                            <TextBlock x:Name="StateGlyph"
                                       FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE73E;"
                                       FontSize="38"
                                       Foreground="{StaticResource PackageSuccessBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Grid>

                    <StackPanel Grid.Column="2"
                                VerticalAlignment="Center">
                        <TextBlock Text="Упаковка сборки"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource PackageMutedTextBrush}" />
                        <TextBlock x:Name="StepText"
                                   Text="{Binding CurrentStep}"
                                   Margin="0,5,0,0"
                                   FontSize="29"
                                   FontWeight="Black"
                                   Foreground="{StaticResource PackageTextBrush}"
                                   TextWrapping="Wrap"
                                   RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform>
                                <TranslateTransform x:Name="StepTranslate" />
                            </TextBlock.RenderTransform>
                        </TextBlock>
                        <TextBlock Text="{Binding StatusText}"
                                   Margin="0,8,0,0"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource PackageSecondaryTextBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.1*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <Border Background="#0D171B"
                            BorderBrush="#263B43"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="6" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Сборка"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource PackageSubtleTextBrush}" />
                            <TextBlock Grid.Row="2"
                                       Text="{Binding BuildName}"
                                       FontSize="17"
                                       FontWeight="Black"
                                       Foreground="{StaticResource PackageTextBrush}"
                                       TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </Border>

                    <Border Grid.Column="2"
                            Background="#0D171B"
                            BorderBrush="#263B43"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="6" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Состав"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource PackageSubtleTextBrush}" />
                            <TextBlock Grid.Row="2"
                                       Text="{Binding CompositionText}"
                                       FontSize="13"
                                       FontWeight="Black"
                                       Foreground="{StaticResource PackageTextBrush}"
                                       TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </Border>
                </Grid>

                <UniformGrid Grid.Row="4"
                             Columns="4"
                             Rows="1">
                    <Border Margin="0,0,8,0">
                        <Border.Style>
                            <Style TargetType="{x:Type Border}" BasedOn="{StaticResource PackageStepCardStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding PrepareStepState}" Value="Complete">
                                        <Setter Property="Opacity" Value="1" />
                                        <Setter Property="Background" Value="#14313A" />
                                        <Setter Property="BorderBrush" Value="#22D3EE" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding PrepareStepState}" Value="Active">
                                        <Setter Property="Opacity" Value="1" />
                                        <Setter Property="Background" Value="#192D34" />
                                        <Setter Property="BorderBrush" Value="#5EEAD4" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <Border Style="{StaticResource PackageStepIconShellStyle}">
                                <controls:LineIcon Data="{StaticResource Icon.FileText}"
                                                   Width="17"
                                                   Height="17"
                                                   Foreground="{StaticResource PackageSecondaryTextBrush}" />
                            </Border>
                            <TextBlock Text="Проверка"
                                       Margin="0,10,0,0"
                                       FontWeight="Black"
                                       Foreground="{StaticResource PackageTextBrush}" />
                            <TextBlock Text="Конфиг"
                                       Margin="0,3,0,0"
                                       FontSize="11"
                                       Foreground="{StaticResource PackageMutedTextBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Margin="0,0,8,0">
                        <Border.Style>
                            <Style TargetType="{x:Type Border}" BasedOn="{StaticResource PackageStepCardStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CompositionStepState}" Value="Complete">
                                        <Setter Property="Opacity" Value="1" />
                                        <Setter Property="Background" Value="#14313A" />
                                        <Setter Property="BorderBrush" Value="#22D3EE" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CompositionStepState}" Value="Active">
                                        <Setter Property="Opacity" Value="1" />
                                        <Setter Property="Background" Value="#192D34" />
                                        <Setter Property="BorderBrush" Value="#5EEAD4" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <Border Style="{StaticResource PackageStepIconShellStyle}">
                                <controls:LineIcon Data="{StaticResource Icon.Layers}"
                                                   Width="18"
                                                   Height="18"
                                                   Foreground="{StaticResource PackageSecondaryTextBrush}" />
                            </Border>
                            <TextBlock Text="Состав"
                                       Margin="0,10,0,0"
                                       FontWeight="Black"
                                       Foreground="{StaticResource PackageTextBrush}" />
                            <TextBlock Text="Моды"
                                       Margin="0,3,0,0"
                                       FontSize="11"
                                       Foreground="{StaticResource PackageMutedTextBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Margin="0,0,8,0">
                        <Border.Style>
                            <Style TargetType="{x:Type Border}" BasedOn="{StaticResource PackageStepCardStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ExportStepState}" Value="Complete">
                                        <Setter Property="Opacity" Value="1" />
                                        <Setter Property="Background" Value="#14313A" />
                                        <Setter Property="BorderBrush" Value="#22D3EE" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ExportStepState}" Value="Active">
                                        <Setter Property="Opacity" Value="1" />
                                        <Setter Property="Background" Value="#192D34" />
                                        <Setter Property="BorderBrush" Value="#5EEAD4" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <Border Style="{StaticResource PackageStepIconShellStyle}">
                                <controls:LineIcon Data="{StaticResource Icon.Folder}"
                                                   Width="18"
                                                   Height="18"
                                                   Foreground="{StaticResource PackageSecondaryTextBrush}" />
                            </Border>
                            <TextBlock Text="Запись"
                                       Margin="0,10,0,0"
                                       FontWeight="Black"
                                       Foreground="{StaticResource PackageTextBrush}" />
                            <TextBlock Text="FluxPack"
                                       Margin="0,3,0,0"
                                       FontSize="11"
                                       Foreground="{StaticResource PackageMutedTextBrush}" />
                        </StackPanel>
                    </Border>

                    <Border>
                        <Border.Style>
                            <Style TargetType="{x:Type Border}" BasedOn="{StaticResource PackageStepCardStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SummaryStepState}" Value="Complete">
                                        <Setter Property="Opacity" Value="1" />
                                        <Setter Property="Background" Value="#14313A" />
                                        <Setter Property="BorderBrush" Value="#22D3EE" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SummaryStepState}" Value="Active">
                                        <Setter Property="Opacity" Value="1" />
                                        <Setter Property="Background" Value="#192D34" />
                                        <Setter Property="BorderBrush" Value="#5EEAD4" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <Border Style="{StaticResource PackageStepIconShellStyle}">
                                <controls:LineIcon Data="{StaticResource Icon.Open}"
                                                   Width="18"
                                                   Height="18"
                                                   Foreground="{StaticResource PackageSecondaryTextBrush}" />
                            </Border>
                            <TextBlock Text="Итог"
                                       Margin="0,10,0,0"
                                       FontWeight="Black"
                                       Foreground="{StaticResource PackageTextBrush}" />
                            <TextBlock Text="Файл"
                                       Margin="0,3,0,0"
                                       FontSize="11"
                                       Foreground="{StaticResource PackageMutedTextBrush}" />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <StackPanel Grid.Row="6">
                    <Grid Margin="0,0,0,9">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding OutputPath}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource PackageMutedTextBrush}"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Value, ElementName=OverallBar, StringFormat={}{0:0}%}"
                                   FontSize="13"
                                   FontWeight="Black"
                                   Foreground="{StaticResource PackageTextBrush}" />
                    </Grid>

                    <ProgressBar x:Name="OverallBar"
                                 Style="{StaticResource PackageProgressBarStyle}"
                                 services:ProgressAnimationService.IsActive="{Binding IsRunning}"
                                 services:SmoothProgressService.TargetValue="{Binding OverallPercent}" />

                    <TextBlock Text="{Binding SummaryText}"
                               Margin="0,10,0,0"
                               FontSize="11"
                               Foreground="{StaticResource PackageMutedTextBrush}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap" />

                    <Border Background="#2A1220"
                            BorderBrush="#7F1D3A"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="12"
                            Margin="0,16,0,0"
                            Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="{StaticResource PackageErrorBrush}"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap" />
                    </Border>

                    <Button Style="{StaticResource PackageButtonStyle}"
                            Content="Закрыть"
                            HorizontalAlignment="Center"
                            MinWidth="132"
                            Margin="0,22,0,0"
                            Visibility="{Binding CanClose, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Command="{Binding CloseCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Height="1"
                VerticalAlignment="Top"
                Background="#31515A"
                Opacity="0.34" />
    </Grid>
</UserControl>
