<Application x:Class="Fluxora.Installer.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Assets/Icons.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <FontFamily x:Key="FluxoraFontBody">./Fonts/#Onest, Segoe UI Variable, Segoe UI</FontFamily>
            <FontFamily x:Key="FluxoraFontDisplay">./Fonts/#Unbounded, Segoe UI Variable, Segoe UI</FontFamily>

            <Style TargetType="{x:Type TextBlock}">
                <Style.Triggers>
                    <Trigger Property="FontWeight" Value="Black">
                        <Setter Property="FontFamily" Value="{StaticResource FluxoraFontDisplay}" />
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
