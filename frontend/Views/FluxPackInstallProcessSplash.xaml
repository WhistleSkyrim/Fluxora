<UserControl x:Class="Fluxora.App.Views.FluxPackInstallProcessSplash"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:services="clr-namespace:Fluxora.App.Services"
             IsHitTestVisible="{Binding IsVisible}"
             FontFamily="{StaticResource FluxoraFontBody}"
             FontWeight="Medium"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             TextOptions.TextHintingMode="Fixed"
             RenderOptions.ClearTypeHint="Enabled"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <SolidColorBrush x:Key="InstallTextBrush" Color="#F7F4FF" />
        <SolidColorBrush x:Key="InstallSecondaryTextBrush" Color="#DDE7F0" />
        <SolidColorBrush x:Key="InstallMutedTextBrush" Color="#9BAEC0" />
        <SolidColorBrush x:Key="InstallPanelBrush" Color="#111A20" />
        <SolidColorBrush x:Key="InstallPanelSoftBrush" Color="#17232B" />
        <SolidColorBrush x:Key="InstallBorderBrush" Color="#314555" />
        <SolidColorBrush x:Key="InstallErrorBrush" Color="#FB7185" />
        <SolidColorBrush x:Key="InstallSuccessBrush" Color="#5EEAD4" />

        <LinearGradientBrush x:Key="InstallProgressBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#5EEAD4" Offset="0" />
            <GradientStop Color="#38BDF8" Offset="0.5" />
            <GradientStop Color="#A78BFA" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="InstallProgressBarStyle" TargetType="{x:Type ProgressBar}">
            <Setter Property="Height" Value="9" />
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="100" />
            <Setter Property="Foreground" Value="{StaticResource InstallProgressBrush}" />
            <Setter Property="Background" Value="#0B1117" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ProgressBar}">
                        <Grid Height="{TemplateBinding Height}" ClipToBounds="True">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="#263846"
                                    BorderThickness="1"
                                    CornerRadius="5" />
                            <Decorator x:Name="PART_Indicator"
                                       HorizontalAlignment="Left"
                                       ClipToBounds="True">
                                <Border Background="{TemplateBinding Foreground}"
                                        CornerRadius="5" />
                            </Decorator>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InstallCloseButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource InstallSecondaryTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="#182632"
                                BorderBrush="{StaticResource InstallBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"
                                              TextElement.FontWeight="{TemplateBinding FontWeight}"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#203444" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#5EEAD4" />
                                <Setter Property="Foreground" Value="{StaticResource InstallTextBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.42" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <UserControl.Style>
        <Style TargetType="{x:Type UserControl}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsVisible}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Style>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F50A0D14" Offset="0" />
                <GradientStop Color="#F0111820" Offset="0.55" />
                <GradientStop Color="#F40B1018" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <Border Width="660"
                MaxWidth="660"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Margin="28"
                Padding="26"
                Background="{StaticResource InstallPanelBrush}"
                BorderBrush="{StaticResource InstallBorderBrush}"
                BorderThickness="1"
                CornerRadius="14">
            <Border.Effect>
                <DropShadowEffect Color="#03090B"
                                  BlurRadius="34"
                                  ShadowDepth="14"
                                  Opacity="0.45" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid Width="62"
                          Height="62"
                          Margin="0,0,18,0">
                        <Ellipse Stroke="#2C4655"
                                 StrokeThickness="2"
                                 Fill="#111A20" />
                        <Path Data="M 31,6 A 25,25 0 1 1 30.9,6"
                              Stroke="{StaticResource InstallProgressBrush}"
                              StrokeThickness="3"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Fill="{x:Null}"
                              RenderTransformOrigin="0.5,0.5">
                            <Path.RenderTransform>
                                <RotateTransform />
                            </Path.RenderTransform>
                            <Path.Triggers>
                                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetProperty="(Path.RenderTransform).(RotateTransform.Angle)"
                                                             From="0"
                                                             To="360"
                                                             Duration="0:0:2.4" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Path.Triggers>
                        </Path>
                        <TextBlock Text="FP"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="17"
                                   FontWeight="Black"
                                   Foreground="{StaticResource InstallTextBrush}" />
                    </Grid>

                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentStep}"
                                   FontSize="24"
                                   FontWeight="Black"
                                   Foreground="{StaticResource InstallTextBrush}"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding StatusText}"
                                   Margin="0,6,0,0"
                                   FontSize="13"
                                   Foreground="{StaticResource InstallSecondaryTextBrush}"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding CurrentItem}"
                                   Margin="0,3,0,0"
                                   FontSize="12"
                                   Foreground="{StaticResource InstallMutedTextBrush}"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Grid>

                <ProgressBar Grid.Row="1"
                             Margin="0,24,0,8"
                             Style="{StaticResource InstallProgressBarStyle}"
                             services:ProgressAnimationService.IsActive="{Binding IsRunning}"
                             Value="{Binding OverallPercent, Mode=OneWay}" />

                <Grid Grid.Row="2"
                      Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding SourceSummaryText}"
                               FontSize="12"
                               Foreground="{StaticResource InstallMutedTextBrush}"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding OverallPercent, StringFormat={}{0}%}"
                               Margin="16,0,0,0"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="{StaticResource InstallTextBrush}" />
                </Grid>

                <ScrollViewer Grid.Row="3"
                              MaxHeight="260"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Providers}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10"
                                        Padding="12"
                                        Background="{StaticResource InstallPanelSoftBrush}"
                                        BorderBrush="#293C4B"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Width="38"
                                                Height="38"
                                                CornerRadius="19"
                                                Background="{Binding AccentBrush}"
                                                VerticalAlignment="Top">
                                            <TextBlock Text="{Binding IconText}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="12"
                                                       FontWeight="Black"
                                                       Foreground="#111827" />
                                        </Border>

                                        <Grid Grid.Column="1"
                                              Margin="12,0,0,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontSize="14"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource InstallTextBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding CountText}"
                                                       Margin="14,0,0,0"
                                                       FontSize="12"
                                                       Foreground="{StaticResource InstallMutedTextBrush}" />

                                            <ProgressBar Grid.Row="1"
                                                         Grid.ColumnSpan="2"
                                                         Margin="0,10,0,7"
                                                         Style="{StaticResource InstallProgressBarStyle}"
                                                         Foreground="{Binding AccentBrush}"
                                                         Value="{Binding ProgressPercent, Mode=OneWay}" />

                                            <Grid Grid.Row="2"
                                                  Grid.ColumnSpan="2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding CurrentItem}"
                                                           FontSize="12"
                                                           Foreground="{StaticResource InstallSecondaryTextBrush}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding StatusText}"
                                                           Margin="14,0,0,0"
                                                           FontSize="12"
                                                           FontWeight="Bold"
                                                           Foreground="{Binding AccentBrush}" />
                                            </Grid>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Grid Grid.Row="4"
                      Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding ResultText}"
                                   FontSize="12"
                                   Foreground="{StaticResource InstallSuccessBrush}"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Margin="0,4,0,0"
                                   FontSize="12"
                                   Foreground="{StaticResource InstallErrorBrush}"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>

                    <Button Grid.Column="1"
                            Style="{StaticResource InstallCloseButtonStyle}"
                            Command="{Binding RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Path=CloseCommand}"
                            IsEnabled="{Binding CanClose}"
                            Content="Закрыть" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
