<UserControl x:Class="Fluxora.App.Views.ExecutableLaunchProcessSplash"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:services="clr-namespace:Fluxora.App.Services"
             xmlns:controls="clr-namespace:Fluxora.App.Controls"
             IsHitTestVisible="{Binding IsVisible}"
             FontFamily="{StaticResource FluxoraFontBody}"
             FontWeight="Medium"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             TextOptions.TextHintingMode="Fixed"
             RenderOptions.ClearTypeHint="Enabled"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <SolidColorBrush x:Key="LaunchTextBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="LaunchSecondaryTextBrush" Color="#BFE9E6" />
        <SolidColorBrush x:Key="LaunchMutedTextBrush" Color="#8AA6A4" />
        <SolidColorBrush x:Key="LaunchErrorBrush" Color="#FB7185" />

        <LinearGradientBrush x:Key="LaunchCoreBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F8FAFC" Offset="0" />
            <GradientStop Color="#5EEAD4" Offset="0.45" />
            <GradientStop Color="#38BDF8" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="LaunchProgressBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#5EEAD4" Offset="0" />
            <GradientStop Color="#38BDF8" Offset="0.58" />
            <GradientStop Color="#A78BFA" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="LaunchProgressBarStyle" TargetType="{x:Type ProgressBar}">
            <Setter Property="Height" Value="9" />
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="100" />
            <Setter Property="Foreground" Value="{StaticResource LaunchProgressBrush}" />
            <Setter Property="Background" Value="#102127" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ProgressBar}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="#24515A"
                                BorderThickness="1"
                                CornerRadius="5"
                                ClipToBounds="True">
                            <Grid x:Name="PART_Track">
                                <Rectangle x:Name="PART_Indicator"
                                           HorizontalAlignment="Left"
                                           Fill="{TemplateBinding Foreground}"
                                           RadiusX="5"
                                           RadiusY="5" />
                                <Border x:Name="ProgressSheen"
                                        Width="78"
                                        HorizontalAlignment="Left"
                                        Opacity="0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#00FFFFFF" Offset="0" />
                                            <GradientStop Color="#88FFFFFF" Offset="0.48" />
                                            <GradientStop Color="#00FFFFFF" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.RenderTransform>
                                        <TranslateTransform x:Name="ProgressSheenTranslate" X="-84" />
                                    </Border.RenderTransform>
                                </Border>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="services:ProgressAnimationService.IsActive" Value="True">
                                <Setter TargetName="ProgressSheen" Property="Opacity" Value="0.26" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard x:Name="LaunchProgressStoryboard">
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetName="ProgressSheenTranslate"
                                                             Storyboard.TargetProperty="X"
                                                             From="-84"
                                                             To="390"
                                                             Duration="0:0:1.8" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <RemoveStoryboard BeginStoryboardName="LaunchProgressStoryboard" />
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LaunchGhostButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="20,0" />
            <Setter Property="Background" Value="#11242B" />
            <Setter Property="BorderBrush" Value="#2C5C65" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource LaunchTextBrush}" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"
                                              TextElement.FontWeight="{TemplateBinding FontWeight}"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#17313A" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#5EEAD4" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.42" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <UserControl.Style>
        <Style TargetType="{x:Type UserControl}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsVisible}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Style>

    <Grid>
        <Grid.Triggers>
            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                <BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever">
                        <DoubleAnimation Storyboard.TargetName="OuterArcRotate"
                                         Storyboard.TargetProperty="Angle"
                                         From="-20"
                                         To="700"
                                         Duration="0:0:3.5" />
                        <DoubleAnimation Storyboard.TargetName="InnerArcRotate"
                                         Storyboard.TargetProperty="Angle"
                                         From="32"
                                         To="-688"
                                         Duration="0:0:3.5" />
                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CoreScale"
                                                       Storyboard.TargetProperty="ScaleX">
                            <SplineDoubleKeyFrame KeyTime="0:0:0" Value="0.86" />
                            <SplineDoubleKeyFrame KeyTime="0:0:1.12" Value="1.2" KeySpline="0.2,0 0.16,1" />
                            <SplineDoubleKeyFrame KeyTime="0:0:3.5" Value="0.86" KeySpline="0.28,0 0.16,1" />
                        </DoubleAnimationUsingKeyFrames>
                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CoreScale"
                                                       Storyboard.TargetProperty="ScaleY">
                            <SplineDoubleKeyFrame KeyTime="0:0:0" Value="0.86" />
                            <SplineDoubleKeyFrame KeyTime="0:0:1.12" Value="1.2" KeySpline="0.2,0 0.16,1" />
                            <SplineDoubleKeyFrame KeyTime="0:0:3.5" Value="0.86" KeySpline="0.28,0 0.16,1" />
                        </DoubleAnimationUsingKeyFrames>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Grid.Triggers>

        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F6070A12" Offset="0" />
                <GradientStop Color="#F10A161B" Offset="0.5" />
                <GradientStop Color="#F40D1424" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid Width="460"
              MaxWidth="460"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="22" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="9" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="24" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Width="118"
                  Height="118"
                  HorizontalAlignment="Center">
                <Ellipse Width="100"
                         Height="100"
                         Stroke="#1C3A42"
                         StrokeThickness="7" />
                <Ellipse Width="100"
                         Height="100"
                         Stroke="#5EEAD4"
                         StrokeThickness="7"
                         StrokeStartLineCap="Round"
                         StrokeEndLineCap="Round"
                         StrokeDashArray="5.8 14.6"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <RotateTransform x:Name="OuterArcRotate" />
                    </Ellipse.RenderTransform>
                </Ellipse>
                <Ellipse Width="66"
                         Height="66"
                         Stroke="#A78BFA"
                         StrokeThickness="4"
                         StrokeStartLineCap="Round"
                         StrokeEndLineCap="Round"
                         StrokeDashArray="2.4 8.4"
                         Opacity="0.48"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <RotateTransform x:Name="InnerArcRotate" />
                    </Ellipse.RenderTransform>
                </Ellipse>
                <Border Width="30"
                        Height="30"
                        CornerRadius="15"
                        Background="{StaticResource LaunchCoreBrush}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <ScaleTransform x:Name="CoreScale" />
                    </Border.RenderTransform>
                </Border>
            </Grid>

            <TextBlock Grid.Row="2"
                       Text="{Binding Title}"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource LaunchMutedTextBrush}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center" />

            <TextBlock Grid.Row="4"
                       Text="{Binding CurrentStep}"
                       FontSize="28"
                       FontWeight="Black"
                       Foreground="{StaticResource LaunchTextBrush}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       MaxWidth="460" />

            <StackPanel Grid.Row="6">
                <TextBlock Text="{Binding StatusText}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource LaunchSecondaryTextBrush}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="440"
                           Margin="0,0,0,18" />

                <Grid>
                    <Grid.Style>
                        <Style TargetType="{x:Type Grid}">
                            <Setter Property="Opacity" Value="1" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsStarting}" Value="False">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 To="0"
                                                                 Duration="0:0:0.32">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 To="1"
                                                                 Duration="0:0:0.18">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>

                    <ProgressBar Style="{StaticResource LaunchProgressBarStyle}"
                                 services:ProgressAnimationService.IsActive="{Binding IsSpinnerActive}"
                                 services:SmoothProgressService.TargetValue="{Binding OverallPercent}" />
                </Grid>

                <Border Background="#2A1220"
                        BorderBrush="#7F1D3A"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="12"
                        Margin="0,16,0,0"
                        Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{StaticResource LaunchErrorBrush}"
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                </Border>

                <Button Style="{StaticResource LaunchGhostButtonStyle}"
                        Content="{Binding CloseButtonText}"
                        HorizontalAlignment="Center"
                        MinWidth="132"
                        Margin="0,22,0,0"
                        Visibility="{Binding CanClose, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Command="{Binding CloseCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" />
            </StackPanel>
        </Grid>

        <Border Height="1"
                VerticalAlignment="Top"
                Background="#24515A"
                Opacity="0.32" />
    </Grid>
</UserControl>
