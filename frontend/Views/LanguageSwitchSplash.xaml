<UserControl x:Class="Fluxora.App.Views.LanguageSwitchSplash"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             IsHitTestVisible="{Binding IsLanguageSwitching}"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <SolidColorBrush x:Key="SplashTextBrush" Color="#F7F4FF" />
        <SolidColorBrush x:Key="SplashSecondaryTextBrush" Color="#C5BEDA" />

        <LinearGradientBrush x:Key="SplashCoreBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F7F4FF" Offset="0" />
            <GradientStop Color="#C4B5FD" Offset="0.45" />
            <GradientStop Color="#8B5CF6" Offset="1" />
        </LinearGradientBrush>
    </UserControl.Resources>

    <UserControl.Style>
        <Style TargetType="{x:Type UserControl}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsLanguageSwitching}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Style>

    <Grid>
        <Grid.Triggers>
            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                <BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever">
                        <DoubleAnimation Storyboard.TargetName="MainArcRotate"
                                         Storyboard.TargetProperty="Angle"
                                         From="-24"
                                         To="696"
                                         Duration="0:0:2.6" />
                        <DoubleAnimation Storyboard.TargetName="EchoArcRotate"
                                         Storyboard.TargetProperty="Angle"
                                         From="42"
                                         To="-678"
                                         Duration="0:0:2.6" />
                        <DoubleAnimation Storyboard.TargetName="CoreRotate"
                                         Storyboard.TargetProperty="Angle"
                                         From="0"
                                         To="360"
                                         Duration="0:0:2.6" />
                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="PulseLayer"
                                                       Storyboard.TargetProperty="Opacity">
                            <SplineDoubleKeyFrame KeyTime="0:0:0" Value="0.08" />
                            <SplineDoubleKeyFrame KeyTime="0:0:1.2" Value="0.24" KeySpline="0.2,0 0.16,1" />
                            <SplineDoubleKeyFrame KeyTime="0:0:2.6" Value="0.08" KeySpline="0.28,0 0.16,1" />
                        </DoubleAnimationUsingKeyFrames>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Grid.Triggers>

        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F4080711" Offset="0" />
                <GradientStop Color="#F20D0A18" Offset="0.52" />
                <GradientStop Color="#F5121022" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid Width="420"
              MaxWidth="420"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="24" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="8" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Width="112"
                  Height="112"
                  HorizontalAlignment="Center">
                <Ellipse Width="94"
                         Height="94"
                         Stroke="#2B2444"
                         StrokeThickness="7"
                         Opacity="0.9" />

                <Ellipse x:Name="PulseLayer"
                         Width="72"
                         Height="72"
                         Fill="#241A46"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         Opacity="0.08" />

                <Ellipse Width="94"
                         Height="94"
                         Stroke="#A78BFA"
                         StrokeThickness="7"
                         StrokeStartLineCap="Round"
                         StrokeEndLineCap="Round"
                         StrokeDashCap="Round"
                         StrokeDashArray="5.8 13.4"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <RotateTransform x:Name="MainArcRotate" />
                    </Ellipse.RenderTransform>
                </Ellipse>

                <Ellipse Width="62"
                         Height="62"
                         Stroke="#F7F4FF"
                         StrokeThickness="4"
                         StrokeStartLineCap="Round"
                         StrokeEndLineCap="Round"
                         StrokeDashCap="Round"
                         StrokeDashArray="2 8.4"
                         Opacity="0.42"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <RotateTransform x:Name="EchoArcRotate" />
                    </Ellipse.RenderTransform>
                </Ellipse>

                <Border Width="27"
                        Height="27"
                        CornerRadius="14"
                        Background="{StaticResource SplashCoreBrush}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <RotateTransform x:Name="CoreRotate" />
                    </Border.RenderTransform>
                </Border>
            </Grid>

            <TextBlock Grid.Row="2"
                       Text="{Binding LanguageSwitchTitle}"
                       FontSize="28"
                       FontWeight="Black"
                       Foreground="{StaticResource SplashTextBrush}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap" />

            <TextBlock Grid.Row="4"
                       Text="{Binding LanguageSwitchSubtitle}"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource SplashSecondaryTextBrush}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       MaxWidth="400" />
        </Grid>

        <Border Height="1"
                VerticalAlignment="Top"
                Background="#2E2550"
                Opacity="0.36" />
    </Grid>
</UserControl>
