<Window x:Class="Fluxora.App.BuildSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:controls="clr-namespace:Fluxora.App.Controls"
        xmlns:services="clr-namespace:Fluxora.App.Services"
        Title="Настройки сборки"
        Width="900"
        Height="560"
        MinWidth="760"
        MinHeight="500"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#080711"
        FontFamily="{StaticResource FluxoraFontBody}"
        FontWeight="Medium"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextHintingMode="Fixed"
        RenderOptions.ClearTypeHint="Enabled"
        FontSize="13"
        Loaded="OnLoaded">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="56"
                            CornerRadius="10"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="7"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <services:InverseBooleanConverter x:Key="InverseBooleanConverter" />

        <SolidColorBrush x:Key="TextBrush" Color="#F7F4FF" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#C5BEDA" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#918AA8" />
        <SolidColorBrush x:Key="SubtleTextBrush" Color="#736D86" />
        <SolidColorBrush x:Key="AccentBrush" Color="#7C3AED" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#8B5CF6" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#241A46" />
        <SolidColorBrush x:Key="AccentLineBrush" Color="#493184" />
        <SolidColorBrush x:Key="PanelBrush" Color="#171523" />
        <SolidColorBrush x:Key="PanelRaisedBrush" Color="#201D31" />
        <SolidColorBrush x:Key="PanelSoftBrush" Color="#11101B" />
        <SolidColorBrush x:Key="PanelHoverBrush" Color="#27223A" />
        <SolidColorBrush x:Key="LineBrush" Color="#302B46" />
        <SolidColorBrush x:Key="LineHoverBrush" Color="#55467D" />
        <SolidColorBrush x:Key="ErrorBrush" Color="#FB7185" />

        <LinearGradientBrush x:Key="AppBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#080711" Offset="0" />
            <GradientStop Color="#0D0A18" Offset="0.48" />
            <GradientStop Color="#121022" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#8B5CF6" Offset="0" />
            <GradientStop Color="#6D5DFB" Offset="0.62" />
            <GradientStop Color="#5B21B6" Offset="1" />
        </LinearGradientBrush>

        <DropShadowEffect x:Key="PanelShadow"
                          Color="#05030B"
                          BlurRadius="30"
                          ShadowDepth="12"
                          Opacity="0.36" />

        <Style x:Key="PanelBorderStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Effect" Value="{StaticResource PanelShadow}" />
        </Style>

        <Style x:Key="InnerPanelStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{StaticResource PanelRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>

        <Style x:Key="CaptionButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="56" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Cursor" Value="Arrow" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root" Background="{TemplateBinding Background}">
                            <Viewbox Width="16"
                                     Height="16"
                                     Stretch="Uniform"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                                <Path Width="24"
                                      Height="24"
                                      Data="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"
                                      Stroke="{TemplateBinding Foreground}"
                                      StrokeThickness="1.8"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round" />
                            </Viewbox>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#BE123C" />
                                <Setter Property="Foreground" Value="#F7F4FF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#9F1239" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BaseButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="15,0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"
                                              TextElement.FontWeight="{TemplateBinding FontWeight}"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource PanelHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
            <Setter Property="Foreground" Value="#F7F4FF" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentHoverBrush}" />
                    <Setter Property="BorderBrush" Value="#B197FC" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="{StaticResource PanelRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource LineHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="20,0,10,0" />
            <Setter Property="Background" Value="#332B47" />
            <Setter Property="BorderBrush" Value="#7A63B8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Arrow" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="9" />
                            <Border Width="6"
                                    Height="24"
                                    CornerRadius="4"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Background="{StaticResource AccentGradientBrush}" />
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              TextElement.FontWeight="{TemplateBinding FontWeight}"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PathTextBoxStyle" TargetType="{x:Type TextBox}">
            <Setter Property="Height" Value="38" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="FontFamily" Value="{StaticResource FluxoraFontBody}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Background" Value="{StaticResource PanelSoftBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="CaretBrush" Value="{StaticResource TextBrush}" />
            <Setter Property="SelectionBrush" Value="{StaticResource AccentLineBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Hidden" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ToolTip" Value="{Binding Text, RelativeSource={RelativeSource Self}}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          ClipToBounds="True"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Disabled" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PathLabelStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Geometry x:Key="FluxoraScrollArrowUpGeometry">M 0 5 L 4 1 L 8 5 Z</Geometry>
        <Geometry x:Key="FluxoraScrollArrowDownGeometry">M 0 1 L 8 1 L 4 5 Z</Geometry>
        <Geometry x:Key="FluxoraScrollArrowLeftGeometry">M 5 0 L 1 4 L 5 8 Z</Geometry>
        <Geometry x:Key="FluxoraScrollArrowRightGeometry">M 1 0 L 5 4 L 1 8 Z</Geometry>

        <Style x:Key="FluxoraVerticalScrollThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="Bar"
                                    Background="{StaticResource LineHoverBrush}"
                                    Width="7"
                                    MinHeight="34"
                                    Margin="0,1"
                                    CornerRadius="3.5"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Stretch" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bar" Property="Background" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="Bar" Property="Background" Value="{StaticResource AccentHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FluxoraHorizontalScrollThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="MinWidth" Value="34" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="Bar"
                                    Background="{StaticResource LineHoverBrush}"
                                    Width="34"
                                    Height="7"
                                    Margin="1,0"
                                    CornerRadius="3.5"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bar" Property="Background" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="Bar" Property="Background" Value="{StaticResource AccentHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FluxoraScrollLineButtonStyle" TargetType="{x:Type RepeatButton}">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Delay" Value="280" />
            <Setter Property="Interval" Value="45" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <Path x:Name="Arrow"
                                  Data="{TemplateBinding Content}"
                                  Width="8"
                                  Height="5"
                                  Fill="{StaticResource MutedTextBrush}"
                                  Stretch="Uniform"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource PanelHoverBrush}" />
                                <Setter TargetName="Arrow" Property="Fill" Value="{StaticResource TextSecondaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                <Setter TargetName="Arrow" Property="Fill" Value="{StaticResource AccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Arrow" Property="Opacity" Value="0.35" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FluxoraScrollPageButtonStyle" TargetType="{x:Type RepeatButton}">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Width" Value="18" />
            <Setter Property="MinWidth" Value="18" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Background="{TemplateBinding Background}"
                              ClipToBounds="False">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="12" />
                                <RowDefinition Height="3" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="3" />
                                <RowDefinition Height="12" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="7" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <RepeatButton Grid.ColumnSpan="3"
                                          Style="{StaticResource FluxoraScrollLineButtonStyle}"
                                          Command="ScrollBar.LineUpCommand"
                                          Content="{StaticResource FluxoraScrollArrowUpGeometry}" />
                            <Track x:Name="PART_Track"
                                   Grid.Row="2"
                                   Grid.Column="1"
                                   Orientation="Vertical"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource FluxoraScrollPageButtonStyle}"
                                                  Command="ScrollBar.PageUpCommand" />
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource FluxoraScrollPageButtonStyle}"
                                                  Command="ScrollBar.PageDownCommand" />
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource FluxoraVerticalScrollThumbStyle}" />
                                </Track.Thumb>
                            </Track>
                            <RepeatButton Grid.Row="4"
                                          Grid.ColumnSpan="3"
                                          Style="{StaticResource FluxoraScrollLineButtonStyle}"
                                          Command="ScrollBar.LineDownCommand"
                                          Content="{StaticResource FluxoraScrollArrowDownGeometry}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto" />
                    <Setter Property="MinWidth" Value="0" />
                    <Setter Property="Height" Value="18" />
                    <Setter Property="MinHeight" Value="18" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type ScrollBar}">
                                <Grid Background="{TemplateBinding Background}"
                                      ClipToBounds="False">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="7" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="3" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="3" />
                                        <ColumnDefinition Width="12" />
                                    </Grid.ColumnDefinitions>
                                    <RepeatButton Grid.RowSpan="3"
                                                  Style="{StaticResource FluxoraScrollLineButtonStyle}"
                                                  Command="ScrollBar.LineLeftCommand"
                                                  Content="{StaticResource FluxoraScrollArrowLeftGeometry}" />
                                    <Track x:Name="PART_Track"
                                           Grid.Row="1"
                                           Grid.Column="2"
                                           Orientation="Horizontal">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource FluxoraScrollPageButtonStyle}"
                                                          Command="ScrollBar.PageLeftCommand" />
                                        </Track.DecreaseRepeatButton>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource FluxoraScrollPageButtonStyle}"
                                                          Command="ScrollBar.PageRightCommand" />
                                        </Track.IncreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource FluxoraHorizontalScrollThumbStyle}" />
                                        </Track.Thumb>
                                    </Track>
                                    <RepeatButton Grid.Column="4"
                                                  Grid.RowSpan="3"
                                                  Style="{StaticResource FluxoraScrollLineButtonStyle}"
                                                  Command="ScrollBar.LineRightCommand"
                                                  Content="{StaticResource FluxoraScrollArrowRightGeometry}" />
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Border Background="#0B0913"
                    BorderBrush="#211C33"
                    BorderThickness="0,0,0,1" />
            <Grid>
                <TextBlock Text="Настройки сборки"
                           Foreground="{StaticResource TextBrush}"
                           FontWeight="Black"
                           FontSize="15"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
                <Button HorizontalAlignment="Right"
                        Style="{StaticResource CaptionButtonStyle}"
                        Tag="{StaticResource Icon.WindowClose}"
                        ToolTip="Закрыть"
                        AutomationProperties.Name="Закрыть"
                        Click="OnCloseButtonClick" />
            </Grid>
        </Grid>

        <Grid Grid.Row="1"
              Margin="24,22,24,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource PanelBorderStyle}"
                    Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="{Binding ProjectName}"
                                   FontSize="23"
                                   FontWeight="Black"
                                   Foreground="{StaticResource TextBrush}"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="Локальные настройки этой сборки"
                                   Margin="0,6,0,0"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Grid.Row="2">
                        <Button Style="{StaticResource NavButtonStyle}"
                                IsHitTestVisible="False">
                            <StackPanel Orientation="Horizontal">
                                <controls:LineIcon Data="{StaticResource Icon.Folder}"
                                                   Width="16"
                                                   Height="16"
                                                   Foreground="{StaticResource TextBrush}"
                                                   Margin="0,0,9,0" />
                                <TextBlock Text="Пути" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource PanelBorderStyle}"
                    Padding="24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Пути"
                                   Foreground="{StaticResource TextBrush}"
                                   FontSize="28"
                                   FontWeight="Black" />
                        <TextBlock Text="Игра, моды, профили, загрузки и overwrite хранятся отдельно для этой сборки."
                                   Margin="0,7,0,0"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <ScrollViewer x:Name="PathsScrollViewer"
                                  Grid.Row="2"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  CanContentScroll="False">
                        <StackPanel>
                            <Border Style="{StaticResource InnerPanelStyle}"
                                    Padding="14"
                                    Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="148" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Папка сборки"
                                               Style="{StaticResource PathLabelStyle}" />
                                    <TextBox Grid.Column="1"
                                             Style="{StaticResource PathTextBoxStyle}"
                                             Text="{Binding ProjectDirectory, Mode=OneWay}"
                                             IsReadOnly="True"
                                             Foreground="{StaticResource MutedTextBrush}" />
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource InnerPanelStyle}"
                                    Padding="14"
                                    Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="148" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="EXE игры"
                                               Style="{StaticResource PathLabelStyle}" />
                                    <TextBox Grid.Column="1"
                                             Style="{StaticResource PathTextBoxStyle}"
                                             Text="{Binding GameExecutablePath, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="3"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding BrowseGameExecutableCommand}"
                                            MinWidth="104"
                                            Content="Выбрать" />
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource InnerPanelStyle}"
                                    Padding="14"
                                    Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="148" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Моды"
                                               Style="{StaticResource PathLabelStyle}" />
                                    <TextBox Grid.Column="1"
                                             Style="{StaticResource PathTextBoxStyle}"
                                             Text="{Binding ModsDirectory, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="3"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding BrowseModsDirectoryCommand}"
                                            MinWidth="104"
                                            Content="Выбрать" />
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource InnerPanelStyle}"
                                    Padding="14"
                                    Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="148" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Профили"
                                               Style="{StaticResource PathLabelStyle}" />
                                    <TextBox Grid.Column="1"
                                             Style="{StaticResource PathTextBoxStyle}"
                                             Text="{Binding ProfilesDirectory, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="3"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding BrowseProfilesDirectoryCommand}"
                                            MinWidth="104"
                                            Content="Выбрать" />
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource InnerPanelStyle}"
                                    Padding="14"
                                    Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="148" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Загрузки"
                                               Style="{StaticResource PathLabelStyle}" />
                                    <TextBox Grid.Column="1"
                                             Style="{StaticResource PathTextBoxStyle}"
                                             Text="{Binding DownloadsDirectory, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="3"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding BrowseDownloadsDirectoryCommand}"
                                            MinWidth="104"
                                            Content="Выбрать" />
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource InnerPanelStyle}"
                                    Padding="14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="148" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Overwrite"
                                               Style="{StaticResource PathLabelStyle}" />
                                    <TextBox Grid.Column="1"
                                             Style="{StaticResource PathTextBoxStyle}"
                                             Text="{Binding OverwriteDirectory, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="3"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding BrowseOverwriteDirectoryCommand}"
                                            MinWidth="104"
                                            Content="Выбрать" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <Grid Grid.Row="3"
                          Margin="0,18,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Background="#2A1220"
                                BorderBrush="#7F1D3A"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="11"
                                Margin="0,0,0,12"
                                Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="{Binding ErrorText}"
                                       Foreground="{StaticResource ErrorBrush}"
                                       TextWrapping="Wrap" />
                        </Border>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{Binding StatusText}"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap" />

                            <Button Grid.Column="1"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Content="Отмена"
                                    MinWidth="104"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}"
                                    Click="OnCloseButtonClick" />

                            <Button Grid.Column="3"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Content="Сохранить"
                                    MinWidth="122"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}"
                                    Click="OnSaveButtonClick" />
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
