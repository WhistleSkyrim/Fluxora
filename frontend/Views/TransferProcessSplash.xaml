<UserControl x:Class="Fluxora.App.Views.TransferProcessSplash"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:services="clr-namespace:Fluxora.App.Services"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <SolidColorBrush x:Key="SplashTextBrush" Color="#F7F4FF" />
        <SolidColorBrush x:Key="SplashSecondaryTextBrush" Color="#C5BEDA" />
        <SolidColorBrush x:Key="SplashMutedTextBrush" Color="#8B84A4" />
        <SolidColorBrush x:Key="SplashErrorBrush" Color="#FB7185" />

        <LinearGradientBrush x:Key="SplashCoreBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F7F4FF" Offset="0" />
            <GradientStop Color="#C4B5FD" Offset="0.45" />
            <GradientStop Color="#8B5CF6" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="SplashProgressBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#34D399" Offset="0" />
            <GradientStop Color="#7C6BFB" Offset="0.55" />
            <GradientStop Color="#8B5CF6" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="SplashProgressBarStyle" TargetType="{x:Type ProgressBar}">
            <Setter Property="Height" Value="8" />
            <Setter Property="Maximum" Value="100" />
            <Setter Property="Foreground" Value="{StaticResource SplashProgressBrush}" />
            <Setter Property="Background" Value="#1B1730" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ProgressBar}">
                        <Grid ClipToBounds="True">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="4" />
                            <!-- PART_Track must exist so the bar sizes PART_Indicator against it. -->
                            <Decorator x:Name="PART_Track" />
                            <Border x:Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="4" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SplashGhostButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="20,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource SplashSecondaryTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="#1A1630"
                                BorderBrush="#3A3160"
                                BorderThickness="1"
                                CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#241D40" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#55467D" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.4" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <UserControl.Style>
        <Style TargetType="{x:Type UserControl}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsTransferProcessVisible}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Style>

    <Grid>
        <Grid.Triggers>
            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                <BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever">
                        <DoubleAnimation Storyboard.TargetName="MainArcRotate"
                                         Storyboard.TargetProperty="Angle"
                                         From="-24"
                                         To="696"
                                         Duration="0:0:3.7" />
                        <DoubleAnimation Storyboard.TargetName="EchoArcRotate"
                                         Storyboard.TargetProperty="Angle"
                                         From="42"
                                         To="-678"
                                         Duration="0:0:3.7" />
                        <DoubleAnimation Storyboard.TargetName="MainArc"
                                         Storyboard.TargetProperty="StrokeDashOffset"
                                         From="0"
                                         To="-43.2"
                                         Duration="0:0:3.7" />
                        <DoubleAnimation Storyboard.TargetName="EchoArc"
                                         Storyboard.TargetProperty="StrokeDashOffset"
                                         From="0"
                                         To="23.6"
                                         Duration="0:0:3.7" />
                        <DoubleAnimation Storyboard.TargetName="CoreRotate"
                                         Storyboard.TargetProperty="Angle"
                                         From="0"
                                         To="360"
                                         Duration="0:0:3.7" />

                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CoreScale"
                                                       Storyboard.TargetProperty="ScaleX">
                            <SplineDoubleKeyFrame KeyTime="0:0:0" Value="0.82" />
                            <SplineDoubleKeyFrame KeyTime="0:0:0.92" Value="1.32" KeySpline="0.26,0 0.14,1" />
                            <SplineDoubleKeyFrame KeyTime="0:0:1.91" Value="0.88" KeySpline="0.42,0 0.16,1" />
                            <SplineDoubleKeyFrame KeyTime="0:0:2.83" Value="1.12" KeySpline="0.2,0 0.12,1" />
                            <SplineDoubleKeyFrame KeyTime="0:0:3.7" Value="0.82" KeySpline="0.26,0 0.16,1" />
                        </DoubleAnimationUsingKeyFrames>
                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CoreScale"
                                                       Storyboard.TargetProperty="ScaleY">
                            <SplineDoubleKeyFrame KeyTime="0:0:0" Value="0.82" />
                            <SplineDoubleKeyFrame KeyTime="0:0:0.92" Value="0.76" KeySpline="0.26,0 0.14,1" />
                            <SplineDoubleKeyFrame KeyTime="0:0:1.91" Value="1.18" KeySpline="0.42,0 0.16,1" />
                            <SplineDoubleKeyFrame KeyTime="0:0:2.83" Value="0.92" KeySpline="0.2,0 0.12,1" />
                            <SplineDoubleKeyFrame KeyTime="0:0:3.7" Value="0.82" KeySpline="0.26,0 0.16,1" />
                        </DoubleAnimationUsingKeyFrames>

                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="PulseScale"
                                                       Storyboard.TargetProperty="ScaleX">
                            <SplineDoubleKeyFrame KeyTime="0:0:0" Value="0.88" />
                            <SplineDoubleKeyFrame KeyTime="0:0:1.63" Value="1.18" KeySpline="0.2,0 0.16,1" />
                            <SplineDoubleKeyFrame KeyTime="0:0:3.7" Value="0.88" KeySpline="0.28,0 0.16,1" />
                        </DoubleAnimationUsingKeyFrames>
                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="PulseScale"
                                                       Storyboard.TargetProperty="ScaleY">
                            <SplineDoubleKeyFrame KeyTime="0:0:0" Value="0.88" />
                            <SplineDoubleKeyFrame KeyTime="0:0:1.63" Value="1.18" KeySpline="0.2,0 0.16,1" />
                            <SplineDoubleKeyFrame KeyTime="0:0:3.7" Value="0.88" KeySpline="0.28,0 0.16,1" />
                        </DoubleAnimationUsingKeyFrames>
                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="PulseLayer"
                                                       Storyboard.TargetProperty="Opacity">
                            <SplineDoubleKeyFrame KeyTime="0:0:0" Value="0.08" />
                            <SplineDoubleKeyFrame KeyTime="0:0:1.63" Value="0.22" KeySpline="0.2,0 0.16,1" />
                            <SplineDoubleKeyFrame KeyTime="0:0:3.7" Value="0.08" KeySpline="0.28,0 0.16,1" />
                        </DoubleAnimationUsingKeyFrames>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Grid.Triggers>

        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F7080711" Offset="0" />
                <GradientStop Color="#F40D0A18" Offset="0.52" />
                <GradientStop Color="#F5121022" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid Width="460"
              MaxWidth="460"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="30" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="26" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Spinner / completion mark -->
            <Grid Width="124"
                  Height="124"
                  HorizontalAlignment="Center">
                <Ellipse Width="104"
                         Height="104"
                         Stroke="#2B2444"
                         StrokeThickness="7"
                         Opacity="0.9" />

                <Grid x:Name="SpinnerLayer">
                    <Ellipse x:Name="PulseLayer"
                             Width="78"
                             Height="78"
                             Fill="#241A46"
                             Opacity="0.08"
                             RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <ScaleTransform x:Name="PulseScale" />
                        </Ellipse.RenderTransform>
                    </Ellipse>

                    <Ellipse x:Name="MainArc"
                             Width="104"
                             Height="104"
                             Stroke="#A78BFA"
                             StrokeThickness="7"
                             StrokeStartLineCap="Round"
                             StrokeEndLineCap="Round"
                             StrokeDashCap="Round"
                             StrokeDashArray="6.4 15.2"
                             RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <RotateTransform x:Name="MainArcRotate" />
                        </Ellipse.RenderTransform>
                    </Ellipse>

                    <Ellipse x:Name="EchoArc"
                             Width="68"
                             Height="68"
                             Stroke="#F7F4FF"
                             StrokeThickness="4"
                             StrokeStartLineCap="Round"
                             StrokeEndLineCap="Round"
                             StrokeDashCap="Round"
                             StrokeDashArray="2.2 9.6"
                             Opacity="0.42"
                             RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <RotateTransform x:Name="EchoArcRotate" />
                        </Ellipse.RenderTransform>
                    </Ellipse>

                    <Border Width="28"
                            Height="28"
                            CornerRadius="14"
                            Background="{StaticResource SplashCoreBrush}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="CoreScale" />
                                <RotateTransform x:Name="CoreRotate" />
                            </TransformGroup>
                        </Border.RenderTransform>
                    </Border>
                </Grid>

                <!-- Shown once the transfer is finished -->
                <Grid x:Name="DoneLayer"
                      Opacity="0">
                    <Ellipse Width="104"
                             Height="104"
                             Stroke="#34D399"
                             StrokeThickness="7"
                             Opacity="0.9" />
                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               Text="&#xE73E;"
                               FontSize="40"
                               Foreground="#5EEAD4"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Grid>
            </Grid>

            <!-- Animated step phrase (driven from code-behind) -->
            <TextBlock x:Name="StepText"
                       Grid.Row="2"
                       FontSize="28"
                       FontWeight="Black"
                       Foreground="{StaticResource SplashTextBrush}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       RenderTransformOrigin="0.5,0.5">
                <TextBlock.RenderTransform>
                    <TranslateTransform x:Name="StepTranslate" />
                </TextBlock.RenderTransform>
            </TextBlock>

            <TextBlock Grid.Row="4"
                       Text="{Binding TransferCurrentItem}"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource SplashSecondaryTextBrush}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       MaxWidth="440" />

            <!-- Single, smoothly animated overall progress bar -->
            <StackPanel Grid.Row="6">
                <Grid Margin="0,0,0,9">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Общий прогресс"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource SplashMutedTextBrush}"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding Value, ElementName=OverallBar, StringFormat={}{0:0}%}"
                               FontSize="13"
                               FontWeight="Black"
                               Foreground="{StaticResource SplashTextBrush}"
                               VerticalAlignment="Center" />
                </Grid>

                <ProgressBar x:Name="OverallBar"
                             Style="{StaticResource SplashProgressBarStyle}"
                             services:SmoothProgressService.TargetValue="{Binding TransferOverallPercent}" />

                <TextBlock Text="{Binding TransferBytesText}"
                           Margin="0,10,0,0"
                           FontSize="11"
                           Foreground="{StaticResource SplashMutedTextBrush}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap" />

                <Border Background="#2A1220"
                        BorderBrush="#7F1D3A"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="12"
                        Margin="0,16,0,0"
                        Visibility="{Binding HasTransferError, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="{Binding TransferError}"
                               Foreground="{StaticResource SplashErrorBrush}"
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                </Border>

                <Button x:Name="CloseButton"
                        Style="{StaticResource SplashGhostButtonStyle}"
                        Content="Закрыть"
                        HorizontalAlignment="Center"
                        MinWidth="132"
                        Margin="0,22,0,0"
                        Command="{Binding CloseCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" />
            </StackPanel>
        </Grid>

        <Border Height="1"
                VerticalAlignment="Top"
                Background="#2E2550"
                Opacity="0.36" />
    </Grid>
</UserControl>
