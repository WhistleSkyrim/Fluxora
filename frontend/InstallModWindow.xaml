<Window x:Class="Fluxora.App.InstallModWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Установка мода"
        Width="432"
        Height="276"
        MinWidth="432"
        MinHeight="276"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        Background="#171523"
        FontFamily="{StaticResource FluxoraFontBody}"
        FontWeight="Medium"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextHintingMode="Fixed"
        RenderOptions.ClearTypeHint="Enabled"
        FontSize="13"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        Loaded="OnLoaded">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="58"
                            CornerRadius="10"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <SolidColorBrush x:Key="TextBrush" Color="#F7F4FF" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#C5BEDA" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#918AA8" />
        <SolidColorBrush x:Key="AccentBrush" Color="#7C3AED" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#8B5CF6" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#241A46" />
        <SolidColorBrush x:Key="AccentLineBrush" Color="#493184" />
        <SolidColorBrush x:Key="PanelBrush" Color="#171523" />
        <SolidColorBrush x:Key="PanelRaisedBrush" Color="#201D31" />
        <SolidColorBrush x:Key="PanelSoftBrush" Color="#11101B" />
        <SolidColorBrush x:Key="PanelHoverBrush" Color="#27223A" />
        <SolidColorBrush x:Key="LineBrush" Color="#302B46" />
        <SolidColorBrush x:Key="LineHoverBrush" Color="#55467D" />
        <SolidColorBrush x:Key="ErrorBrush" Color="#FB7185" />

        <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#8B5CF6" Offset="0" />
            <GradientStop Color="#6D5DFB" Offset="0.62" />
            <GradientStop Color="#5B21B6" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="DialogCloseButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}">
                            <Viewbox Width="16"
                                     Height="16"
                                     Stretch="Uniform"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                                <Path Width="24"
                                      Height="24"
                                      Data="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"
                                      Stroke="{TemplateBinding Foreground}"
                                      StrokeThickness="1.8"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round" />
                            </Viewbox>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#F7F4FF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.72" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DialogButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="38" />
            <Setter Property="MinWidth" Value="108" />
            <Setter Property="Padding" Value="15,0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"
                                              TextElement.FontWeight="{TemplateBinding FontWeight}"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.48" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryDialogButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource DialogButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
            <Setter Property="Foreground" Value="#F7F4FF" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentHoverBrush}" />
                    <Setter Property="BorderBrush" Value="#B197FC" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryDialogButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource DialogButtonStyle}">
            <Setter Property="Background" Value="{StaticResource PanelRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PanelHoverBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource LineHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DialogTextBoxStyle" TargetType="{x:Type TextBox}">
            <Setter Property="Height" Value="46" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Background" Value="{StaticResource PanelSoftBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="CaretBrush" Value="{StaticResource AccentHoverBrush}" />
            <Setter Property="SelectionBrush" Value="{StaticResource AccentHoverBrush}" />
            <Setter Property="SelectionOpacity" Value="0.35" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <Grid>
                                <Border x:Name="FocusWash"
                                        Background="{StaticResource AccentSoftBrush}"
                                        CornerRadius="9"
                                        Opacity="0" />
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              HorizontalScrollBarVisibility="Hidden"
                                              VerticalScrollBarVisibility="Disabled" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                                <Setter TargetName="Root" Property="Background" Value="#151322" />
                                <Setter TargetName="FocusWash" Property="Opacity" Value="0.25" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ConflictActionButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="MinHeight" Value="84" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="Background" Value="{StaticResource PanelRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource PanelHoverBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentLineBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="Transparent">
        <Border x:Name="DialogSurface"
                Margin="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="1"
                CornerRadius="16"
                Padding="22,20,22,20"
                Opacity="0"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <TranslateTransform Y="10" />
            </Border.RenderTransform>
            <Border.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="DialogSurface"
                                             Storyboard.TargetProperty="Opacity"
                                             To="1"
                                             Duration="0:0:0.18" />
                            <DoubleAnimation Storyboard.TargetName="DialogSurface"
                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                             To="0"
                                             Duration="0:0:0.22" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Border.Triggers>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid MouseLeftButtonDown="OnWindowDragMouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Border Width="34"
                                Height="34"
                                CornerRadius="10"
                                Background="{StaticResource AccentGradientBrush}"
                                Margin="0,0,12,0">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE8B7;"
                                       FontSize="15"
                                       Foreground="#F7F4FF"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <TextBlock x:Name="TitleTextBlock"
                                   Text="Установка мода"
                                   FontSize="20"
                                   FontWeight="Black"
                                   Foreground="{StaticResource TextBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <Button Grid.Column="1"
                            Style="{StaticResource DialogCloseButtonStyle}"
                            Tag="{StaticResource Icon.WindowClose}"
                            AutomationProperties.Name="Закрыть"
                            Click="OnCancelClick" />
                </Grid>

                <TextBlock x:Name="DescriptionTextBlock"
                           Grid.Row="1"
                           Text="Укажите название, под которым мод появится в папке mods."
                           Margin="0,10,40,16"
                           Foreground="{StaticResource MutedTextBrush}"
                           LineHeight="18"
                           TextWrapping="Wrap" />

                <Border x:Name="PlacementPreviewPanel"
                         Grid.Row="2"
                        Background="{StaticResource PanelSoftBrush}"
                        BorderBrush="{StaticResource LineBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="12"
                        Margin="0,0,0,14"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="План размещения"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}" />
                        <TextBlock x:Name="PlacementPreviewSummaryTextBlock"
                                   Margin="0,5,0,0"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   LineHeight="17"
                                   TextWrapping="Wrap" />
                        <ScrollViewer MaxHeight="118"
                                      Margin="0,8,0,0"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl x:Name="PlacementPreviewItemsControl">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   LineHeight="17"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,5" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <TextBox x:Name="ModNameTextBox"
                         Grid.Row="3"
                         Style="{StaticResource DialogTextBoxStyle}"
                         TextChanged="OnModNameTextChanged"
                         AutomationProperties.Name="Название мода" />

                <StackPanel x:Name="ConflictPanel"
                            Grid.Row="3"
                            Grid.RowSpan="2"
                            Visibility="Collapsed">
                    <Button x:Name="ReplaceActionButton"
                            Style="{StaticResource ConflictActionButtonStyle}"
                            Click="OnReplaceClick"
                            AutomationProperties.Name="Заменить мод">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="34"
                                    Height="34"
                                    CornerRadius="10"
                                    Background="{StaticResource AccentSoftBrush}"
                                    BorderBrush="{StaticResource AccentLineBrush}"
                                    BorderThickness="1"
                                    Margin="0,0,12,0">
                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                           Text="&#xE8AC;"
                                           FontSize="15"
                                           Foreground="{StaticResource AccentHoverBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Заменить"
                                           FontSize="14"
                                           FontWeight="Black"
                                           Foreground="{StaticResource TextBrush}" />
                                <TextBlock x:Name="ReplaceDescriptionTextBlock"
                                           Text="Полностью удалить старый мод и поставить новый."
                                           Margin="0,5,0,0"
                                           LineHeight="17"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource MutedTextBrush}" />
                            </StackPanel>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource ConflictActionButtonStyle}"
                            Click="OnMergeClick"
                            Margin="0,10,0,0"
                            AutomationProperties.Name="Объединить мод">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="34"
                                    Height="34"
                                    CornerRadius="10"
                                    Background="#1D2A35"
                                    BorderBrush="#356B68"
                                    BorderThickness="1"
                                    Margin="0,0,12,0">
                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                           Text="&#xE8B3;"
                                           FontSize="15"
                                           Foreground="#68E1D1"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Объединить"
                                           FontSize="14"
                                           FontWeight="Black"
                                           Foreground="{StaticResource TextBrush}" />
                                <TextBlock x:Name="MergeDescriptionTextBlock"
                                           Text="Добавить новые файлы, а совпадающие файлы перезаписать."
                                           Margin="0,5,0,0"
                                           LineHeight="17"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource MutedTextBrush}" />
                            </StackPanel>
                        </Grid>
                    </Button>
                </StackPanel>

                <TextBlock x:Name="ValidationMessageTextBlock"
                           Grid.Row="4"
                           Margin="2,7,0,0"
                           Foreground="{StaticResource ErrorBrush}"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Visibility="Collapsed" />

                <StackPanel Grid.Row="5"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,18,0,0">
                    <Button Style="{StaticResource SecondaryDialogButtonStyle}"
                            IsCancel="True"
                            Click="OnCancelClick"
                            Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE711;"
                                       FontSize="12"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="Отмена" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="AcceptButton"
                            Style="{StaticResource PrimaryDialogButtonStyle}"
                            IsDefault="True"
                            Click="OnOkClick">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE73E;"
                                       FontSize="12"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                            <TextBlock x:Name="AcceptButtonTextBlock"
                                       Text="Установить" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
