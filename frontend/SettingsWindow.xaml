<Window x:Class="Fluxora.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:services="clr-namespace:Fluxora.App.Services"
        xmlns:views="clr-namespace:Fluxora.App.Views"
        xmlns:controls="clr-namespace:Fluxora.App.Controls"
        xmlns:models="clr-namespace:Fluxora.App.Models"
        xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
        Title="Настройки"
        Width="900"
        Height="560"
        MinWidth="760"
        MinHeight="500"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#080711"
        FontFamily="{StaticResource FluxoraFontBody}"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        FontSize="13"
        Loaded="OnLoaded">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="56"
                            CornerRadius="10"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="7"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <services:InverseBooleanConverter x:Key="InverseBooleanConverter" />

        <SolidColorBrush x:Key="TextBrush" Color="#F7F4FF" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#C5BEDA" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#918AA8" />
        <SolidColorBrush x:Key="SubtleTextBrush" Color="#736D86" />
        <SolidColorBrush x:Key="AccentBrush" Color="#7C3AED" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#8B5CF6" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#241A46" />
        <SolidColorBrush x:Key="AccentLineBrush" Color="#493184" />
        <SolidColorBrush x:Key="NavSelectedBrush" Color="#332B47" />
        <SolidColorBrush x:Key="NavSelectedLineBrush" Color="#7A63B8" />
        <SolidColorBrush x:Key="PanelBrush" Color="#171523" />
        <SolidColorBrush x:Key="PanelRaisedBrush" Color="#201D31" />
        <SolidColorBrush x:Key="PanelSoftBrush" Color="#11101B" />
        <SolidColorBrush x:Key="PanelHoverBrush" Color="#27223A" />
        <SolidColorBrush x:Key="LineBrush" Color="#302B46" />
        <SolidColorBrush x:Key="LineHoverBrush" Color="#55467D" />
        <SolidColorBrush x:Key="WarningBrush" Color="#FBBF24" />
        <SolidColorBrush x:Key="ErrorBrush" Color="#FB7185" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#7DD3FC" />

        <LinearGradientBrush x:Key="AppBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#080711" Offset="0" />
            <GradientStop Color="#0D0A18" Offset="0.48" />
            <GradientStop Color="#121022" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#8B5CF6" Offset="0" />
            <GradientStop Color="#6D5DFB" Offset="0.62" />
            <GradientStop Color="#5B21B6" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ProgressGradientBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#7DD3FC" Offset="0" />
            <GradientStop Color="#8B5CF6" Offset="0.55" />
            <GradientStop Color="#C084FC" Offset="1" />
        </LinearGradientBrush>

        <DropShadowEffect x:Key="PanelShadow"
                          Color="#05030B"
                          BlurRadius="30"
                          ShadowDepth="12"
                          Opacity="0.36" />

        <Style x:Key="PanelBorderStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Effect" Value="{StaticResource PanelShadow}" />
        </Style>

        <Style x:Key="InnerPanelStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{StaticResource PanelRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>

        <!-- Right-hand content panel. Inherits the panel chrome and adds a soft
             fade + rise whenever it becomes visible, so switching sections feels
             like the content slides into place instead of snapping. -->
        <Style x:Key="ContentPanelStyle"
               TargetType="{x:Type Border}"
               BasedOn="{StaticResource PanelBorderStyle}">
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="0" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Visibility" Value="Visible">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="0"
                                                 To="1"
                                                 Duration="0:0:0.22" />
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                 From="12"
                                                 To="0"
                                                 Duration="0:0:0.28">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CaptionButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="54" />
            <Setter Property="Height" Value="56" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="Transparent">
                            <Border x:Name="Root"
                                    Width="34"
                                    Height="34"
                                    Background="{StaticResource PanelRaisedBrush}"
                                    BorderBrush="{StaticResource LineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <Viewbox x:Name="CaptionGlyphBox"
                                     Width="13"
                                     Height="13"
                                     Stretch="Uniform"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                                <Path Width="24"
                                      Height="24"
                                      Data="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"
                                      Stroke="{TemplateBinding Foreground}"
                                      StrokeThickness="1.8"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round" />
                            </Viewbox>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#2A1220" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#7F1D3A" />
                                <Setter Property="Foreground" Value="#F7F4FF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#3A1023" />
                                <Setter TargetName="Root" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                         Value="Maximized">
                                <Setter TargetName="CaptionGlyphBox" Property="Margin" Value="0,8,0,0" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BaseButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="15,0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Root"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                         To="1.018"
                                                         Duration="0:0:0.14" />
                                        <DoubleAnimation Storyboard.TargetName="Root"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                         To="1.018"
                                                         Duration="0:0:0.14" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Root"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                         To="1"
                                                         Duration="0:0:0.18" />
                                        <DoubleAnimation Storyboard.TargetName="Root"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                         To="1"
                                                         Duration="0:0:0.18" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
            <Setter Property="Foreground" Value="#F7F4FF" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentHoverBrush}" />
                    <Setter Property="BorderBrush" Value="#B197FC" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="{StaticResource PanelRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PanelHoverBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource LineHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Steam-style settings section row: compact, single line, no chunky card. -->
        <Style x:Key="SectionNavButtonStyle" TargetType="{x:Type ToggleButton}">
            <Setter Property="Height" Value="38" />
            <Setter Property="Margin" Value="0,1" />
            <Setter Property="Padding" Value="20,0,10,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Grid ClipToBounds="True">
                            <Border x:Name="BaseFill"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="9" />
                            <Border x:Name="SelectedFill"
                                    Background="{StaticResource NavSelectedBrush}"
                                    BorderBrush="{StaticResource NavSelectedLineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="9"
                                    Opacity="0" />
                            <Border x:Name="HoverFill"
                                    Background="{StaticResource PanelHoverBrush}"
                                    CornerRadius="9"
                                    Opacity="0" />
                            <Border x:Name="SelectedMarker"
                                    Width="6"
                                    Height="24"
                                    CornerRadius="4"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Margin="0,0,0,0"
                                    Background="{StaticResource AccentGradientBrush}"
                                    Opacity="0" />
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverFill"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.6"
                                                         Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverFill"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0"
                                                         Duration="0:0:0.2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                <Setter TargetName="SelectedFill" Property="Opacity" Value="1" />
                                <Setter TargetName="HoverFill" Property="Opacity" Value="0" />
                                <Setter TargetName="SelectedMarker" Property="Opacity" Value="1" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="SelectedFill"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="0:0:0.18" />
                                            <DoubleAnimation Storyboard.TargetName="SelectedMarker"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="0:0:0.2" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="SelectedFill"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0"
                                                             Duration="0:0:0.16" />
                                            <DoubleAnimation Storyboard.TargetName="SelectedMarker"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0"
                                                             Duration="0:0:0.18" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="PillBorderStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentLineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="9,5" />
        </Style>

        <Style x:Key="StepMarkerStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{StaticResource PanelRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <Style x:Key="TransferSourceButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="{StaticResource PanelRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <TranslateTransform Y="0" />
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Root"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                         To="-3"
                                                         Duration="0:0:0.16" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Root"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                         To="0"
                                                         Duration="0:0:0.18" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource PanelHoverBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.86" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.48" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Animated switch: the thumb slides via a TranslateTransform and the
             accent track cross-fades in, instead of snapping between two states. -->
        <Style x:Key="SwitchToggleStyle" TargetType="{x:Type ToggleButton}">
            <Setter Property="Width" Value="58" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Grid x:Name="Root"
                              Width="{TemplateBinding Width}"
                              Height="{TemplateBinding Height}">
                            <Border x:Name="Track"
                                    Background="#161322"
                                    BorderBrush="{StaticResource LineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="16" />
                            <Border x:Name="TrackAccent"
                                    Background="{StaticResource AccentBrush}"
                                    BorderBrush="{StaticResource AccentHoverBrush}"
                                    BorderThickness="1"
                                    CornerRadius="16"
                                    Opacity="0" />
                            <Ellipse x:Name="Thumb"
                                     Width="24"
                                     Height="24"
                                     Margin="4"
                                     Fill="{StaticResource TextSecondaryBrush}"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Center"
                                     RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform X="0" />
                                </Ellipse.RenderTransform>
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#06040D"
                                                      BlurRadius="12"
                                                      ShadowDepth="2"
                                                      Opacity="0.45" />
                                </Ellipse.Effect>
                            </Ellipse>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Thumb" Property="Fill" Value="#F7F4FF" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="TrackAccent"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="0:0:0.18" />
                                            <DoubleAnimation Storyboard.TargetName="Thumb"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                             To="26"
                                                             Duration="0:0:0.22">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="TrackAccent"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0"
                                                             Duration="0:0:0.18" />
                                            <DoubleAnimation Storyboard.TargetName="Thumb"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                             To="0"
                                                             Duration="0:0:0.22">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="BorderBrush" Value="{StaticResource LineHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.5" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TransferTextBoxStyle" TargetType="{x:Type TextBox}">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="CaretBrush" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#12101C" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.62" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TransferComboBoxStyle" TargetType="{x:Type ComboBox}">
            <Setter Property="Height" Value="40" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#12101C" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="{x:Type ComboBoxItem}">
                        <Setter Property="IsEnabled" Value="{Binding IsSelectable}" />
                        <Style.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="LanguageOptionTemplate" DataType="{x:Type models:LanguageOption}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="42" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Image Width="32"
                       Height="32"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="HighQuality">
                    <Image.Style>
                        <Style TargetType="{x:Type Image}">
                            <Setter Property="Source"
                                    Value="{svgc:SvgImage Source=/Assets/Emoji/flag_us.svg, AppName=FluxoraModding}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Code}" Value="de">
                                    <Setter Property="Source"
                                            Value="{svgc:SvgImage Source=/Assets/Emoji/flag_de.svg, AppName=FluxoraModding}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Code}" Value="ru">
                                    <Setter Property="Source"
                                            Value="{svgc:SvgImage Source=/Assets/Emoji/flag_ru.svg, AppName=FluxoraModding}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>
                </Image>

                <TextBlock Grid.Column="2"
                           Text="{Binding DisplayName}"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}"
                           TextTrimming="CharacterEllipsis" />
            </Grid>
        </DataTemplate>

        <Style x:Key="LanguageComboBoxItemStyle" TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Height" Value="52" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="IsEnabled" Value="{Binding IsSelectable}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                        <Border x:Name="Root"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="11"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource PanelHoverBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#3B3158" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LanguageComboBoxStyle" TargetType="{x:Type ComboBox}">
            <Setter Property="Height" Value="58" />
            <Setter Property="Background" Value="{StaticResource PanelSoftBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Border x:Name="Root"
                                                Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderThickness="1"
                                                CornerRadius="15">
                                            <Grid>
                                                <ContentPresenter Margin="14,0,54,0"
                                                                  VerticalAlignment="Center"
                                                                  HorizontalAlignment="Stretch"
                                                                  Content="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentTemplate="{Binding ItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}" />
                                                <Path x:Name="Arrow"
                                                      Width="12"
                                                      Height="8"
                                                      HorizontalAlignment="Right"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,20,0"
                                                      Data="M1 1.5 L6 6.5 L11 1.5"
                                                      Stroke="{StaticResource TextSecondaryBrush}"
                                                      StrokeThickness="2"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      RenderTransformOrigin="0.5,0.5">
                                                    <Path.RenderTransform>
                                                        <RotateTransform Angle="0" />
                                                    </Path.RenderTransform>
                                                </Path>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Root" Property="Background" Value="{StaticResource PanelHoverBrush}" />
                                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource LineHoverBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                                                <Trigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="Arrow"
                                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                             To="180"
                                                                             Duration="0:0:0.18" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.EnterActions>
                                                <Trigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="Arrow"
                                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                             To="0"
                                                                             Duration="0:0:0.18" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.ExitActions>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="Root" Property="Opacity" Value="0.55" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PopupAnimation="Fade">
                                <Border x:Name="DropDown"
                                        Margin="0,8,0,0"
                                        Width="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="180"
                                        Background="{StaticResource PanelSoftBrush}"
                                        BorderBrush="{StaticResource LineHoverBrush}"
                                        BorderThickness="1"
                                        CornerRadius="15"
                                        Padding="7"
                                        SnapsToDevicePixels="True"
                                        Opacity="0"
                                        RenderTransformOrigin="0.5,0">
                                    <Border.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform ScaleX="0.98" ScaleY="0.92" />
                                            <TranslateTransform Y="-8" />
                                        </TransformGroup>
                                    </Border.RenderTransform>
                                    <Border.Triggers>
                                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="DropDown"
                                                                     Storyboard.TargetProperty="Opacity"
                                                                     To="1"
                                                                     Duration="0:0:0.14" />
                                                    <DoubleAnimation Storyboard.TargetName="DropDown"
                                                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                                     To="1"
                                                                     Duration="0:0:0.18" />
                                                    <DoubleAnimation Storyboard.TargetName="DropDown"
                                                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                                     To="1"
                                                                     Duration="0:0:0.18" />
                                                    <DoubleAnimation Storyboard.TargetName="DropDown"
                                                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)"
                                                                     To="0"
                                                                     Duration="0:0:0.18" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Border.Triggers>
                                    <ScrollViewer CanContentScroll="True"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  VerticalScrollBarVisibility="Disabled">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundedProgressBarStyle" TargetType="{x:Type ProgressBar}">
            <Setter Property="Height" Value="8" />
            <Setter Property="Foreground" Value="{StaticResource ProgressGradientBrush}" />
            <Setter Property="Background" Value="#10101A" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ProgressBar}">
                        <Grid ClipToBounds="True">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="4" />
                            <Border x:Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="4" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Rectangle Opacity="0.10"
                   IsHitTestVisible="False">
            <Rectangle.Fill>
                <VisualBrush TileMode="Tile"
                             Viewport="0,0,96,96"
                             ViewportUnits="Absolute">
                    <VisualBrush.Visual>
                        <Grid Width="96" Height="96">
                            <Path Stroke="#39325C"
                                  StrokeThickness="1"
                                  Data="M 0 0 H 96 M 0 0 V 96" />
                        </Grid>
                    </VisualBrush.Visual>
                </VisualBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#0B0913"
                    BorderBrush="#211C33"
                    BorderThickness="0,0,0,1">
                <Grid Margin="22,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <controls:LineIcon Data="{StaticResource Icon.Settings}"
                                           Width="24"
                                           Height="24"
                                           StrokeThickness="2"
                                           Foreground="#C4B5FD"
                                           Margin="0,0,12,0" />
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Настройки"
                                       FontSize="21"
                                       FontWeight="Black"
                                       Foreground="{StaticResource TextBrush}" />
                        </StackPanel>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Style="{StaticResource CaptionButtonStyle}"
                            Tag="{StaticResource Icon.WindowClose}"
                            ToolTip="Закрыть"
                            AutomationProperties.Name="Close settings"
                            Click="OnCloseButtonClick" />
                </Grid>
            </Border>

            <Grid Grid.Row="1"
                  Margin="18"
                  Visibility="{Binding IsNormalSettingsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="206" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource PanelBorderStyle}"
                        Padding="10">
                    <StackPanel>
                        <ToggleButton Style="{StaticResource SectionNavButtonStyle}"
                                      Command="{Binding SelectConnectionsCommand}"
                                      IsChecked="{Binding IsConnectionsSelected, Mode=OneWay}"
                                      AutomationProperties.Name="Привязки">
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <controls:LineIcon Data="{StaticResource Icon.Link}"
                                                   Width="17"
                                                   Height="17"
                                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                                   Margin="0,0,11,0" />
                                <TextBlock Text="Привязки"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </ToggleButton>

                        <ToggleButton Style="{StaticResource SectionNavButtonStyle}"
                                      Command="{Binding SelectLanguagesCommand}"
                                      IsChecked="{Binding IsLanguagesSelected, Mode=OneWay}"
                                      AutomationProperties.Name="Языки">
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <controls:LineIcon Data="{StaticResource Icon.Language}"
                                                   Width="17"
                                                   Height="17"
                                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                                   Margin="0,0,11,0" />
                                <TextBlock Text="Языки"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </ToggleButton>

                        <ToggleButton Style="{StaticResource SectionNavButtonStyle}"
                                      Command="{Binding SelectTransferCommand}"
                                      IsChecked="{Binding IsTransferSelected, Mode=OneWay}"
                                      AutomationProperties.Name="Перенос">
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <controls:LineIcon Data="{StaticResource Icon.Transfer}"
                                                   Width="17"
                                                   Height="17"
                                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                                   Margin="0,0,11,0" />
                                <TextBlock Text="Перенос"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </ToggleButton>
                    </StackPanel>
                </Border>

                <Grid Grid.Column="2">
                    <Border Style="{StaticResource ContentPanelStyle}"
                            Padding="22"
                            Visibility="{Binding IsConnectionsSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <TextBlock Text="Привязки"
                                           FontSize="32"
                                           FontWeight="Black"
                                           Foreground="{StaticResource TextBrush}" />
                                <TextBlock Text="Подключите аккаунт, чтобы Fluxora могла работать с моддинг-сервисами без ручной рутины."
                                           Margin="0,8,0,0"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <Border Grid.Row="1"
                                    Style="{StaticResource InnerPanelStyle}"
                                    Padding="16"
                                    Margin="0,18,0,0"
                                    VerticalAlignment="Top">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="54" />
                                        <ColumnDefinition Width="14" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Image Source="{StaticResource Image.NexusMods}"
                                           Width="46"
                                           Height="50"
                                           Stretch="Uniform"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"
                                           RenderOptions.BitmapScalingMode="HighQuality" />

                                    <StackPanel Grid.Column="2"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding NexusModsTitle}"
                                                   FontSize="17"
                                                   FontWeight="Black"
                                                   Foreground="{StaticResource TextBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="3"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center"
                                                Margin="20,0,0,0">
                                        <TextBlock Text="{Binding NexusModsToggleText}"
                                                   MinWidth="44"
                                                   TextAlignment="Right"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,12,0" />
                                        <ToggleButton Style="{StaticResource SwitchToggleStyle}"
                                                      IsChecked="{Binding IsNexusModsToggleChecked, Mode=OneWay}"
                                                      IsEnabled="{Binding IsNexusModsToggleEnabled}"
                                                      Command="{Binding ToggleNexusModsCommand}"
                                                      ToolTip="Привязать NexusMods через OAuth" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <ProgressBar Grid.Row="2"
                                         Height="3"
                                         VerticalAlignment="Top"
                                         IsIndeterminate="True"
                                         Foreground="{StaticResource AccentHoverBrush}"
                                         Background="#0E0C16"
                                         BorderThickness="0"
                                         Margin="0,12,0,0"
                                         Visibility="{Binding IsNexusBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />

                        </Grid>
                    </Border>

                    <Border Style="{StaticResource ContentPanelStyle}"
                            Padding="22"
                            Visibility="{Binding IsLanguagesSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <TextBlock Text="Языки"
                                           FontSize="32"
                                           FontWeight="Black"
                                           Foreground="{StaticResource TextBrush}" />
                            </StackPanel>

                            <Border Grid.Row="1"
                                    Style="{StaticResource InnerPanelStyle}"
                                    Padding="20"
                                    Margin="0,22,0,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="10" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="Язык интерфейса"
                                               Style="{StaticResource FieldLabelStyle}" />

                                    <ComboBox Grid.Row="2"
                                              Style="{StaticResource LanguageComboBoxStyle}"
                                              ItemContainerStyle="{StaticResource LanguageComboBoxItemStyle}"
                                              ItemTemplate="{StaticResource LanguageOptionTemplate}"
                                              ItemsSource="{Binding AvailableLanguages}"
                                              SelectedItem="{Binding SelectedLanguage}"
                                              IsEnabled="{Binding IsLanguageSwitching, Converter={StaticResource InverseBooleanConverter}}" />
                                </Grid>
                            </Border>

                            <Border Grid.Row="2"
                                    Background="#2A1220"
                                    BorderBrush="#7F1D3A"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="12"
                                    VerticalAlignment="Top"
                                    Visibility="{Binding HasLanguageError, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="{Binding LanguageError}"
                                           Foreground="{StaticResource ErrorBrush}"
                                           TextWrapping="Wrap" />
                            </Border>

                        </Grid>
                    </Border>

                    <Border Style="{StaticResource ContentPanelStyle}"
                            Padding="22"
                            Visibility="{Binding IsTransferMenuVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <TextBlock Text="Перенос сборки"
                                           FontSize="34"
                                           FontWeight="Black"
                                           Foreground="{StaticResource TextBrush}" />
                            </StackPanel>

                            <Button Grid.Row="1"
                                    Style="{StaticResource TransferSourceButtonStyle}"
                                    Click="OnTransferToMainButtonClick"
                                    Margin="0,20,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Image Source="Assets/Images/mod-organizer-2.png"
                                           Width="53"
                                           Height="53"
                                           Stretch="Uniform"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"
                                           RenderOptions.BitmapScalingMode="HighQuality" />

                                    <StackPanel Grid.Column="2"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="Mod Organizer 2"
                                                   FontSize="20"
                                                   FontWeight="Black"
                                                   Foreground="{StaticResource TextBrush}" />
                                        <TextBlock Text="Импортировать существующую MO2-сборку во Fluxora."
                                                   Margin="0,5,0,0"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="3"
                                                VerticalAlignment="Center"
                                                Margin="18,0,0,0">
                                        <Border Background="{StaticResource AccentBrush}"
                                                BorderBrush="{StaticResource AccentHoverBrush}"
                                                BorderThickness="1"
                                                CornerRadius="10"
                                                Padding="14,10">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Перенести сборку"
                                                           Foreground="#F7F4FF"
                                                           FontWeight="SemiBold" />
                                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                                           Text="&#xE72A;"
                                                           FontSize="12"
                                                           Foreground="#F7F4FF"
                                                           Margin="8,1,0,0" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Button>

                        </Grid>
                    </Border>

                    <Border Style="{StaticResource ContentPanelStyle}"
                            Padding="22"
                            Visibility="{Binding IsTransferStepperVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="{Binding TransferStepTitle}"
                                               FontSize="31"
                                               FontWeight="Black"
                                               Foreground="{StaticResource TextBrush}" />
                                    <TextBlock Text="{Binding TransferStepSubtitle}"
                                               Margin="0,7,0,0"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <Border Grid.Column="1"
                                        Style="{StaticResource PillBorderStyle}"
                                        VerticalAlignment="Top">
                                    <TextBlock Text="{Binding TransferStepCounter}"
                                               Foreground="{StaticResource TextBrush}"
                                               FontWeight="SemiBold" />
                                </Border>
                            </Grid>

                            <Grid Grid.Row="1"
                                  Margin="0,22,0,22">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border>
                                    <Border.Style>
                                        <Style TargetType="{x:Type Border}" BasedOn="{StaticResource StepMarkerStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding TransferStepIndex}" Value="0">
                                                    <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="Источник"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextBrush}"
                                               TextAlignment="Center" />
                                </Border>

                                <Border Grid.Column="1">
                                    <Border.Style>
                                        <Style TargetType="{x:Type Border}" BasedOn="{StaticResource StepMarkerStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding TransferStepIndex}" Value="1">
                                                    <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="Назначение"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextBrush}"
                                               TextAlignment="Center" />
                                </Border>

                                <Border Grid.Column="2">
                                    <Border.Style>
                                        <Style TargetType="{x:Type Border}" BasedOn="{StaticResource StepMarkerStyle}">
                                            <Setter Property="Margin" Value="0" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding TransferStepIndex}" Value="2">
                                                    <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="Проверка"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextBrush}"
                                               TextAlignment="Center" />
                                </Border>
                            </Grid>

                            <Grid Grid.Row="2">
                                <Grid Visibility="{Binding IsTransferSourceStep, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel>
                                        <TextBlock Text="Папка Mod Organizer 2"
                                                   Style="{StaticResource FieldLabelStyle}" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="10" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox Style="{StaticResource TransferTextBoxStyle}"
                                                     Text="{Binding SourceDirectory, UpdateSourceTrigger=PropertyChanged}" />
                                            <Button Grid.Column="2"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Command="{Binding BrowseSourceCommand}"
                                                    MinWidth="104">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                                                               Text="&#xE8B7;"
                                                               FontSize="13"
                                                               Margin="0,0,8,0" />
                                                    <TextBlock Text="Выбрать" />
                                                </StackPanel>
                                            </Button>
                                        </Grid>

                                        <Border Style="{StaticResource InnerPanelStyle}"
                                                Padding="16"
                                                Margin="0,18,0,0">
                                            <StackPanel>
                                                <TextBlock Text="Что будет перенесено"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextBrush}" />
                                                <TextBlock Text="C++ core проверит структуру MO2, прочитает профиль, порядок модов и подготовит перенос без удаления исходной папки."
                                                           Margin="0,8,0,0"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>

                                <Grid Visibility="{Binding IsTransferDestinationStep, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding DestinationLabel}"
                                                   Style="{StaticResource FieldLabelStyle}" />
                                        <ComboBox Style="{StaticResource TransferComboBoxStyle}"
                                                  ItemsSource="{Binding AvailableDrives}"
                                                  SelectedItem="{Binding SelectedDrive}"
                                                  DisplayMemberPath="DisplayName"
                                                  IsEnabled="{Binding CanChangeDestination}" />
                                        <Grid Margin="0,12,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="10" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox Style="{StaticResource TransferTextBoxStyle}"
                                                     Text="{Binding DestinationRootDirectory, UpdateSourceTrigger=PropertyChanged}"
                                                     IsEnabled="{Binding CanChangeDestination}" />
                                            <Button Grid.Column="2"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Command="{Binding BrowseDestinationCommand}"
                                                    IsEnabled="{Binding CanChangeDestination}"
                                                    MinWidth="104">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                                                               Text="&#xE8B7;"
                                                               FontSize="13"
                                                               Margin="0,0,8,0" />
                                                    <TextBlock Text="Папка" />
                                                </StackPanel>
                                            </Button>
                                        </Grid>

                                        <Border Style="{StaticResource InnerPanelStyle}"
                                                Padding="16"
                                                Margin="0,18,0,0">
                                            <StackPanel>
                                                <TextBlock Text="Итоговый путь"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextBrush}" />
                                                <TextBlock Text="{Binding TransferTargetText}"
                                                           Margin="0,8,0,0"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding TransferAvailableText}"
                                                           Margin="0,8,0,0"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>

                                <ScrollViewer Visibility="{Binding IsTransferReviewStep, Converter={StaticResource BooleanToVisibilityConverter}}"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              Padding="0,0,4,0">
                                    <StackPanel>
                                        <Border Style="{StaticResource InnerPanelStyle}"
                                                Padding="18">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding TransferProjectName}"
                                                                   FontSize="22"
                                                                   FontWeight="Black"
                                                                   Foreground="{StaticResource TextBrush}"
                                                                   TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding TransferMessage}"
                                                                   Margin="0,6,0,0"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   TextWrapping="Wrap" />
                                                    </StackPanel>
                                                        </Grid>

                                                <ProgressBar Grid.Row="1"
                                                             Height="3"
                                                             IsIndeterminate="True"
                                                             Foreground="{StaticResource AccentHoverBrush}"
                                                             Background="#0E0C16"
                                                             BorderThickness="0"
                                                             Margin="0,14,0,0"
                                                             Visibility="{Binding IsAnalyzingTransfer, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                                <Grid Grid.Row="2"
                                                      Margin="0,18,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="12" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="12" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Background="#151220"
                                                            BorderBrush="{StaticResource LineBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="10"
                                                            Padding="14">
                                                        <StackPanel>
                                                            <TextBlock Text="Моды"
                                                                       Foreground="{StaticResource MutedTextBrush}"
                                                                       FontSize="12" />
                                                            <TextBlock Text="{Binding TransferModCountText}"
                                                                       Margin="0,5,0,0"
                                                                       Foreground="{StaticResource TextBrush}"
                                                                       FontWeight="Black"
                                                                       TextWrapping="Wrap" />
                                                        </StackPanel>
                                                    </Border>
                                                    <Border Grid.Column="2"
                                                            Background="#151220"
                                                            BorderBrush="{StaticResource LineBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="10"
                                                            Padding="14">
                                                        <StackPanel>
                                                            <TextBlock Text="Вес"
                                                                       Foreground="{StaticResource MutedTextBrush}"
                                                                       FontSize="12" />
                                                            <TextBlock Text="{Binding TransferSizeText}"
                                                                       Margin="0,5,0,0"
                                                                       Foreground="{StaticResource TextBrush}"
                                                                       FontWeight="Black" />
                                                            <TextBlock Text="{Binding TransferAvailableText}"
                                                                       Margin="0,3,0,0"
                                                                       Foreground="{StaticResource SubtleTextBrush}"
                                                                       FontSize="11"
                                                                       TextWrapping="Wrap" />
                                                        </StackPanel>
                                                    </Border>
                                                    <Border Grid.Column="4"
                                                            Background="#151220"
                                                            BorderBrush="{StaticResource LineBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="10"
                                                            Padding="14">
                                                        <StackPanel>
                                                            <TextBlock Text="Профиль"
                                                                       Foreground="{StaticResource MutedTextBrush}"
                                                                       FontSize="12" />
                                                            <TextBlock Text="{Binding TransferProfileText}"
                                                                       Margin="0,5,0,0"
                                                                       Foreground="{StaticResource TextBrush}"
                                                                       FontWeight="Black"
                                                                       TextWrapping="Wrap" />
                                                            <TextBlock Text="{Binding TransferGameText}"
                                                                       Margin="0,3,0,0"
                                                                       Foreground="{StaticResource SubtleTextBrush}"
                                                                       FontSize="11"
                                                                       TextWrapping="Wrap" />
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>
                                            </Grid>
                                        </Border>

                                        <Border Background="#241A12"
                                                BorderBrush="#6D4D1F"
                                                BorderThickness="1"
                                                CornerRadius="10"
                                                Padding="12"
                                                Margin="0,14,0,0"
                                                Visibility="{Binding HasTransferWarning, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="{Binding TransferWarningText}"
                                                       Foreground="#FDE68A"
                                                       TextWrapping="Wrap" />
                                        </Border>

                                        <Border Padding="12"
                                                Margin="0,14,0,0"
                                                Visibility="{Binding HasTransferAnalysis, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <Border.Style>
                                                <Style TargetType="{x:Type Border}">
                                                    <Setter Property="Background" Value="#2A1220" />
                                                    <Setter Property="BorderBrush" Value="#7F1D3A" />
                                                    <Setter Property="BorderThickness" Value="1" />
                                                    <Setter Property="CornerRadius" Value="10" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasEnoughSpace}" Value="True">
                                                            <Setter Property="Background" Value="#10251D" />
                                                            <Setter Property="BorderBrush" Value="#2F9E68" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding TransferDiskSpaceText}"
                                                       Foreground="{StaticResource TextBrush}"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                        </Border>

                                        <TextBlock Text="{Binding TransferTargetText}"
                                                   Margin="0,12,0,0"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   FontSize="11"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>

                            <Grid Grid.Row="3"
                                  Margin="0,18,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border Background="#2A1220"
                                        BorderBrush="#7F1D3A"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="12"
                                        Margin="0,0,0,12"
                                        Visibility="{Binding HasTransferError, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="{Binding TransferError}"
                                               Foreground="{StaticResource ErrorBrush}"
                                               TextWrapping="Wrap" />
                                </Border>

                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Button Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding CancelTransferFlowCommand}"
                                            Content="Отменить перенос"
                                            MinWidth="142" />

                                    <Button Grid.Column="2"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding PreviousTransferStepCommand}"
                                            MinWidth="94">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                                       Text="&#xE72B;"
                                                       FontSize="12"
                                                       Margin="0,0,7,0" />
                                            <TextBlock Text="Назад" />
                                        </StackPanel>
                                    </Button>

                                    <Button Grid.Column="4"
                                            Command="{Binding NextTransferStepCommand}"
                                            MinWidth="126">
                                        <Button.Style>
                                            <Style TargetType="{x:Type Button}" BasedOn="{StaticResource PrimaryButtonStyle}">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsTransferReviewStep}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding NextTransferStepText}" />
                                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                                       Text="&#xE72A;"
                                                       FontSize="12"
                                                       Margin="7,0,0,0" />
                                        </StackPanel>
                                    </Button>

                                    <Button Grid.Column="4"
                                            Command="{Binding StartTransferCommand}"
                                            MinWidth="164">
                                        <Button.Style>
                                            <Style TargetType="{x:Type Button}" BasedOn="{StaticResource PrimaryButtonStyle}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsTransferReviewStep}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <TextBlock Text="{Binding StartTransferText}" />
                                    </Button>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <Grid Grid.Row="1"
                  Margin="42"
                  Visibility="{Binding IsTransferProcessVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Border Style="{StaticResource PanelBorderStyle}"
                        Padding="34">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="22" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Width="76"
                                    Height="76"
                                    CornerRadius="22"
                                    Background="{StaticResource AccentGradientBrush}">
                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                           Text="&#xE895;"
                                           FontSize="31"
                                           Foreground="#F7F4FF"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           RenderTransformOrigin="0.5,0.5">
                                    <TextBlock.RenderTransform>
                                        <RotateTransform Angle="0" />
                                    </TextBlock.RenderTransform>
                                    <TextBlock.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                     From="0"
                                                                     To="360"
                                                                     Duration="0:0:1.2" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </TextBlock.Triggers>
                                </TextBlock>
                            </Border>

                            <StackPanel Grid.Column="2"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{Binding TransferProcessTitle}"
                                           FontSize="34"
                                           FontWeight="Black"
                                           Foreground="{StaticResource TextBrush}" />
                                <TextBlock Text="{Binding TransferProcessSubtitle}"
                                           Margin="0,8,0,0"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>

                        <Border Grid.Row="1"
                                Background="#12101C"
                                BorderBrush="{StaticResource LineBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="18"
                                Margin="0,30,0,22">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding TransferCurrentStep}"
                                               FontSize="20"
                                               FontWeight="Black"
                                               Foreground="{StaticResource TextBrush}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding TransferCurrentItem}"
                                               Margin="0,6,0,0"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding TransferOverallPercent, StringFormat={}{0}%}"
                                           Foreground="{StaticResource TextBrush}"
                                           FontSize="26"
                                           FontWeight="Black"
                                           Margin="18,0,0,0"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <StackPanel Grid.Row="2"
                                    VerticalAlignment="Top">
                            <TextBlock Text="Общий прогресс"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontWeight="SemiBold" />
                            <ProgressBar Style="{StaticResource RoundedProgressBarStyle}"
                                         Value="{Binding TransferOverallPercent, Mode=OneWay}"
                                         Maximum="100"
                                         Margin="0,9,0,20" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Копирование файлов"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               FontWeight="SemiBold" />
                                    <ProgressBar Style="{StaticResource RoundedProgressBarStyle}"
                                                 Value="{Binding TransferCopyPercent, Mode=OneWay}"
                                                 Maximum="100"
                                                 Margin="0,9,0,8" />
                                    <TextBlock Text="{Binding TransferBytesText}"
                                               Foreground="{StaticResource SubtleTextBrush}"
                                               FontSize="11"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="База данных"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               FontWeight="SemiBold" />
                                    <ProgressBar Style="{StaticResource RoundedProgressBarStyle}"
                                                 Value="{Binding TransferDatabasePercent, Mode=OneWay}"
                                                 Maximum="100"
                                                 Margin="0,9,0,8" />
                                    <TextBlock Text="meta.ini переносится в instance.db"
                                               Foreground="{StaticResource SubtleTextBrush}"
                                               FontSize="11"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>

                            <Border Background="#2A1220"
                                    BorderBrush="#7F1D3A"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="12"
                                    Margin="0,22,0,0"
                                    Visibility="{Binding HasTransferError, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="{Binding TransferError}"
                                           Foreground="{StaticResource ErrorBrush}"
                                           TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>

                        <Grid Grid.Row="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding TransferMessage}"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="1"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Content="Закрыть"
                                    Click="OnCloseButtonClick"
                                    MinWidth="112"
                                    Margin="18,0,0,0" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <views:LanguageSwitchSplash Panel.ZIndex="120" />
    </Grid>
</Window>
