<UserControl x:Class="Fluxora.App.Views.CreateProjectWizardSplash"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Fluxora.App.Controls"
             FontFamily="{StaticResource FluxoraFontBody}"
             FontWeight="Medium"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             TextOptions.TextHintingMode="Fixed"
             RenderOptions.ClearTypeHint="Enabled"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True"
             IsHitTestVisible="{Binding IsCreateProjectPanelOpen}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <SolidColorBrush x:Key="WizardTextBrush" Color="#F7F4FF" />
        <SolidColorBrush x:Key="WizardSecondaryTextBrush" Color="#D8D2EB" />
        <SolidColorBrush x:Key="WizardMutedTextBrush" Color="#9B93B4" />
        <SolidColorBrush x:Key="WizardSubtleTextBrush" Color="#736D86" />
        <SolidColorBrush x:Key="WizardAccentBrush" Color="#7C3AED" />
        <SolidColorBrush x:Key="WizardAccentHoverBrush" Color="#9D7BFF" />
        <SolidColorBrush x:Key="WizardAccentSoftBrush" Color="#241A46" />
        <SolidColorBrush x:Key="WizardAccentLineBrush" Color="#5B3EA0" />
        <SolidColorBrush x:Key="WizardPanelBrush" Color="#171523" />
        <SolidColorBrush x:Key="WizardPanelRaisedBrush" Color="#201D31" />
        <SolidColorBrush x:Key="WizardPanelSoftBrush" Color="#11101B" />
        <SolidColorBrush x:Key="WizardLineBrush" Color="#332D4B" />
        <SolidColorBrush x:Key="WizardErrorBrush" Color="#FB7185" />

        <LinearGradientBrush x:Key="WizardAccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#9D7BFF" Offset="0" />
            <GradientStop Color="#7C3AED" Offset="0.58" />
            <GradientStop Color="#5B21B6" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="WizardButtonBaseStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"
                                              TextElement.FontWeight="{TemplateBinding FontWeight}"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.42" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WizardPrimaryButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource WizardButtonBaseStyle}">
            <Setter Property="Background" Value="{StaticResource WizardAccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource WizardAccentHoverBrush}" />
            <Setter Property="Foreground" Value="{StaticResource WizardTextBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource WizardAccentHoverBrush}" />
                    <Setter Property="BorderBrush" Value="#B197FC" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WizardSecondaryButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource WizardButtonBaseStyle}">
            <Setter Property="Background" Value="#171421" />
            <Setter Property="BorderBrush" Value="{StaticResource WizardLineBrush}" />
            <Setter Property="Foreground" Value="{StaticResource WizardSecondaryTextBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#241F34" />
                    <Setter Property="BorderBrush" Value="{StaticResource WizardAccentLineBrush}" />
                    <Setter Property="Foreground" Value="{StaticResource WizardTextBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WizardTextBoxStyle" TargetType="{x:Type TextBox}">
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="13,0" />
            <Setter Property="Background" Value="#0E0C16" />
            <Setter Property="BorderBrush" Value="{StaticResource WizardLineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource WizardTextBrush}" />
            <Setter Property="CaretBrush" Value="{StaticResource WizardTextBrush}" />
            <Setter Property="SelectionBrush" Value="{StaticResource WizardAccentLineBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource WizardAccentHoverBrush}" />
                                <Setter TargetName="Root" Property="Background" Value="#12101C" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WizardLargeTextBoxStyle" TargetType="{x:Type TextBox}" BasedOn="{StaticResource WizardTextBoxStyle}">
            <Setter Property="Height" Value="72" />
            <Setter Property="Padding" Value="20,0" />
            <Setter Property="FontSize" Value="25" />
            <Setter Property="FontWeight" Value="Black" />
        </Style>

        <Style x:Key="WizardBareTextBoxStyle" TargetType="{x:Type TextBox}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource WizardTextBrush}" />
            <Setter Property="CaretBrush" Value="{StaticResource WizardTextBrush}" />
            <Setter Property="SelectionBrush" Value="{StaticResource WizardAccentLineBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>

        <Style x:Key="WizardFieldLabelStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource WizardTextBrush}" />
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="WizardHintTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource WizardMutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="WizardStepCardStyle" TargetType="{x:Type Border}">
            <Setter Property="Height" Value="68" />
            <Setter Property="Padding" Value="13" />
            <Setter Property="CornerRadius" Value="13" />
            <Setter Property="Background" Value="#16131F" />
            <Setter Property="BorderBrush" Value="{StaticResource WizardLineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="WizardGameListBoxStyle" TargetType="{x:Type ListBox}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="VirtualizingStackPanel.IsVirtualizing" Value="False" />
        </Style>

        <Style x:Key="WizardGameListBoxItemStyle" TargetType="{x:Type ListBoxItem}">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="12" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border x:Name="Card"
                                Background="#15131F"
                                BorderBrush="{StaticResource WizardLineBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="0">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Card" Property="Background" Value="#1B1729" />
                                <Setter TargetName="Card" Property="BorderBrush" Value="{StaticResource WizardAccentLineBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Card" Property="Background" Value="{StaticResource WizardAccentSoftBrush}" />
                                <Setter TargetName="Card" Property="BorderBrush" Value="{StaticResource WizardAccentHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="0"
                                             To="1"
                                             Duration="0:0:0.22" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                             From="12"
                                             To="0"
                                             Duration="0:0:0.28">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <UserControl.Style>
        <Style TargetType="{x:Type UserControl}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCreateProjectPanelOpen}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Style>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FA080711" Offset="0" />
                <GradientStop Color="#FC0D0A18" Offset="0.52" />
                <GradientStop Color="#FD121022" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <Border HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Margin="42,30,42,28"
                ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Новая сборка"
                                   FontSize="12"
                                   FontWeight="Black"
                                   Foreground="{StaticResource WizardMutedTextBrush}" />
                        <TextBlock Text="{Binding CreateProjectStepTitle}"
                                   Margin="0,4,0,0"
                                   FontSize="30"
                                   FontWeight="Black"
                                   Foreground="{StaticResource WizardTextBrush}" />
                        <TextBlock Text="{Binding CreateProjectStepSubtitle}"
                                   Margin="0,6,0,0"
                                   FontSize="13"
                                   Foreground="{StaticResource WizardSecondaryTextBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <Border Grid.Column="1"
                            Height="30"
                            MinWidth="78"
                            Padding="14,0"
                            CornerRadius="15"
                            Background="{StaticResource WizardAccentSoftBrush}"
                            BorderBrush="{StaticResource WizardAccentLineBrush}"
                            BorderThickness="1"
                            VerticalAlignment="Top">
                        <TextBlock Text="{Binding CreateProjectStepCounter}"
                                   Foreground="{StaticResource WizardTextBrush}"
                                   FontWeight="Black"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                </Grid>

                <Grid Grid.Row="1"
                      Margin="0,26,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0">
                        <Border.Style>
                            <Style TargetType="{x:Type Border}" BasedOn="{StaticResource WizardStepCardStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CreateProjectStepIndex}" Value="0">
                                        <Setter Property="Background" Value="{StaticResource WizardAccentSoftBrush}" />
                                        <Setter Property="BorderBrush" Value="{StaticResource WizardAccentHoverBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="34"
                                    Height="34"
                                    CornerRadius="10"
                                    Background="#211B32"
                                    BorderBrush="{StaticResource WizardAccentLineBrush}"
                                    BorderThickness="1">
                                <controls:LineIcon Data="{StaticResource Icon.FileText}"
                                                   Width="17"
                                                   Height="17"
                                                   Foreground="{StaticResource WizardAccentHoverBrush}" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Название" Foreground="{StaticResource WizardTextBrush}" FontWeight="Black" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="Имя папки" Foreground="{StaticResource WizardMutedTextBrush}" FontSize="11" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1"
                            Height="1"
                            Margin="6,0"
                            Background="{StaticResource WizardAccentLineBrush}"
                            Opacity="0.58"
                            VerticalAlignment="Center" />

                    <Border Grid.Column="2">
                        <Border.Style>
                            <Style TargetType="{x:Type Border}" BasedOn="{StaticResource WizardStepCardStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CreateProjectStepIndex}" Value="1">
                                        <Setter Property="Background" Value="{StaticResource WizardAccentSoftBrush}" />
                                        <Setter Property="BorderBrush" Value="{StaticResource WizardAccentHoverBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="34"
                                    Height="34"
                                    CornerRadius="10"
                                    Background="#211B32"
                                    BorderBrush="{StaticResource WizardAccentLineBrush}"
                                    BorderThickness="1">
                                <controls:LineIcon Data="{StaticResource Icon.Gamepad}"
                                                   Width="18"
                                                   Height="18"
                                                   Foreground="{StaticResource WizardAccentHoverBrush}" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Игра" Foreground="{StaticResource WizardTextBrush}" FontWeight="Black" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="Шаблон" Foreground="{StaticResource WizardMutedTextBrush}" FontSize="11" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="3"
                            Height="1"
                            Margin="6,0"
                            Background="{StaticResource WizardAccentLineBrush}"
                            Opacity="0.58"
                            VerticalAlignment="Center" />

                    <Border Grid.Column="4">
                        <Border.Style>
                            <Style TargetType="{x:Type Border}" BasedOn="{StaticResource WizardStepCardStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CreateProjectStepIndex}" Value="2">
                                        <Setter Property="Background" Value="{StaticResource WizardAccentSoftBrush}" />
                                        <Setter Property="BorderBrush" Value="{StaticResource WizardAccentHoverBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="34"
                                    Height="34"
                                    CornerRadius="10"
                                    Background="#211B32"
                                    BorderBrush="{StaticResource WizardAccentLineBrush}"
                                    BorderThickness="1">
                                <controls:LineIcon Data="{StaticResource Icon.Open}"
                                                   Width="18"
                                                   Height="18"
                                                   Foreground="{StaticResource WizardAccentHoverBrush}" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="EXE" Foreground="{StaticResource WizardTextBrush}" FontWeight="Black" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="Файл игры" Foreground="{StaticResource WizardMutedTextBrush}" FontSize="11" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="5"
                            Height="1"
                            Margin="6,0"
                            Background="{StaticResource WizardAccentLineBrush}"
                            Opacity="0.58"
                            VerticalAlignment="Center" />

                    <Border Grid.Column="6">
                        <Border.Style>
                            <Style TargetType="{x:Type Border}" BasedOn="{StaticResource WizardStepCardStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CreateProjectStepIndex}" Value="3">
                                        <Setter Property="Background" Value="{StaticResource WizardAccentSoftBrush}" />
                                        <Setter Property="BorderBrush" Value="{StaticResource WizardAccentHoverBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="34"
                                    Height="34"
                                    CornerRadius="10"
                                    Background="#211B32"
                                    BorderBrush="{StaticResource WizardAccentLineBrush}"
                                    BorderThickness="1">
                                <controls:LineIcon Data="{StaticResource Icon.Folder}"
                                                   Width="18"
                                                   Height="18"
                                                   Foreground="{StaticResource WizardAccentHoverBrush}" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Папка" Foreground="{StaticResource WizardTextBrush}" FontWeight="Black" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="Установка" Foreground="{StaticResource WizardMutedTextBrush}" FontSize="11" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <Border Grid.Row="2"
                        Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType={x:Type Grid}}}"
                        HorizontalAlignment="Center"
                        CornerRadius="18">
                    <Border.Style>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="Background" Value="#F011101B" />
                            <Setter Property="BorderBrush" Value="{StaticResource WizardLineBrush}" />
                            <Setter Property="BorderThickness" Value="1" />
                            <Setter Property="Padding" Value="28" />
                            <Setter Property="MinHeight" Value="320" />
                            <Setter Property="MaxWidth" Value="940" />
                            <Setter Property="VerticalAlignment" Value="Top" />
                            <Setter Property="Margin" Value="0,22,0,18" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsNameStep}" Value="True">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderBrush" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="MinHeight" Value="0" />
                                    <Setter Property="MaxWidth" Value="760" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="Margin" Value="0,54,0,44" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsGameExeStep}" Value="True">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderBrush" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="MinHeight" Value="0" />
                                    <Setter Property="MaxWidth" Value="820" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="Margin" Value="0,54,0,44" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid x:Name="StepHost" ClipToBounds="True">
                        <Grid x:Name="NameStepPanel"
                              Opacity="1"
                              Visibility="Visible"
                              RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <TranslateTransform />
                            </Grid.RenderTransform>
                            <StackPanel Width="540"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <TextBlock Text="Как мы назовём вашу сборку?"
                                           FontSize="27"
                                           FontWeight="Black"
                                           Foreground="{StaticResource WizardTextBrush}"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,18" />
                                <TextBox Text="{Binding ProjectName, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource WizardLargeTextBoxStyle}" />
                            </StackPanel>
                        </Grid>

                        <Grid x:Name="GameStepPanel"
                              Opacity="0"
                              Visibility="Collapsed"
                              RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <TranslateTransform />
                            </Grid.RenderTransform>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <TextBlock Text="Выберите игру"
                                           Style="{StaticResource WizardFieldLabelStyle}" />
                            </StackPanel>

                            <Border Grid.Row="1"
                                    Height="46"
                                    Margin="0,14,0,12"
                                    Background="#0E0C16"
                                    BorderBrush="{StaticResource WizardLineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <Border.Style>
                                    <Style TargetType="{x:Type Border}">
                                        <Setter Property="Background" Value="#0E0C16" />
                                        <Setter Property="BorderBrush" Value="{StaticResource WizardLineBrush}" />
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Setter Property="CornerRadius" Value="12" />
                                        <Style.Triggers>
                                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                                <Setter Property="Background" Value="#12101C" />
                                                <Setter Property="BorderBrush" Value="{StaticResource WizardAccentHoverBrush}" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <controls:LineIcon Data="{StaticResource Icon.Search}"
                                                       Width="18"
                                                       Height="18"
                                                       Foreground="{StaticResource WizardMutedTextBrush}"
                                                       Margin="15,0,0,0"
                                                       HorizontalAlignment="Left"
                                                       VerticalAlignment="Center" />
                                    <TextBlock Text="Поиск игры"
                                               Margin="45,0,14,0"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource WizardSubtleTextBrush}"
                                               IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="{x:Type TextBlock}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding GameSearchText}" Value="">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBox Text="{Binding GameSearchText, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource WizardBareTextBoxStyle}"
                                             Margin="43,0,14,0" />
                                </Grid>
                            </Border>

                            <Grid Grid.Row="2">
                                <ListBox x:Name="GameTemplateList"
                                         ItemsSource="{Binding VisibleTemplates}"
                                         SelectedItem="{Binding SelectedTemplate, Mode=TwoWay}"
                                         ItemContainerStyle="{StaticResource WizardGameListBoxItemStyle}"
                                         Style="{StaticResource WizardGameListBoxStyle}"
                                         MaxHeight="188"
                                         Visibility="{Binding HasVisibleTemplates, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid x:Name="DefaultGameLayout"
                                                      Margin="18,16">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="44" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Width="34"
                                                            Height="34"
                                                            CornerRadius="10"
                                                            Background="#211B32"
                                                            BorderBrush="{StaticResource WizardAccentLineBrush}"
                                                            BorderThickness="1"
                                                            VerticalAlignment="Top">
                                                        <controls:LineIcon Data="{StaticResource Icon.Gamepad}"
                                                                           Width="17"
                                                                           Height="17"
                                                                           Foreground="{StaticResource WizardAccentHoverBrush}" />
                                                    </Border>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   Foreground="{StaticResource WizardTextBrush}"
                                                                   FontWeight="Black" />
                                                        <TextBlock Text="{Binding Summary}"
                                                                   Margin="0,7,0,0"
                                                                   Foreground="{StaticResource WizardMutedTextBrush}"
                                                                   FontSize="12"
                                                                   TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </Grid>

                                                <Grid x:Name="SkyrimGameLayout"
                                                      Visibility="Collapsed"
                                                      MinHeight="78"
                                                      Margin="18,14">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="58" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Width="46"
                                                            Height="46"
                                                            Background="#0E0C16"
                                                            BorderBrush="{StaticResource WizardAccentLineBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="11"
                                                            ClipToBounds="True"
                                                            VerticalAlignment="Center">
                                                        <Image Source="pack://application:,,,/Assets/Images/SkyrimSpecialEditionIcon.png"
                                                               Stretch="UniformToFill"
                                                               SnapsToDevicePixels="True" />
                                                    </Border>
                                                    <StackPanel Grid.Column="1"
                                                                VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   Foreground="{StaticResource WizardTextBrush}"
                                                                   FontWeight="Black" />
                                                        <TextBlock Text="{Binding Summary}"
                                                                   Margin="0,7,0,0"
                                                                   Foreground="{StaticResource WizardMutedTextBrush}"
                                                                   FontSize="12"
                                                                   TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </Grid>
                                            </Grid>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding DisplayName}" Value="Skyrim Special Edition">
                                                    <Setter TargetName="DefaultGameLayout" Property="Visibility" Value="Collapsed" />
                                                    <Setter TargetName="SkyrimGameLayout" Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <Border Background="#15131F"
                                        BorderBrush="{StaticResource WizardLineBrush}"
                                        BorderThickness="1"
                                        CornerRadius="14"
                                        Padding="18"
                                        VerticalAlignment="Top">
                                    <Border.Style>
                                        <Style TargetType="{x:Type Border}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasVisibleTemplates}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="{Binding GameSearchResultText}"
                                                   Foreground="{StaticResource WizardTextBrush}"
                                                   FontWeight="Black" />
                                        <TextBlock Text="Попробуйте изменить запрос или проверьте подключение C++ core."
                                                   Margin="0,6,0,0"
                                                   Style="{StaticResource WizardHintTextStyle}" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                        </Grid>

                        <Grid x:Name="ExeStepPanel"
                              Opacity="0"
                              Visibility="Collapsed"
                              RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <TranslateTransform />
                            </Grid.RenderTransform>
                            <StackPanel Width="760"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <TextBlock Text="Выберите EXE игры"
                                           FontSize="26"
                                           FontWeight="Black"
                                           Foreground="{StaticResource WizardTextBrush}"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,8" />
                                <TextBlock Text="Можно вставить путь вручную или выбрать файл через проводник."
                                           Foreground="{StaticResource WizardMutedTextBrush}"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,22" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding GamePath, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource WizardTextBoxStyle}" />
                                    <Button Grid.Column="2"
                                            Style="{StaticResource WizardSecondaryButtonStyle}"
                                            Command="{Binding BrowseGamePathCommand}"
                                            MinWidth="126">
                                        <StackPanel Orientation="Horizontal">
                                            <controls:LineIcon Data="{StaticResource Icon.Folder}" Width="15" Height="15" Margin="0,0,8,0" />
                                            <TextBlock Text="Выбрать" />
                                        </StackPanel>
                                    </Button>
                                </Grid>

                                <Border Background="#171421"
                                        BorderBrush="{StaticResource WizardLineBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="14"
                                        Margin="0,16,0,0"
                                        Visibility="{Binding HasResolvedTemplate, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel Orientation="Horizontal">
                                        <controls:LineIcon Data="{StaticResource Icon.Gamepad}"
                                                           Width="17"
                                                           Height="17"
                                                           Foreground="{StaticResource WizardAccentHoverBrush}"
                                                           Margin="0,0,10,0" />
                                        <TextBlock VerticalAlignment="Center" TextWrapping="Wrap">
                                            <Run Text="Игра: " Foreground="{StaticResource WizardMutedTextBrush}" />
                                            <Run Text="{Binding SelectedResolvedTemplate.DisplayName, Mode=OneWay}"
                                                 FontWeight="Black"
                                                 Foreground="{StaticResource WizardTextBrush}" />
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <Grid x:Name="InstallStepPanel"
                              Opacity="0"
                              Visibility="Collapsed"
                              RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <TranslateTransform />
                            </Grid.RenderTransform>
                            <StackPanel>
                                <TextBlock Text="Куда установить сборку"
                                           Style="{StaticResource WizardFieldLabelStyle}" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding InstallRootDirectory, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource WizardTextBoxStyle}" />
                                    <Button Grid.Column="2"
                                            Style="{StaticResource WizardSecondaryButtonStyle}"
                                            Command="{Binding BrowseInstallRootCommand}"
                                            MinWidth="118">
                                        <StackPanel Orientation="Horizontal">
                                            <controls:LineIcon Data="{StaticResource Icon.Folder}" Width="15" Height="15" Margin="0,0,8,0" />
                                            <TextBlock Text="Папка" />
                                        </StackPanel>
                                    </Button>
                                </Grid>

                                <Border Background="#171421"
                                        BorderBrush="{StaticResource WizardLineBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="16"
                                        Margin="0,18,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Итоговый путь"
                                                   FontWeight="Black"
                                                   Foreground="{StaticResource WizardTextBrush}" />
                                        <TextBlock Text="{Binding TargetProjectDirectory}"
                                                   Margin="0,7,0,0"
                                                   Style="{StaticResource WizardHintTextStyle}" />
                                    </StackPanel>
                                </Border>

                                <Border Background="{StaticResource WizardAccentSoftBrush}"
                                        BorderBrush="{StaticResource WizardAccentLineBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="16"
                                        Margin="0,14,0,0"
                                        Visibility="{Binding HasResolvedTemplate, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel Orientation="Horizontal">
                                        <controls:LineIcon Data="{StaticResource Icon.Layers}"
                                                           Width="17"
                                                           Height="17"
                                                           Foreground="{StaticResource WizardAccentHoverBrush}"
                                                           Margin="0,0,10,0" />
                                        <TextBlock VerticalAlignment="Center" TextWrapping="Wrap">
                                            <Run Text="Будет развёрнут шаблон: " Foreground="{StaticResource WizardMutedTextBrush}" />
                                            <Run Text="{Binding SelectedResolvedTemplate.DisplayName, Mode=OneWay}"
                                                 FontWeight="Black"
                                                 Foreground="{StaticResource WizardTextBrush}" />
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <Grid Grid.Row="3"
                      Margin="0,8,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding ValidationMessage}"
                                   Foreground="{StaticResource WizardErrorBrush}"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center" />

                        <Button Grid.Column="1"
                                Style="{StaticResource WizardSecondaryButtonStyle}"
                                Command="{Binding CancelCreateProjectCommand}"
                                Content="Отмена"
                                MinWidth="104" />

                        <Button Grid.Column="3"
                                Style="{StaticResource WizardSecondaryButtonStyle}"
                                Command="{Binding PreviousCreateStepCommand}"
                                MinWidth="104">
                            <StackPanel Orientation="Horizontal">
                                <controls:LineIcon Data="{StaticResource Icon.Back}" Width="15" Height="15" Margin="0,0,8,0" />
                                <TextBlock Text="Назад" />
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="5"
                                Command="{Binding NextCreateStepCommand}"
                                MinWidth="122">
                            <Button.Style>
                                <Style TargetType="{x:Type Button}" BasedOn="{StaticResource WizardPrimaryButtonStyle}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsInstallStep}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Далее" />
                                <controls:LineIcon Data="{StaticResource Icon.Back}"
                                                   Width="15"
                                                   Height="15"
                                                   Margin="8,0,0,0"
                                                   RenderTransformOrigin="0.5,0.5">
                                    <controls:LineIcon.RenderTransform>
                                        <RotateTransform Angle="180" />
                                    </controls:LineIcon.RenderTransform>
                                </controls:LineIcon>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="5"
                                Command="{Binding CreateProjectCommand}"
                                MinWidth="138">
                            <Button.Style>
                                <Style TargetType="{x:Type Button}" BasedOn="{StaticResource WizardPrimaryButtonStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsInstallStep}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <controls:LineIcon Data="{StaticResource Icon.Plus}" Width="15" Height="15" Margin="0,0,8,0" />
                                <TextBlock Text="Создать" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
