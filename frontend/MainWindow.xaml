                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding DownloadSpeedDisplayText}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding DownloadSpeedDisplayText}"
                                   Visibility="{Binding HasDownloadSpeedDisplay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding ProgressPercentText}"
                                   Foreground="{StaticResource TextBrush}"
                                   FontSize="10"
                                   FontWeight="Black"
                                   Margin="10,0,0,0" />
                    </Grid>
                    <ProgressBar Style="{StaticResource DownloadProgressBarStyle}"
                                 Grid.Row="1"
                                 Value="{Binding ProgressPercent}"
                                 IsIndeterminate="{Binding IsProgressIndeterminate}"
                                 services:ProgressAnimationService.IsActive="{Binding IsDownloading}" />
                    <Grid x:Name="ProgressCaption"
                          Grid.Row="2"
                          Margin="0,6,0,0"
                          Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
