<Window x:Class="Fluxora.App.ExecutableManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:services="clr-namespace:Fluxora.App.Services"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Исполняемые файлы"
        Width="760"
        Height="520"
        MinWidth="720"
        MinHeight="500"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        Background="#171523"
        FontFamily="{StaticResource FluxoraFontBody}"
        FontWeight="Medium"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextHintingMode="Fixed"
        RenderOptions.ClearTypeHint="Enabled"
        FontSize="12"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        Loaded="OnLoaded">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="66"
                            CornerRadius="10"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <SolidColorBrush x:Key="TextBrush" Color="#F7F4FF" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#C5BEDA" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#918AA8" />
        <SolidColorBrush x:Key="AccentBrush" Color="#7C3AED" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#8B5CF6" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#241A46" />
        <SolidColorBrush x:Key="AccentLineBrush" Color="#493184" />
        <SolidColorBrush x:Key="PanelBrush" Color="#171523" />
        <SolidColorBrush x:Key="PanelRaisedBrush" Color="#201D31" />
        <SolidColorBrush x:Key="PanelSoftBrush" Color="#11101B" />
        <SolidColorBrush x:Key="PanelHoverBrush" Color="#27223A" />
        <SolidColorBrush x:Key="LineBrush" Color="#302B46" />
        <SolidColorBrush x:Key="LineHoverBrush" Color="#55467D" />
        <SolidColorBrush x:Key="ErrorBrush" Color="#FB7185" />
        <services:ExecutableIconSourceConverter x:Key="ExecutableIconSourceConverter" />

        <Style x:Key="DialogCloseButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root" Background="{TemplateBinding Background}">
                            <Viewbox Width="16"
                                     Height="16"
                                     Stretch="Uniform"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                                <Path Width="24"
                                      Height="24"
                                      Data="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"
                                      Stroke="{TemplateBinding Foreground}"
                                      StrokeThickness="1.8"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round" />
                            </Viewbox>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.72" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DialogButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="Padding" Value="13,0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"
                                              TextElement.FontWeight="{TemplateBinding FontWeight}"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource LineHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.48" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryDialogButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource DialogButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
            <Setter Property="Foreground" Value="#F7F4FF" />
        </Style>

        <Style x:Key="SecondaryDialogButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource DialogButtonStyle}">
            <Setter Property="Background" Value="{StaticResource PanelRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PanelHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DialogTextBoxStyle" TargetType="{x:Type TextBox}">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Background" Value="{StaticResource PanelSoftBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="CaretBrush" Value="{StaticResource AccentHoverBrush}" />
            <Setter Property="SelectionBrush" Value="{StaticResource AccentHoverBrush}" />
            <Setter Property="SelectionOpacity" Value="0.35" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Disabled" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                                <Setter TargetName="Root" Property="Background" Value="#151322" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,7" />
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="11" />
        </Style>

        <Style x:Key="ExecutableListBoxStyle" TargetType="{x:Type ListBox}">
            <Setter Property="Background" Value="{StaticResource PanelSoftBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        </Style>

        <Style TargetType="{x:Type ListBoxItem}">
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border x:Name="Root"
                                Margin="6,5"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource PanelHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="Transparent">
        <Border Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="1"
                CornerRadius="16"
                Padding="22,20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid MouseLeftButtonDown="OnWindowDragMouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Исполняемые файлы"
                                   FontSize="21"
                                   FontWeight="Black"
                                   Foreground="{StaticResource TextBrush}" />
                        <TextBlock Text="Добавляйте игры и инструменты, меняйте путь и аргументы запуска."
                                   Margin="0,5,0,0"
                                   Style="{StaticResource MutedTextStyle}" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Style="{StaticResource DialogCloseButtonStyle}"
                            Tag="{StaticResource Icon.WindowClose}"
                            AutomationProperties.Name="Закрыть"
                            Click="OnCancelClick" />
                </Grid>

                <Grid Grid.Row="1" Margin="0,20,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <ListBox x:Name="ExecutablesListBox"
                                 Style="{StaticResource ExecutableListBoxStyle}"
                                 ItemsSource="{Binding Executables}"
                                 SelectedItem="{Binding SelectedExecutable, Mode=TwoWay}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="34" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="26"
                                                Height="26"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Top"
                                                Background="#211B32"
                                                BorderBrush="{StaticResource LineBrush}"
                                                BorderThickness="1"
                                                CornerRadius="6">
                                            <Image Width="20"
                                                   Height="20"
                                                   Source="{Binding IconPath, Converter={StaticResource ExecutableIconSourceConverter}}"
                                                   Stretch="Uniform"
                                                   RenderOptions.BitmapScalingMode="HighQuality" />
                                        </Border>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding DisplayTitle}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding SummaryText}"
                                                       Margin="0,3,0,0"
                                                       Style="{StaticResource MutedTextStyle}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <StackPanel Grid.Row="1"
                                    Orientation="Horizontal"
                                    Margin="0,12,0,0">
                            <Button Style="{StaticResource SecondaryDialogButtonStyle}"
                                    MinWidth="112"
                                    Click="OnAddExecutableClick">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                                               Text="&#xE710;"
                                               FontSize="12"
                                               Margin="0,0,7,0" />
                                    <TextBlock Text="Добавить" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SecondaryDialogButtonStyle}"
                                    MinWidth="94"
                                    Margin="8,0,0,0"
                                    IsEnabled="{Binding HasSelectedExecutable}"
                                    Click="OnDeleteExecutableClick">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                                               Text="&#xE74D;"
                                               FontSize="12"
                                               Margin="0,0,7,0" />
                                    <TextBlock Text="Удалить" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Column="2"
                            Background="{StaticResource PanelRaisedBrush}"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="18">
                        <Grid IsEnabled="{Binding HasSelectedExecutable}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <TextBlock Text="Название"
                                           Style="{StaticResource FieldLabelStyle}" />
                                <TextBox Style="{StaticResource DialogTextBoxStyle}"
                                         Text="{Binding SelectedExecutable.DisplayName, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Row="1" Margin="0,15,0,0">
                                <TextBlock Text="Путь к .exe"
                                           Style="{StaticResource FieldLabelStyle}" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Style="{StaticResource DialogTextBoxStyle}"
                                             Text="{Binding SelectedExecutable.ExecutablePath, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="2"
                                            Style="{StaticResource SecondaryDialogButtonStyle}"
                                            MinWidth="98"
                                            Click="OnBrowseExecutableClick">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                                       Text="&#xE8B7;"
                                                       FontSize="12"
                                                       Margin="0,0,7,0" />
                                            <TextBlock Text="Обзор" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Margin="0,15,0,0">
                                <TextBlock Text="Аргументы"
                                           Style="{StaticResource FieldLabelStyle}" />
                                <TextBox Style="{StaticResource DialogTextBoxStyle}"
                                         Text="{Binding SelectedExecutable.Arguments, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Row="3" Margin="0,15,0,0">
                                <TextBlock Text="Рабочая папка"
                                           Style="{StaticResource FieldLabelStyle}" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Style="{StaticResource DialogTextBoxStyle}"
                                             Text="{Binding SelectedExecutable.WorkingDirectory, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="2"
                                            Style="{StaticResource SecondaryDialogButtonStyle}"
                                            MinWidth="98"
                                            Click="OnBrowseWorkingDirectoryClick">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                                       Text="&#xE8B7;"
                                                       FontSize="12"
                                                       Margin="0,0,7,0" />
                                            <TextBlock Text="Папка" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <Grid Grid.Row="2" Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="{Binding ValidationMessage}"
                               Foreground="{StaticResource ErrorBrush}"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap" />

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Style="{StaticResource SecondaryDialogButtonStyle}"
                                IsCancel="True"
                                Click="OnCancelClick"
                                Margin="0,0,10,0"
                                Content="Отмена" />
                        <Button Style="{StaticResource PrimaryDialogButtonStyle}"
                                IsDefault="True"
                                Click="OnSaveClick"
                                Content="Сохранить" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
