                                          ToolTip="{Binding SelectedExecutableToolTip}" />
                                 <Button Style="{StaticResource PrimaryButtonStyle}"
                                         Command="{Binding LaunchSelectedExecutableCommand}"
                                         MinWidth="102"
                                         Height="28"
                                         ToolTip="{Binding SelectedExecutableToolTip}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                                   Text="&#xE768;"
                                                   FontSize="11"
                                                   Margin="0,0,6,0" />
                                        <TextBlock Text="Запустить" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="65*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="35*" MinWidth="360" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Style="{StaticResource PanelBorderStyle}"
                                Padding="14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Моды"
                                                   FontSize="17"
                                                   FontWeight="Black"
                                                   Foreground="{StaticResource TextBrush}" />
                                        <TextBlock Text="{Binding ModCountText}"
                                                   Margin="0,2,0,0"
                                                   Style="{StaticResource MutedTextStyle}" />
                                    </StackPanel>
                                    <WrapPanel Grid.Column="1"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center">
                                         <Button Style="{StaticResource CompactSecondaryButtonStyle}"
                                                 Command="{Binding CheckModUpdatesCommand}"
                                                 MinWidth="104"
                                                 Margin="0,0,8,0"
                                                 ToolTip="Проверить версии Nexus-модов и обновить remote cache">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE895;" FontSize="12" Margin="0,0,7,0" />
                                                 <TextBlock Text="Проверить" />
                                             </StackPanel>
                                         </Button>
                                         <Button Style="{StaticResource CompactSecondaryButtonStyle}"
                                                 Command="{Binding MoveSelectedModUpCommand}"
                                                 Width="28"
                                                 Padding="0"
                                                 Margin="0,0,6,0"
                                                 ToolTip="Выше">
                                             <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE70E;" FontSize="12" />
                                         </Button>
                                         <Button Style="{StaticResource CompactSecondaryButtonStyle}"
                                                 Command="{Binding MoveSelectedModDownCommand}"
                                                 Width="28"
                                                 Padding="0"
                                                 Margin="0,0,8,0"
                                                 ToolTip="Ниже">
                                             <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE70D;" FontSize="12" />
                                         </Button>
                                         <Button Style="{StaticResource CompactSecondaryButtonStyle}"
                                                 Command="{Binding DeleteSelectedModCommand}"
                                                 MinWidth="88"
                                                Margin="0"
                                                ToolTip="Удалить выбранный мод или разделитель">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE74D;" FontSize="12" Margin="0,0,7,0" />
                                                <TextBlock Text="Удалить" />
                                            </StackPanel>
                                        </Button>
                                    </WrapPanel>
                                </Grid>

                                <Grid Grid.Row="1" Margin="0,12,0,0">
                                    <DataGrid x:Name="ModsGrid"
                                              ItemsSource="{Binding Mods}"
                                              SelectedItem="{Binding SelectedMod}"
                                              SelectionUnit="FullRow"
                                              EnableRowVirtualization="True"
                                              EnableColumnVirtualization="True"
                                              VirtualizingPanel.IsVirtualizing="True"
                                              VirtualizingPanel.VirtualizationMode="Recycling"
                                              ScrollViewer.CanContentScroll="True"
                                              CanUserReorderColumns="False"
                                              CanUserResizeRows="False"
                                              ToolTip="Зажмите строку и перетащите её в нужное место"
                                              PreviewMouseRightButtonDown="OnModsGridPreviewMouseRightButtonDown">
                                        <DataGrid.ContextMenu>
                                            <ContextMenu Style="{StaticResource DarkContextMenuStyle}">
                                                <MenuItem Header="Включить"
                                                          Style="{StaticResource DarkMenuItemStyle}"
                                                          Command="{Binding PlacementTarget.DataContext.EnableSelectedModCommand, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext.SelectedMod, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}">
                                                    <MenuItem.Icon>
                                                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                                                   Text="&#xE8FB;"
                                                                   FontSize="12"
                                                                   Foreground="#C4B5FD" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="Включить всё"
                                                          Style="{StaticResource DarkMenuItemStyle}"
                                                          Command="{Binding PlacementTarget.DataContext.EnableAllModsCommand, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}">
                                                    <MenuItem.Icon>
                                                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                                                   Text="&#xE73E;"
                                                                   FontSize="12"
                                                                   Foreground="#C4B5FD" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="Выключить"
                                                          Style="{StaticResource DarkMenuItemStyle}"
                                                          Command="{Binding PlacementTarget.DataContext.DisableSelectedModCommand, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext.SelectedMod, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}">
                                                    <MenuItem.Icon>
                                                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                                                   Text="&#xE711;"
                                                                   FontSize="12"
                                                                   Foreground="{StaticResource TextSecondaryBrush}" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="Выключить всё"
                                                          Style="{StaticResource DarkMenuItemStyle}"
                                                          Command="{Binding PlacementTarget.DataContext.DisableAllModsCommand, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}">
                                                    <MenuItem.Icon>
                                                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                                                   Text="&#xE711;"
                                                                   FontSize="12"
                                                                   Foreground="{StaticResource TextSecondaryBrush}" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <Separator Margin="4,4" />
                                                <MenuItem Header="Создать разделитель..."
                                                          Style="{StaticResource DarkMenuItemStyle}"
                                                          Command="{Binding PlacementTarget.DataContext.CreateModSeparatorCommand, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}">
                                                    <MenuItem.Icon>
                                                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                                                   Text="&#xE8A5;"
                                                                   FontSize="12"
                                                                   Foreground="{StaticResource AccentHoverBrush}" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <Separator Margin="4,4" />
                                                <MenuItem Header="Удалить"
                                                          Style="{StaticResource DarkMenuItemStyle}"
                                                          Command="{Binding PlacementTarget.DataContext.DeleteSelectedModCommand, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext.SelectedMod, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}">
                                                    <MenuItem.Icon>
                                                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                                                   Text="&#xE74D;"
                                                                   FontSize="12"
                                                                   Foreground="{StaticResource ErrorBrush}" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                            </ContextMenu>
                                        </DataGrid.ContextMenu>
                                        <DataGrid.Style>
                                            <Style TargetType="{x:Type DataGrid}" BasedOn="{StaticResource DarkDataGridStyle}">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasModOrderItems}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGrid.Style>
                                        <DataGrid.RowStyle>
                                            <Style TargetType="{x:Type DataGridRow}">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                                <Setter Property="MinHeight" Value="36" />
                                                <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
                                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                                                <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
                                                <Setter Property="RenderTransform">
                                                    <Setter.Value>
                                                        <TranslateTransform Y="0" />
                                                    </Setter.Value>
                                                </Setter>
                                                <!-- Smoothly fold the row away when its separator is collapsed -->
                                                <Setter Property="services:AnimatedCollapseBehavior.IsHidden" Value="{Binding IsHidden}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSeparator}" Value="True">
                                                        <Setter Property="MinHeight" Value="34" />
                                                        <Setter Property="Background" Value="{StaticResource PanelSoftBrush}" />
                                                        <Setter Property="Foreground" Value="{StaticResource AccentHoverBrush}" />
                                                        <Setter Property="FontWeight" Value="Bold" />
                                                    </DataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource PanelHoverBrush}" />
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGrid.RowStyle>
                                        <DataGrid.Columns>
                                            <DataGridTemplateColumn Header=""
                                                                    IsReadOnly="True"
                                                                    Width="48">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Grid>
                                                            <!-- Separator fold toggle, tucked into the left corner -->
                                                            <Button Style="{StaticResource SeparatorCollapseButtonStyle}"
                                                                    Command="{Binding DataContext.ToggleModSeparatorCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                                    CommandParameter="{Binding}"
                                                                    HorizontalAlignment="Left"
                                                                    VerticalAlignment="Center">
                                                                <Button.Visibility>
                                                                    <Binding Path="IsSeparator" Converter="{StaticResource BooleanToVisibilityConverter}" />
                                                                </Button.Visibility>
                                                            </Button>
                                                            <!-- Enabled indicator for mods that are NOT grouped under a separator.
                                                                 Grouped mods show their checkbox inline in the name column instead,
                                                                 so the whole plate shifts right and reads as nested in the separator. -->
                                                            <CheckBox IsChecked="{Binding IsEnabled, Mode=OneWay}"
                                                                      IsHitTestVisible="False"
                                                                      Focusable="False"
                                                                      HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center">
                                                                <CheckBox.Style>
                                                                    <Style TargetType="{x:Type CheckBox}" BasedOn="{StaticResource FluxoraCheckBoxStyle}">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                        <Style.Triggers>
                                                                            <MultiDataTrigger>
                                                                                <MultiDataTrigger.Conditions>
                                                                                    <Condition Binding="{Binding IsMod}" Value="True" />
                                                                                    <Condition Binding="{Binding IsUnderSeparator}" Value="False" />
                                                                                </MultiDataTrigger.Conditions>
                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                            </MultiDataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </CheckBox.Style>
                                                            </CheckBox>
                                                        </Grid>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header=""
                                                                    IsReadOnly="True"
                                                                    Width="42">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"
                                                                    ToolTip="{Binding ConflictIndicatorToolTip}">
                                                            <StackPanel.Style>
                                                                <Style TargetType="{x:Type StackPanel}">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding HasConflictIndicator}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </StackPanel.Style>

                                                            <controls:LineIcon Data="{StaticResource Icon.ConflictDot}"
                                                                               Fill="{StaticResource ConflictFullyOverwrittenBrush}"
                                                                               Foreground="{StaticResource ConflictFullyOverwrittenBrush}"
                                                                               StrokeThickness="0"
                                                                                Width="14"
                                                                               Height="14">
                                                                <controls:LineIcon.Style>
                                                                    <Style TargetType="{x:Type controls:LineIcon}"
                                                                           BasedOn="{StaticResource {x:Type controls:LineIcon}}">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsFullyOverwritten}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </controls:LineIcon.Style>
                                                            </controls:LineIcon>

                                                            <Border Width="16"
                                                                    Height="16"
                                                                    CornerRadius="8"
                                                                    Background="{StaticResource ConflictOverwritesBrush}"
                                                                    Margin="0,0,3,0">
                                                                <Border.Style>
                                                                    <Style TargetType="{x:Type Border}">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding ShowsOverwritesIcon}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <controls:LineIcon Data="{StaticResource Icon.ConflictPlus}"
                                                                                   Foreground="#06140B"
                                                                                   StrokeThickness="2.4"
                                                                                   Width="12"
                                                                                   Height="12"
                                                                                   HorizontalAlignment="Center"
                                                                                   VerticalAlignment="Center" />
                                                            </Border>

                                                            <Border Width="16"
                                                                    Height="16"
                                                                    CornerRadius="8"
                                                                    Background="{StaticResource ConflictOverwrittenBrush}">
                                                                <Border.Style>
                                                                    <Style TargetType="{x:Type Border}">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding ShowsOverwrittenIcon}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <controls:LineIcon Data="{StaticResource Icon.ConflictMinus}"
                                                                                   Foreground="#190707"
                                                                                   StrokeThickness="2.4"
                                                                                   Width="12"
                                                                                   Height="12"
                                                                                   HorizontalAlignment="Center"
                                                                                   VerticalAlignment="Center" />
                                                            </Border>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="Название"
                                                                    IsReadOnly="True"
                                                                    Width="*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <!-- Leading block. For a mod under a separator it nudges right and reveals
                                                             an inline checkbox, so the plate starts at the separator's title. -->
                                                        <Grid VerticalAlignment="Center">
                                                            <Grid.Style>
                                                                <Style TargetType="{x:Type Grid}">
                                                                    <Setter Property="Margin" Value="0" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsUnderSeparator}" Value="True">
                                                                            <Setter Property="Margin" Value="10,0,0,0" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Grid.Style>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <CheckBox Grid.Column="0"
                                                                      IsChecked="{Binding IsEnabled, Mode=OneWay}"
                                                                      IsHitTestVisible="False"
                                                                      Focusable="False"
                                                                      VerticalAlignment="Center"
                                                                      Margin="0,0,9,0">
                                                                <CheckBox.Style>
                                                                    <Style TargetType="{x:Type CheckBox}" BasedOn="{StaticResource FluxoraCheckBoxStyle}">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsUnderSeparator}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </CheckBox.Style>
                                                            </CheckBox>
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding DisplayName}"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       VerticalAlignment="Center">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="{x:Type TextBlock}">
                                                                        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                                                        <Setter Property="FontWeight" Value="SemiBold" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsSeparator}" Value="True">
                                                                                <Setter Property="Foreground" Value="{StaticResource AccentHoverBrush}" />
                                                                                <Setter Property="FontWeight" Value="Black" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Grid>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Header="Версия"
                                                                Binding="{Binding VersionText}"
                                                                IsReadOnly="True"
                                                                Width="82" />
                                            <DataGridTextColumn Header="Latest"
                                                                Binding="{Binding LatestVersionText}"
                                                                IsReadOnly="True"
                                                                Width="82" />
                                            <DataGridTextColumn Header="Статус"
                                                                Binding="{Binding UpdateStatus}"
                                                                IsReadOnly="True"
                                                                Width="116" />
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <Border Padding="22">
                                        <Border.ContextMenu>
                                            <ContextMenu Style="{StaticResource DarkContextMenuStyle}">
                                                <MenuItem Header="Создать разделитель..."
                                                          Style="{StaticResource DarkMenuItemStyle}"
                                                          Command="{Binding PlacementTarget.DataContext.CreateModSeparatorCommand, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}">
                                                    <MenuItem.Icon>
                                                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                                                   Text="&#xE8A5;"
                                                                   FontSize="12"
                                                                   Foreground="{StaticResource AccentHoverBrush}" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <Border.Style>
                                            <Style TargetType="{x:Type Border}" BasedOn="{StaticResource InnerPanelStyle}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasModOrderItems}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel VerticalAlignment="Center"
                                                    HorizontalAlignment="Center"
                                                    MaxWidth="390">
                                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                                       Text="&#xE8B7;"
                                                       FontSize="28"
                                                       Foreground="{StaticResource AccentHoverBrush}"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,0,0,10" />
                                            <TextBlock Text="Папка mods пуста"
                                                       FontSize="17"
                                                       FontWeight="Black"
                                                       Foreground="{StaticResource TextBrush}"
                                                       TextAlignment="Center" />
                                            <TextBlock Text="Добавьте моды через NXM или вручную, затем обновите список."
                                                       Margin="0,8,0,0"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2"
                                Style="{StaticResource PanelBorderStyle}"
                                Padding="12">
                            <TabControl Style="{StaticResource ModernTabControlStyle}"
                                        ItemContainerStyle="{StaticResource ModernTabItemStyle}"
                                        SelectedIndex="{Binding SelectedWorkspaceTabIndex, Mode=TwoWay}">
                                <TabItem Header="Плагины">
                                    <Grid Margin="0,10,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="Порядок загрузки"
                                                           FontSize="12"
                                                           FontWeight="Black"
                                                           Foreground="{StaticResource TextBrush}" />
                                                <TextBlock Text="{Binding PluginCountText}"
                                                           Margin="0,2,0,0"
                                                           Style="{StaticResource MutedTextStyle}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <Button Style="{StaticResource CompactSecondaryButtonStyle}"
                                                        Command="{Binding MoveSelectedPluginUpCommand}"
                                                        Width="28"
                                                        Padding="0"
                                                        Margin="0,0,6,0"
                                                        ToolTip="Выше">
                                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE70E;" FontSize="12" />
                                                </Button>
                                                <Button Style="{StaticResource CompactSecondaryButtonStyle}"
                                                        Command="{Binding MoveSelectedPluginDownCommand}"
                                                        Width="28"
                                                        Padding="0"
                                                        ToolTip="Ниже">
                                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE70D;" FontSize="12" />
                                                </Button>
                                            </StackPanel>
                                        </Grid>

                                        <Grid Grid.Row="1" Margin="0,10,0,0">
                                            <ListBox x:Name="PluginsListBox"
                                                     ItemsSource="{Binding Plugins}"
                                                     SelectedItem="{Binding SelectedPlugin}"
                                                     ItemContainerStyle="{StaticResource PluginListBoxItemStyle}"
                                                     Background="Transparent"
                                                     BorderThickness="0"
                                                     AllowDrop="True"
                                                     VirtualizingPanel.IsVirtualizing="True"
                                                     VirtualizingPanel.VirtualizationMode="Recycling"
                                                     ScrollViewer.CanContentScroll="True"
                                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                     PreviewMouseRightButtonDown="OnPluginsListPreviewMouseRightButtonDown">
                                                <ListBox.ContextMenu>
                                                    <ContextMenu Style="{StaticResource DarkContextMenuStyle}">
                                                        <MenuItem Header="Создать разделитель..."
                                                                  Style="{StaticResource DarkMenuItemStyle}"
                                                                  Command="{Binding PlacementTarget.DataContext.CreatePluginSeparatorCommand, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}">
                                                            <MenuItem.Icon>
                                                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                                                           Text="&#xE8A5;"
                                                                           FontSize="12"
                                                                           Foreground="{StaticResource AccentHoverBrush}" />
                                                            </MenuItem.Icon>
                                                        </MenuItem>
                                                        <Separator Margin="4,4" />
                                                        <MenuItem Header="Удалить разделитель"
                                                                  Style="{StaticResource DarkMenuItemStyle}"
                                                                  Command="{Binding PlacementTarget.DataContext.DeleteSelectedPluginCommand, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext.SelectedPlugin, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}">
                                                            <MenuItem.Icon>
                                                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                                                           Text="&#xE74D;"
                                                                           FontSize="12"
                                                                           Foreground="{StaticResource ErrorBrush}" />
                                                            </MenuItem.Icon>
                                                        </MenuItem>
                                                    </ContextMenu>
                                                </ListBox.ContextMenu>
                                                <ListBox.Style>
                                                    <Style TargetType="{x:Type ListBox}" BasedOn="{StaticResource ProjectListBoxStyle}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasPlugins}" Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ListBox.Style>
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="24" />
                                                                <ColumnDefinition Width="30" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>

                                                            <!-- Separator fold toggle, tucked into the left corner -->
                                                            <Button Grid.Column="0"
                                                                    Style="{StaticResource SeparatorCollapseButtonStyle}"
                                                                    Command="{Binding DataContext.TogglePluginSeparatorCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                                    CommandParameter="{Binding}"
                                                                    HorizontalAlignment="Left"
                                                                    VerticalAlignment="Center"
                                                                    Visibility="{Binding IsSeparator, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                                            <CheckBox Grid.Column="0"
                                                                      Style="{StaticResource FluxoraCheckBoxStyle}"
                                                                      IsChecked="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                      IsEnabled="{Binding CanToggle}"
                                                                      Command="{Binding DataContext.TogglePluginEnabledCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                                      CommandParameter="{Binding}"
                                                                      HorizontalAlignment="Left"
                                                                      VerticalAlignment="Center"
                                                                      Visibility="{Binding IsPlugin, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding OrderText}"
                                                                       FontWeight="Bold"
                                                                       Foreground="{StaticResource MutedTextBrush}"
                                                                       VerticalAlignment="Center" />

                                                            <StackPanel Grid.Column="2"
                                                                        Margin="3,0,10,0">
                                                                <TextBlock Text="{Binding DisplayName}"
                                                                           TextTrimming="CharacterEllipsis">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="{x:Type TextBlock}">
                                                                            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                                                            <Setter Property="FontWeight" Value="SemiBold" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsSeparator}" Value="True">
                                                                                    <Setter Property="Foreground" Value="{StaticResource AccentHoverBrush}" />
                                                                                    <Setter Property="FontWeight" Value="Black" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                                <TextBlock Text="{Binding SourceText}"
                                                                           Margin="0,4,0,0"
                                                                           TextTrimming="CharacterEllipsis">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource MutedTextStyle}">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsSeparator}" Value="True">
                                                                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </StackPanel>

                                                            <Border Grid.Column="3"
                                                                    Background="{StaticResource PanelSoftBrush}"
                                                                    BorderBrush="{StaticResource LineBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="9"
                                                                    Padding="7,3"
                                                                    VerticalAlignment="Center">
                                                                <Border.Style>
                                                                    <Style TargetType="{x:Type Border}">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsSeparator}" Value="True">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <TextBlock Text="{Binding TypeText}"
                                                                           FontSize="10"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                                            </Border>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>

                                            <Border Padding="18">
                                                <Border.ContextMenu>
                                                    <ContextMenu Style="{StaticResource DarkContextMenuStyle}">
                                                        <MenuItem Header="Создать разделитель..."
                                                                  Style="{StaticResource DarkMenuItemStyle}"
                                                                  Command="{Binding PlacementTarget.DataContext.CreatePluginSeparatorCommand, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}">
                                                            <MenuItem.Icon>
                                                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                                                           Text="&#xE8A5;"
                                                                           FontSize="12"
                                                                           Foreground="{StaticResource AccentHoverBrush}" />
                                                            </MenuItem.Icon>
                                                        </MenuItem>
                                                    </ContextMenu>
                                                </Border.ContextMenu>
                                                <Border.Style>
                                                    <Style TargetType="{x:Type Border}" BasedOn="{StaticResource InnerPanelStyle}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasPlugins}" Value="False">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel VerticalAlignment="Center"
                                                            HorizontalAlignment="Center"
                                                            MaxWidth="280">
                                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                                                               Text="&#xE950;"
                                                               FontSize="26"
                                                               Foreground="{StaticResource AccentHoverBrush}"
                                                               HorizontalAlignment="Center"
                                                               Margin="0,0,0,10" />
                                                    <TextBlock Text="Плагины не найдены"
                                                               FontSize="16"
                                                               FontWeight="Black"
                                                               Foreground="{StaticResource TextBrush}"
                                                               TextAlignment="Center" />
                                                    <TextBlock Text="Установите мод с .esp, .esm или .esl, затем список появится здесь."
                                                               Margin="0,6,0,0"
                                                               Foreground="{StaticResource MutedTextBrush}"
                                                               TextAlignment="Center"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <Border Grid.Row="2"
                                                Style="{StaticResource InnerPanelStyle}"
                                                Padding="12"
                                                Margin="0,10,0,0">
                                            <StackPanel>
                                                <TextBlock Text="{Binding SelectedPluginTitle}"
                                                           FontWeight="Black"
                                                           Foreground="{StaticResource TextBrush}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding SelectedPluginStatusText}"
                                                           Margin="0,4,0,0"
                                                           Style="{StaticResource MutedTextStyle}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </TabItem>

                                <TabItem Header="Данные">
                                    <ScrollViewer Margin="0,16,0,0"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <StackPanel>
                                            <TextBlock Text="Выбранный мод"
                                                       Style="{StaticResource SectionLabelStyle}" />
                                            <Border Style="{StaticResource InnerPanelStyle}"
                                                    Padding="14"
                                                    Margin="0,0,0,14">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding SelectedModTitle}"
                                                               FontWeight="Black"
                                                               Foreground="{StaticResource TextBrush}"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding SelectedModVersionText}"
                                                               Margin="0,6,0,0"
                                                               Style="{StaticResource MutedTextStyle}"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding SelectedModUpdateText}"
                                                               Margin="0,4,0,0"
                                                               Style="{StaticResource MutedTextStyle}"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding SelectedModConflictText}"
                                                               Margin="0,4,0,0"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding SelectedModFileCountText}"
                                                               Margin="0,4,0,0"
                                                               Style="{StaticResource MutedTextStyle}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>

                                            <TextBlock Text="Дерево файлов"
                                                       Style="{StaticResource SectionLabelStyle}" />
                                            <Border Style="{StaticResource InnerPanelStyle}"
                                                    Padding="8"
                                                    Margin="0,0,0,14"
                                                    MinHeight="220">
                                                <Grid>
                                                    <TreeView ItemsSource="{Binding SelectedModFileTree}"
                                                              Background="Transparent"
                                                              BorderThickness="0"
                                                              Foreground="{StaticResource TextBrush}">
                                                        <TreeView.ItemContainerStyle>
                                                            <Style TargetType="{x:Type TreeViewItem}">
                                                                <EventSetter Event="Expanded" Handler="OnModFileTreeItemExpanded" />
                                                            </Style>
                                                        </TreeView.ItemContainerStyle>
                                                        <TreeView.ItemTemplate>
                                                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                                                <Grid Margin="0,2">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="20" />
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                                                                               Text="{Binding IconText}"
                                                                               FontSize="12"
                                                                               Foreground="{StaticResource MutedTextBrush}"
                                                                               VerticalAlignment="Center" />
                                                                    <StackPanel Grid.Column="1"
                                                                                Margin="4,0,10,0">
                                                                        <TextBlock Text="{Binding Name}"
                                                                                   Foreground="{StaticResource TextBrush}"
                                                                                   TextTrimming="CharacterEllipsis" />
                                                                        <TextBlock Text="{Binding ConflictText}"
                                                                                   FontSize="11"
                                                                                   Foreground="{StaticResource AccentHoverBrush}"
                                                                                   TextTrimming="CharacterEllipsis">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="{x:Type TextBlock}">
                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding HasConflict}" Value="False">
                                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                    </StackPanel>
                                                                    <TextBlock Grid.Column="2"
                                                                               Text="{Binding SizeText}"
                                                                               Foreground="{StaticResource MutedTextBrush}"
                                                                               FontSize="11"
                                                                               VerticalAlignment="Center" />
                                                                </Grid>
                                                            </HierarchicalDataTemplate>
                                                        </TreeView.ItemTemplate>
                                                    </TreeView>

                                                    <TextBlock Text="Файлы появятся после выбора мода"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource MutedTextStyle}">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasSelectedModFileTree}" Value="False">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </Border>

                                            <TextBlock Text="Папки сборки"
                                                       Style="{StaticResource SectionLabelStyle}" />
                                            <ItemsControl ItemsSource="{Binding SelectedProject.Template.Folders}"
                                                          ItemsPanel="{StaticResource WrapPanelTemplate}"
                                                          ItemTemplate="{StaticResource FolderChipTemplate}" />

                                            <TextBlock Text="Файлы профиля"
                                                       Style="{StaticResource SectionLabelStyle}"
                                                       Margin="0,12,0,8" />
                                            <TextBlock Text="{Binding SelectedProjectProfileFilesText}"
                                                       Style="{StaticResource MutedTextStyle}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </ScrollViewer>
                                </TabItem>

                                <TabItem Header="Загрузки">
                                    <Grid Margin="0,10,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Text="{Binding DownloadCountText}"
                                                   FontWeight="Black"
                                                   Foreground="{StaticResource TextBrush}" />

                                        <Grid Grid.Row="1"
                                              Margin="0,10,0,0">
                                            <DataGrid ItemsSource="{Binding Downloads}"
                                                      SelectedItem="{Binding SelectedDownload}"
                                                      IsReadOnly="True"
                                                      CanUserReorderColumns="False"
                                                      SelectionUnit="FullRow"
                                                      RowStyle="{StaticResource DownloadDataGridRowStyle}"
                                                      services:DataGridInteractionService.RowDoubleClickCommand="{Binding InstallSelectedDownloadCommand}">
                                                <DataGrid.Style>
                                                    <Style TargetType="{x:Type DataGrid}" BasedOn="{StaticResource DarkDataGridStyle}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasDownloads}" Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </DataGrid.Style>
                                                <DataGrid.Columns>
                                                    <DataGridTemplateColumn Header="Название"
                                                                            CellTemplate="{StaticResource DownloadNameCellTemplate}"
                                                                            IsReadOnly="True"
                                                                            MinWidth="150"
                                                                            Width="1.35*" />
                                                    <DataGridTemplateColumn Header="Прогресс"
                                                                            CellTemplate="{StaticResource DownloadProgressCellTemplate}"
                                                                            IsReadOnly="True"
                                                                            MinWidth="220"
                                                                            Width="1.85*" />
                                                    <DataGridTemplateColumn Header="Статус"
                                                                            CellTemplate="{StaticResource DownloadStatusCellTemplate}"
                                                                            IsReadOnly="True"
                                                                            MinWidth="118"
                                                                            Width="132" />
                                                    <DataGridTemplateColumn Header="Размер"
                                                                            CellTemplate="{StaticResource DownloadSizeCellTemplate}"
                                                                            IsReadOnly="True"
                                                                            MinWidth="104"
                                                                            Width="116" />
                                                </DataGrid.Columns>
                                            </DataGrid>

                                            <Border Padding="22">
                                                <Border.Style>
                                                    <Style TargetType="{x:Type Border}" BasedOn="{StaticResource InnerPanelStyle}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasDownloads}" Value="False">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel VerticalAlignment="Center"
                                                            HorizontalAlignment="Center"
                                                            MaxWidth="280">
                                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                                                               Text="&#xE896;"
                                                               FontSize="30"
                                                               Foreground="{StaticResource AccentHoverBrush}"
                                                               HorizontalAlignment="Center"
                                                               Margin="0,0,0,12" />
                                                    <TextBlock Text="Загрузок пока нет"
                                                               FontSize="18"
                                                               FontWeight="Black"
                                                               Foreground="{StaticResource TextBrush}"
                                                               TextAlignment="Center" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                    </Grid>
                                </TabItem>

                                <TabItem Header="Сборка" Visibility="Collapsed">
                                    <ScrollViewer Margin="0,16,0,0"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <StackPanel>
                                            <Button Style="{StaticResource SecondaryButtonStyle}"
                                                    Command="{Binding OpenGameDirectoryCommand}"
                                                    HorizontalAlignment="Stretch"
                                                    Margin="0,0,0,9">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8B7;" FontSize="12" Margin="0,0,7,0" />
                                                    <TextBlock Text="Папка игры" />
                                                </StackPanel>
                                            </Button>

                                            <Button Style="{StaticResource SecondaryButtonStyle}"
                                                    Command="{Binding OpenProjectDirectoryCommand}"
                                                    HorizontalAlignment="Stretch"
                                                    Margin="0,0,0,16">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8B7;" FontSize="12" Margin="0,0,7,0" />
                                                    <TextBlock Text="Папка сборки" />
                                                </StackPanel>
                                            </Button>

                                            <TextBlock Text="Функциональные модули"
                                                       Style="{StaticResource SectionLabelStyle}" />
                                            <ItemsControl ItemsSource="{Binding SelectedProject.Template.Capabilities}"
                                                          ItemsPanel="{StaticResource WrapPanelTemplate}"
                                                          ItemTemplate="{StaticResource CapabilityChipTemplate}" />

                                            <TextBlock Text="Расширения плагинов"
                                                       Style="{StaticResource SectionLabelStyle}"
                                                       Margin="0,12,0,8" />
                                            <TextBlock Text="{Binding SelectedProjectPluginExtensionsText}"
                                                       Style="{StaticResource MutedTextStyle}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </ScrollViewer>
                                </TabItem>
                            </TabControl>
                        </Border>
                    </Grid>

                    <Border Grid.Row="2"
                            Background="#0E0C16"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10"
                            Margin="0,12,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Статус"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontWeight="SemiBold"
                                       Margin="0,0,12,0" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding ActivityMessage}"
                                       Foreground="{StaticResource TextBrush}"
                                       TextWrapping="Wrap" />
                        </Grid>
                    </Border>
                </Grid>

                <Grid>
                    <Grid.Style>
                        <Style TargetType="{x:Type Grid}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsHomeViewOpen}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource PanelBorderStyle}"
                            Background="{StaticResource HeroBrush}"
                            Padding="26,22"
                            Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Home"
                                           FontSize="30"
                                           FontWeight="Black"
                                           Foreground="{StaticResource TextBrush}" />
                                <TextBlock Text="Создавайте игровые структуры и держите рабочие папки под рукой."
                                           Margin="0,8,0,0"
                                           FontSize="13"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           MaxWidth="560" />
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding OpenCreateProjectCommand}"
                                    Height="42"
                                    MinWidth="168"
                                    VerticalAlignment="Center"
                                    Margin="20,0,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <controls:LineIcon Data="{StaticResource Icon.Plus}" Width="16" Height="16" Margin="0,0,8,0" />
                                    <TextBlock Text="Создать сборку" FontSize="13" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <Border Padding="22">
                            <Border.Style>
                                <Style TargetType="{x:Type Border}" BasedOn="{StaticResource PanelBorderStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding HasSelectedProject}" Value="True" />
                                                <Condition Binding="{Binding IsCreateProjectPanelOpen}" Value="False" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <!-- Header: avatar + name + open -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Border Width="54"
                                            Height="54"
                                            CornerRadius="15"
                                            Background="{StaticResource AccentGradientBrush}"
                                            VerticalAlignment="Center">
                                        <controls:LineIcon Data="{StaticResource Icon.Gamepad}"
                                                           Width="27"
                                                           Height="27"
                                                           Foreground="#F7F4FF" />
                                    </Border>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding SelectedProject.Name}"
                                                   FontSize="26"
                                                   FontWeight="Black"
                                                   Foreground="{StaticResource TextBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding SelectedProject.GameName}"
                                                   Margin="0,4,0,0"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <Button Grid.Column="3"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Command="{Binding OpenProjectBuildCommand}"
                                            CommandParameter="{Binding SelectedProject}"
                                            Height="42"
                                            MinWidth="144"
                                            VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <controls:LineIcon Data="{StaticResource Icon.Open}" Width="15" Height="15" Margin="0,0,8,0" />
                                            <TextBlock Text="Открыть" FontSize="13" />
                                        </StackPanel>
                                    </Button>
                                </Grid>

                                <!-- Body: locations + quick actions fill the remaining height -->
                                <Grid Grid.Row="1" Margin="0,20,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="248" />
                                    </Grid.ColumnDefinitions>

                                    <Border Style="{StaticResource InnerPanelStyle}" Padding="18">
                                        <StackPanel>
                                            <TextBlock Text="РАСПОЛОЖЕНИЕ" Style="{StaticResource SectionLabelStyle}" />

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="12" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Width="36" Height="36" CornerRadius="10"
                                                        Background="{StaticResource AccentSoftBrush}"
                                                        BorderBrush="{StaticResource AccentLineBrush}"
                                                        BorderThickness="1"
                                                        VerticalAlignment="Top">
                                                    <controls:LineIcon Data="{StaticResource Icon.Folder}" Width="18" Height="18"
                                                                       Foreground="{StaticResource AccentHoverBrush}" />
                                                </Border>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Папка сборки" FontWeight="SemiBold" FontSize="12"
                                                               Foreground="{StaticResource TextBrush}" />
                                                    <TextBlock Text="{Binding SelectedProject.ProjectDirectory}"
                                                               Margin="0,3,0,0"
                                                               Style="{StaticResource MutedTextStyle}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Grid>

                                            <Grid Margin="0,16,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="12" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Width="36" Height="36" CornerRadius="10"
                                                        Background="{StaticResource AccentSoftBrush}"
                                                        BorderBrush="{StaticResource AccentLineBrush}"
                                                        BorderThickness="1"
                                                        VerticalAlignment="Top">
                                                    <controls:LineIcon Data="{StaticResource Icon.HardDrive}" Width="18" Height="18"
                                                                       Foreground="{StaticResource AccentHoverBrush}" />
                                                </Border>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Папка игры" FontWeight="SemiBold" FontSize="12"
                                                               Foreground="{StaticResource TextBrush}" />
                                                    <TextBlock Text="{Binding SelectedProject.GamePath}"
                                                               Margin="0,3,0,0"
                                                               Style="{StaticResource MutedTextStyle}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Grid>

                                            <Grid Margin="0,16,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="12" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Width="36" Height="36" CornerRadius="10"
                                                        Background="{StaticResource AccentSoftBrush}"
                                                        BorderBrush="{StaticResource AccentLineBrush}"
                                                        BorderThickness="1"
                                                        VerticalAlignment="Top">
                                                    <controls:LineIcon Data="{StaticResource Icon.Calendar}" Width="18" Height="18"
                                                                       Foreground="{StaticResource AccentHoverBrush}" />
                                                </Border>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Добавлена" FontWeight="SemiBold" FontSize="12"
                                                               Foreground="{StaticResource TextBrush}" />
                                                    <TextBlock Text="{Binding SelectedProjectCreatedText}"
                                                               Margin="0,3,0,0"
                                                               Style="{StaticResource MutedTextStyle}" />
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="2" Style="{StaticResource InnerPanelStyle}" Padding="18">
                                        <StackPanel>
                                            <TextBlock Text="БЫСТРЫЕ ДЕЙСТВИЯ" Style="{StaticResource SectionLabelStyle}" />

                                            <Button Style="{StaticResource SecondaryButtonStyle}"
                                                    Command="{Binding OpenHomeProjectDirectoryCommand}"
                                                    Height="40"
                                                    HorizontalContentAlignment="Left"
                                                    HorizontalAlignment="Stretch">
                                                <StackPanel Orientation="Horizontal">
                                                    <controls:LineIcon Data="{StaticResource Icon.Folder}" Width="16" Height="16" Margin="0,0,10,0" />
                                                    <TextBlock Text="Папка сборки" />
                                                </StackPanel>
                                            </Button>

                                            <Button Style="{StaticResource SecondaryButtonStyle}"
                                                    Command="{Binding OpenHomeGameDirectoryCommand}"
                                                    Height="40"
                                                    Margin="0,8,0,0"
                                                    HorizontalContentAlignment="Left"
                                                    HorizontalAlignment="Stretch">
                                                <StackPanel Orientation="Horizontal">
                                                    <controls:LineIcon Data="{StaticResource Icon.HardDrive}" Width="16" Height="16" Margin="0,0,10,0" />
                                                    <TextBlock Text="Папка игры" />
                                                </StackPanel>
                                            </Button>

                                            <Button Style="{StaticResource SecondaryButtonStyle}"
                                                    Command="{Binding OpenCreateProjectCommand}"
                                                    Height="40"
                                                    Margin="0,8,0,0"
                                                    HorizontalContentAlignment="Left"
                                                    HorizontalAlignment="Stretch">
                                                <StackPanel Orientation="Horizontal">
                                                    <controls:LineIcon Data="{StaticResource Icon.Plus}" Width="16" Height="16" Margin="0,0,10,0" />
                                                    <TextBlock Text="Новая сборка" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- No build selected on Home -->
                        <Border Padding="40"
                                VerticalAlignment="Stretch">
                            <Border.Style>
                                <Style TargetType="{x:Type Border}" BasedOn="{StaticResource PanelBorderStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding HasSelectedProject}" Value="False" />
                                                <Condition Binding="{Binding IsCreateProjectPanelOpen}" Value="False" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="380">
                                <controls:LineIcon Data="{StaticResource Icon.Layers}"
                                                   Width="40" Height="40"
                                                   Foreground="{StaticResource AccentHoverBrush}"
                                                   HorizontalAlignment="Center" />
                                <TextBlock Text="Выберите сборку"
                                           Margin="0,16,0,0"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}"
                                           TextAlignment="Center" />
                                <TextBlock Text="Откройте сборку из библиотеки слева или создайте новую, чтобы увидеть её детали."
                                           Margin="0,8,0,0"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap" />
                                <Button Style="{StaticResource PrimaryButtonStyle}"
                                        Command="{Binding OpenCreateProjectCommand}"
                                        Height="42"
                                        MinWidth="168"
                                        Margin="0,20,0,0"
                                        HorizontalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <controls:LineIcon Data="{StaticResource Icon.Plus}" Width="16" Height="16" Margin="0,0,8,0" />
                                        <TextBlock Text="Создать сборку" FontSize="13" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource PanelBorderStyle}"
                                Padding="22"
                                Visibility="{Binding IsCreateProjectPanelOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="{Binding CreateProjectStepTitle}"
                                                   FontSize="30"
                                                   FontWeight="Black"
                                                   Foreground="{StaticResource TextBrush}" />
                                        <TextBlock Text="{Binding CreateProjectStepSubtitle}"
                                                   Margin="0,7,0,0"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <Border Grid.Column="1"
                                            Style="{StaticResource PillBorderStyle}"
                                            VerticalAlignment="Top">
                                        <TextBlock Text="{Binding CreateProjectStepCounter}"
                                                   Foreground="{StaticResource TextBrush}"
                                                   FontWeight="SemiBold" />
                                    </Border>
                                </Grid>

                                <Grid Grid.Row="1" Margin="0,22,0,24">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border>
                                        <Border.Style>
                                            <Style TargetType="{x:Type Border}" BasedOn="{StaticResource StepMarkerStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CreateProjectStepIndex}" Value="0">
                                                        <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                                        <Setter Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="Название"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextBrush}"
                                                   TextAlignment="Center" />
                                    </Border>

                                    <Border Grid.Column="1">
                                        <Border.Style>
                                            <Style TargetType="{x:Type Border}" BasedOn="{StaticResource StepMarkerStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CreateProjectStepIndex}" Value="1">
                                                        <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                                        <Setter Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="Игра"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextBrush}"
                                                   TextAlignment="Center" />
                                    </Border>

                                    <Border Grid.Column="2">
                                        <Border.Style>
                                            <Style TargetType="{x:Type Border}" BasedOn="{StaticResource StepMarkerStyle}">
                                                <Setter Property="Margin" Value="0" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CreateProjectStepIndex}" Value="2">
                                                        <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                                        <Setter Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="Папка"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextBrush}"
                                                   TextAlignment="Center" />
                                    </Border>
                                </Grid>

                                <Grid Grid.Row="2">
                                    <Grid>
                                        <Grid.Style>
                                            <Style TargetType="{x:Type Grid}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsNameStep}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <StackPanel>
                                            <TextBlock Text="Название сборки"
                                                       Style="{StaticResource FieldLabelStyle}" />
                                            <TextBox Text="{Binding ProjectName, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource TextBoxStyle}" />
                                            <Border Style="{StaticResource InnerPanelStyle}"
                                                    Padding="16"
                                                    Margin="0,18,0,0">
                                                <StackPanel>
                                                    <TextBlock Text="Папка будет названа так же"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextBrush}" />
                                                    <TextBlock Text="{Binding TargetProjectDirectory}"
                                                               Margin="0,8,0,0"
                                                               Style="{StaticResource MutedTextStyle}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Grid>

                                    <Grid>
                                        <Grid.Style>
                                            <Style TargetType="{x:Type Grid}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsGameStep}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Disabled"
                                                      Padding="0,0,4,0">
                                            <StackPanel>
                                                <TextBlock Text="Игра"
                                                           Style="{StaticResource FieldLabelStyle}" />
                                                <ComboBox ItemsSource="{Binding AvailableTemplates}"
                                                          SelectedItem="{Binding SelectedTemplate}"
                                                          DisplayMemberPath="DisplayName"
                                                          Style="{StaticResource ComboBoxStyle}" />

                                                <TextBlock Text="Список игр приходит из C++ core. Шаблон игры наложится на базовый шаблон сборки."
                                                           Margin="0,9,0,0"
                                                           Style="{StaticResource MutedTextStyle}"
                                                           TextWrapping="Wrap" />

                                                <Border Background="#2A1F12"
                                                        BorderBrush="#7C4A16"
                                                        BorderThickness="1"
                                                        CornerRadius="14"
                                                        Padding="14"
                                                        Margin="0,14,0,0">
                                                    <Border.Style>
                                                        <Style TargetType="{x:Type Border}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasTemplates}" Value="False">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="C++ core не подключён: шаблоны игр недоступны. Соберите backend и положите FluxoraCore.dll рядом с приложением."
                                                               Foreground="#FBBF24"
                                                               FontSize="12"
                                                               TextWrapping="Wrap" />
                                                </Border>

                                                <TextBlock Text="EXE игры"
                                                           Style="{StaticResource FieldLabelStyle}"
                                                           Margin="0,20,0,8" />
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="10" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox Text="{Binding GamePath, UpdateSourceTrigger=PropertyChanged}"
                                                             Style="{StaticResource TextBoxStyle}" />
                                                    <Button Grid.Column="2"
                                                            Style="{StaticResource SecondaryButtonStyle}"
                                                            Command="{Binding BrowseGamePathCommand}"
                                                            MinWidth="118">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8B7;" FontSize="13" Margin="0,0,8,0" />
                                                            <TextBlock Text="Выбрать" />
                                                        </StackPanel>
                                                    </Button>
                                                </Grid>

                                                <Border Style="{StaticResource InnerPanelStyle}"
                                                        Padding="18"
                                                        Margin="0,20,0,0"
                                                        Visibility="{Binding HasResolvedTemplate, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                                                       Text="&#xE790;"
                                                                       FontSize="15"
                                                                       Foreground="#C4B5FD"
                                                                       VerticalAlignment="Center"
                                                                       Margin="0,0,9,0" />
                                                            <TextBlock VerticalAlignment="Center">
                                                                <Run Text="Базовый шаблон + " Foreground="{StaticResource MutedTextBrush}" />
                                                                <Run Text="{Binding SelectedResolvedTemplate.DisplayName, Mode=OneWay}"
                                                                     FontWeight="SemiBold"
                                                                     Foreground="{StaticResource TextBrush}" />
                                                            </TextBlock>
                                                        </StackPanel>

                                                        <TextBlock Text="{Binding SelectedResolvedTemplate.Summary}"
                                                                   Margin="0,9,0,0"
                                                                   Style="{StaticResource MutedTextStyle}"
                                                                   TextWrapping="Wrap" />

                                                        <TextBlock Text="Функциональные модули"
                                                                   Style="{StaticResource SectionLabelStyle}"
                                                                   Margin="0,18,0,8" />
                                                        <ItemsControl ItemsSource="{Binding SelectedResolvedTemplate.Capabilities}"
                                                                      ItemsPanel="{StaticResource WrapPanelTemplate}"
                                                                      ItemTemplate="{StaticResource CapabilityChipTemplate}" />

                                                        <StackPanel Visibility="{Binding SelectedResolvedTemplate.HasBasePlugins, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                            <TextBlock Text="Мастер-файлы игры"
                                                                       Style="{StaticResource SectionLabelStyle}"
                                                                       Margin="0,10,0,8" />
                                                            <ItemsControl ItemsSource="{Binding SelectedResolvedTemplate.BasePlugins}"
                                                                          ItemsPanel="{StaticResource WrapPanelTemplate}"
                                                                          ItemTemplate="{StaticResource PluginChipTemplate}" />
                                                            <TextBlock Margin="0,3,0,0"
                                                                       Style="{StaticResource MutedTextStyle}">
                                                                <Run Text="Расширения плагинов: " />
                                                                <Run Text="{Binding SelectedResolvedTemplate.PluginExtensionsText, Mode=OneWay}"
                                                                     Foreground="{StaticResource TextSecondaryBrush}" />
                                                            </TextBlock>
                                                        </StackPanel>

                                                        <Border Style="{StaticResource InnerPanelStyle}"
                                                                Padding="14"
                                                                Margin="0,16,0,0"
                                                                Visibility="{Binding SelectedResolvedTemplate.HasScriptExtender, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                                                           Text="&#xE756;"
                                                                           FontSize="15"
                                                                           Foreground="#C4B5FD"
                                                                           VerticalAlignment="Center"
                                                                           Margin="0,0,10,0" />
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding SelectedResolvedTemplate.ScriptExtender.Name}"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="{StaticResource TextBrush}" />
                                                                    <TextBlock Text="{Binding SelectedResolvedTemplate.ScriptExtender.LoaderExecutable}"
                                                                               Style="{StaticResource MutedTextStyle}"
                                                                               Margin="0,4,0,0" />
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </Border>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Grid>

                                    <Grid>
                                        <Grid.Style>
                                            <Style TargetType="{x:Type Grid}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsInstallStep}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <StackPanel>
                                            <TextBlock Text="Куда установить сборку"
                                                       Style="{StaticResource FieldLabelStyle}" />
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="10" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBox Text="{Binding InstallRootDirectory, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource TextBoxStyle}" />
                                                <Button Grid.Column="2"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        Command="{Binding BrowseInstallRootCommand}"
                                                        MinWidth="118">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8B7;" FontSize="13" Margin="0,0,8,0" />
                                                        <TextBlock Text="Выбрать" />
                                                    </StackPanel>
                                                </Button>
                                            </Grid>

                                            <Border Style="{StaticResource InnerPanelStyle}"
                                                    Padding="16"
                                                    Margin="0,20,0,0">
                                                <StackPanel>
                                                    <TextBlock Text="Итоговый путь"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextBrush}" />
                                                    <TextBlock Text="{Binding TargetProjectDirectory}"
                                                               Margin="0,8,0,0"
                                                               Style="{StaticResource MutedTextStyle}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>

                                            <Border Style="{StaticResource InnerPanelStyle}"
                                                    Background="{StaticResource AccentSoftBrush}"
                                                    BorderBrush="{StaticResource AccentLineBrush}"
                                                    Padding="16"
                                                    Margin="0,14,0,0"
                                                    Visibility="{Binding HasResolvedTemplate, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                                                               Text="&#xE790;"
                                                               FontSize="15"
                                                               Foreground="#C4B5FD"
                                                               VerticalAlignment="Center"
                                                               Margin="0,0,10,0" />
                                                    <TextBlock VerticalAlignment="Center" TextWrapping="Wrap">
                                                        <Run Text="Будет развёрнут шаблон: " Foreground="{StaticResource MutedTextBrush}" />
                                                        <Run Text="базовый + " Foreground="{StaticResource TextBrush}" />
                                                        <Run Text="{Binding SelectedResolvedTemplate.DisplayName, Mode=OneWay}"
                                                             FontWeight="SemiBold"
                                                             Foreground="{StaticResource TextBrush}" />
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Grid>

                                <Grid Grid.Row="3" Margin="0,22,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="{Binding ValidationMessage}"
                                               Foreground="{StaticResource ErrorBrush}"
                                               FontSize="12"
                                               TextWrapping="Wrap" />

                                    <ProgressBar Grid.Row="1"
                                                 Height="3"
                                                 IsIndeterminate="True"
                                                 Foreground="{StaticResource AccentHoverBrush}"
                                                 Background="#0E0C16"
                                                 BorderThickness="0"
                                                 Margin="0,10,0,0"
                                                 Visibility="{Binding IsCreatingProject, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                    <Grid Grid.Row="1" Margin="0,18,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding CancelCreateProjectCommand}"
                                                Content="Отмена"
                                                MinWidth="94" />

                                        <Button Grid.Column="2"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding PreviousCreateStepCommand}"
                                                MinWidth="94">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE72B;" FontSize="12" Margin="0,0,7,0" />
                                                <TextBlock Text="Назад" />
                                            </StackPanel>
                                        </Button>

                                        <Button Grid.Column="4"
                                                Command="{Binding NextCreateStepCommand}"
                                                MinWidth="112">
                                            <Button.Style>
                                                <Style TargetType="{x:Type Button}" BasedOn="{StaticResource PrimaryButtonStyle}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsInstallStep}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Далее" />
                                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE72A;" FontSize="12" Margin="7,0,0,0" />
                                            </StackPanel>
                                        </Button>

                                        <Button Grid.Column="4"
                                                Command="{Binding CreateProjectCommand}"
                                                MinWidth="142">
                                            <Button.Style>
                                                <Style TargetType="{x:Type Button}" BasedOn="{StaticResource PrimaryButtonStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsInstallStep}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE710;" FontSize="13" Margin="0,0,8,0" />
                                                <TextBlock Text="Создать" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Padding="28">
                            <Border.Style>
                                <Style TargetType="{x:Type Border}" BasedOn="{StaticResource PanelBorderStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding HasSelectedProject}" Value="False" />
                                                <Condition Binding="{Binding IsCreateProjectPanelOpen}" Value="False" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        MaxWidth="410">
                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                           Text="&#xE7C3;"
                                           FontSize="38"
                                           Foreground="{StaticResource AccentHoverBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,16" />
                                <TextBlock Text="Откройте или создайте сборку"
                                           FontSize="24"
                                           FontWeight="Black"
                                           Foreground="{StaticResource TextBrush}"
                                           TextAlignment="Center" />
                                <TextBlock Text="Выберите JSON-конфиг, чтобы загрузить отдельную конфигурацию сборки."
                                           Margin="0,10,0,0"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap" />
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            Margin="0,22,0,0">
                                    <Button Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding OpenProjectCommand}"
                                            MinWidth="132"
                                            Margin="0,0,10,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8E5;" FontSize="13" Margin="0,0,8,0" />
                                            <TextBlock Text="Открыть" />
                                        </StackPanel>
                                    </Button>

                                    <Button Style="{StaticResource PrimaryButtonStyle}"
                                            Command="{Binding OpenCreateProjectCommand}"
                                            MinWidth="154">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE710;" FontSize="13" Margin="0,0,8,0" />
                                            <TextBlock Text="Создать" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource PanelBorderStyle}"
                                Padding="22"
                                Visibility="{Binding IsTransferPanelOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid DataContext="{Binding TransferViewModel}">
                                <Grid>
                                    <Grid.Style>
                                        <Style TargetType="{x:Type Grid}">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTransferProcessVisible}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock Text="{Binding TransferStepTitle}"
                                                       FontSize="31"
                                                       FontWeight="Black"
                                                       Foreground="{StaticResource TextBrush}" />
                                            <TextBlock Text="{Binding TransferStepSubtitle}"
                                                       Margin="0,7,0,0"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>

                                        <Border Grid.Column="1"
                                                Style="{StaticResource PillBorderStyle}"
                                                VerticalAlignment="Top">
                                            <TextBlock Text="{Binding TransferStepCounter}"
                                                       Foreground="{StaticResource TextBrush}"
                                                       FontWeight="SemiBold" />
                                        </Border>
                                    </Grid>

                                    <Grid Grid.Row="1"
                                          Margin="0,22,0,22">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border>
                                            <Border.Style>
                                                <Style TargetType="{x:Type Border}" BasedOn="{StaticResource StepMarkerStyle}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding TransferStepIndex}" Value="0">
                                                            <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                                            <Setter Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="Источник"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextBrush}"
                                                       TextAlignment="Center" />
                                        </Border>

                                        <Border Grid.Column="1">
                                            <Border.Style>
                                                <Style TargetType="{x:Type Border}" BasedOn="{StaticResource StepMarkerStyle}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding TransferStepIndex}" Value="1">
                                                            <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                                            <Setter Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="Назначение"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextBrush}"
                                                       TextAlignment="Center" />
                                        </Border>

                                        <Border Grid.Column="2">
                                            <Border.Style>
                                                <Style TargetType="{x:Type Border}" BasedOn="{StaticResource StepMarkerStyle}">
                                                    <Setter Property="Margin" Value="0" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding TransferStepIndex}" Value="2">
                                                            <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                                            <Setter Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="Проверка"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextBrush}"
                                                       TextAlignment="Center" />
                                        </Border>
                                    </Grid>

                                    <Grid Grid.Row="2">
                                        <Grid Visibility="{Binding IsTransferSourceStep, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <StackPanel>
                                                <TextBlock Text="Папка Mod Organizer 2"
                                                           Style="{StaticResource FieldLabelStyle}" />
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="10" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox Style="{StaticResource TextBoxStyle}"
                                                             Text="{Binding SourceDirectory, UpdateSourceTrigger=PropertyChanged}" />
                                                    <Button Grid.Column="2"
                                                            Style="{StaticResource SecondaryButtonStyle}"
                                                            Command="{Binding BrowseSourceCommand}"
                                                            MinWidth="104">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                                                       Text="&#xE8B7;"
                                                                       FontSize="13"
                                                                       Margin="0,0,8,0" />
                                                            <TextBlock Text="Выбрать" />
                                                        </StackPanel>
                                                    </Button>
                                                </Grid>

                                                <Border Style="{StaticResource InnerPanelStyle}"
                                                        Padding="16"
                                                        Margin="0,18,0,0">
                                                    <StackPanel>
                                                        <TextBlock Text="Что будет перенесено"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TextBrush}" />
                                                        <TextBlock Text="C++ core проверит структуру MO2, прочитает профиль, порядок модов и подготовит перенос без удаления исходной папки."
                                                                   Margin="0,8,0,0"
                                                                   Foreground="{StaticResource MutedTextBrush}"
                                                                   TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </Grid>

                                        <Grid Visibility="{Binding IsTransferDestinationStep, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding DestinationLabel}"
                                                           Style="{StaticResource FieldLabelStyle}" />
                                                <ComboBox Style="{StaticResource ComboBoxStyle}"
                                                          ItemsSource="{Binding AvailableDrives}"
                                                          SelectedItem="{Binding SelectedDrive}"
                                                          DisplayMemberPath="DisplayName"
                                                          IsEnabled="{Binding CanChangeDestination}">
                                                    <ComboBox.ItemContainerStyle>
                                                        <Style TargetType="{x:Type ComboBoxItem}">
                                                            <Setter Property="IsEnabled" Value="{Binding IsSelectable}" />
                                                            <Style.Triggers>
                                                                <Trigger Property="IsEnabled" Value="False">
                                                                    <Setter Property="Opacity" Value="0.45" />
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ComboBox.ItemContainerStyle>
                                                </ComboBox>
                                                <Grid Margin="0,12,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="10" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox Style="{StaticResource TextBoxStyle}"
                                                             Text="{Binding DestinationRootDirectory, UpdateSourceTrigger=PropertyChanged}"
                                                             IsEnabled="{Binding CanChangeDestination}" />
                                                    <Button Grid.Column="2"
                                                            Style="{StaticResource SecondaryButtonStyle}"
                                                            Command="{Binding BrowseDestinationCommand}"
                                                            IsEnabled="{Binding CanChangeDestination}"
                                                            MinWidth="104">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                                                       Text="&#xE8B7;"
                                                                       FontSize="13"
                                                                       Margin="0,0,8,0" />
                                                            <TextBlock Text="Папка" />
                                                        </StackPanel>
                                                    </Button>
                                                </Grid>

                                                <Border Style="{StaticResource InnerPanelStyle}"
                                                        Padding="16"
                                                        Margin="0,18,0,0">
                                                    <StackPanel>
                                                        <TextBlock Text="Итоговый путь"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TextBrush}" />
                                                        <TextBlock Text="{Binding TransferTargetText}"
                                                                   Margin="0,8,0,0"
                                                                   Foreground="{StaticResource MutedTextBrush}"
                                                                   TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding TransferAvailableText}"
                                                                   Margin="0,8,0,0"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </Grid>

                                        <ScrollViewer Visibility="{Binding IsTransferReviewStep, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                      VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Disabled"
                                                      Padding="0,0,4,0">
                                            <StackPanel>
                                                <Border Style="{StaticResource InnerPanelStyle}"
                                                        Padding="18">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>

                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding TransferProjectName}"
                                                                           FontSize="22"
                                                                           FontWeight="Black"
                                                                           Foreground="{StaticResource TextBrush}"
                                                                           TextWrapping="Wrap" />
                                                                <TextBlock Text="{Binding TransferMessage}"
                                                                           Margin="0,6,0,0"
                                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                                           TextWrapping="Wrap" />
                                                            </StackPanel>
                                                        </Grid>

                                                        <ProgressBar Grid.Row="1"
                                                                     Height="3"
                                                                     IsIndeterminate="True"
                                                                     Foreground="{StaticResource AccentHoverBrush}"
                                                                     Background="#0E0C16"
                                                                     BorderThickness="0"
                                                                     Margin="0,14,0,0"
                                                                     Visibility="{Binding IsAnalyzingTransfer, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                                        <Grid Grid.Row="2"
                                                              Margin="0,18,0,0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="12" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="12" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <Border Background="#151220"
                                                                    BorderBrush="{StaticResource LineBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="10"
                                                                    Padding="14">
                                                                <StackPanel>
                                                                    <TextBlock Text="Моды"
                                                                               Foreground="{StaticResource MutedTextBrush}"
                                                                               FontSize="12" />
                                                                    <TextBlock Text="{Binding TransferModCountText}"
                                                                               Margin="0,5,0,0"
                                                                               Foreground="{StaticResource TextBrush}"
                                                                               FontWeight="Black"
                                                                               TextWrapping="Wrap" />
                                                                </StackPanel>
                                                            </Border>
                                                            <Border Grid.Column="2"
                                                                    Background="#151220"
                                                                    BorderBrush="{StaticResource LineBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="10"
                                                                    Padding="14">
                                                                <StackPanel>
                                                                    <TextBlock Text="Вес"
                                                                               Foreground="{StaticResource MutedTextBrush}"
                                                                               FontSize="12" />
                                                                    <TextBlock Text="{Binding TransferSizeText}"
                                                                               Margin="0,5,0,0"
                                                                               Foreground="{StaticResource TextBrush}"
                                                                               FontWeight="Black" />
                                                                    <TextBlock Text="{Binding TransferAvailableText}"
                                                                               Margin="0,3,0,0"
                                                                               Foreground="{StaticResource SubtleTextBrush}"
                                                                               FontSize="11"
                                                                               TextWrapping="Wrap" />
                                                                </StackPanel>
                                                            </Border>
                                                            <Border Grid.Column="4"
                                                                    Background="#151220"
                                                                    BorderBrush="{StaticResource LineBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="10"
                                                                    Padding="14">
                                                                <StackPanel>
                                                                    <TextBlock Text="Профиль"
                                                                               Foreground="{StaticResource MutedTextBrush}"
                                                                               FontSize="12" />
                                                                    <TextBlock Text="{Binding TransferProfileText}"
                                                                               Margin="0,5,0,0"
                                                                               Foreground="{StaticResource TextBrush}"
                                                                               FontWeight="Black"
                                                                               TextWrapping="Wrap" />
                                                                    <TextBlock Text="{Binding TransferGameText}"
                                                                               Margin="0,3,0,0"
                                                                               Foreground="{StaticResource SubtleTextBrush}"
                                                                               FontSize="11"
                                                                               TextWrapping="Wrap" />
                                                                </StackPanel>
                                                            </Border>
                                                        </Grid>
                                                    </Grid>
                                                </Border>

                                                <Border Background="#241A12"
                                                        BorderBrush="#6D4D1F"
                                                        BorderThickness="1"
                                                        CornerRadius="10"
                                                        Padding="12"
                                                        Margin="0,14,0,0"
                                                        Visibility="{Binding HasTransferWarning, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="{Binding TransferWarningText}"
                                                               Foreground="#FDE68A"
                                                               TextWrapping="Wrap" />
                                                </Border>

                                                <Border Padding="12"
                                                        Margin="0,14,0,0"
                                                        Visibility="{Binding HasTransferAnalysis, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <Border.Style>
                                                        <Style TargetType="{x:Type Border}">
                                                            <Setter Property="Background" Value="#2A1220" />
                                                            <Setter Property="BorderBrush" Value="#7F1D3A" />
                                                            <Setter Property="BorderThickness" Value="1" />
                                                            <Setter Property="CornerRadius" Value="10" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasEnoughSpace}" Value="True">
                                                                    <Setter Property="Background" Value="#10251D" />
                                                                    <Setter Property="BorderBrush" Value="#2F9E68" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding TransferDiskSpaceText}"
                                                               Foreground="{StaticResource TextBrush}"
                                                               FontWeight="SemiBold"
                                                               TextWrapping="Wrap" />
                                                </Border>

                                                <TextBlock Text="{Binding TransferTargetText}"
                                                           Margin="0,12,0,0"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           FontSize="11"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Grid>

                                    <Grid Grid.Row="3"
                                          Margin="0,18,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Border Background="#2A1220"
                                                BorderBrush="#7F1D3A"
                                                BorderThickness="1"
                                                CornerRadius="10"
                                                Padding="12"
                                                Margin="0,0,0,12"
                                                Visibility="{Binding HasTransferError, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="{Binding TransferError}"
                                                       Foreground="{StaticResource ErrorBrush}"
                                                       TextWrapping="Wrap" />
                                        </Border>

                                        <Grid Grid.Row="1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="10" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <Button Style="{StaticResource SecondaryButtonStyle}"
                                                    Command="{Binding CancelTransferFlowCommand}"
                                                    Content="Отменить перенос"
                                                    MinWidth="142" />

                                            <Button Grid.Column="2"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Command="{Binding PreviousTransferStepCommand}"
                                                    MinWidth="94">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                                                               Text="&#xE72B;"
                                                               FontSize="12"
                                                               Margin="0,0,7,0" />
                                                    <TextBlock Text="Назад" />
                                                </StackPanel>
                                            </Button>

                                            <Button Grid.Column="4"
                                                    Command="{Binding NextTransferStepCommand}"
                                                    MinWidth="126">
                                                <Button.Style>
                                                    <Style TargetType="{x:Type Button}" BasedOn="{StaticResource PrimaryButtonStyle}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsTransferReviewStep}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding NextTransferStepText}" />
                                                    <TextBlock FontFamily="Segoe MDL2 Assets"
                                                               Text="&#xE72A;"
                                                               FontSize="12"
                                                               Margin="7,0,0,0" />
                                                </StackPanel>
                                            </Button>

                                            <Button Grid.Column="4"
                                                    Command="{Binding StartTransferCommand}"
                                                    MinWidth="164">
                                                <Button.Style>
                                                    <Style TargetType="{x:Type Button}" BasedOn="{StaticResource PrimaryButtonStyle}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsTransferReviewStep}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <TextBlock Text="{Binding StartTransferText}" />
                                            </Button>
                                        </Grid>
                                    </Grid>
                                </Grid>

                                <Grid Margin="20"
                                      Visibility="{Binding IsTransferProcessVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="22" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Width="76"
                                                Height="76"
                                                CornerRadius="22"
                                                Background="{StaticResource AccentGradientBrush}">
                                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                                       Text="&#xE895;"
                                                       FontSize="31"
                                                       Foreground="#F7F4FF"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>

                                        <StackPanel Grid.Column="2"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding TransferProcessTitle}"
                                                       FontSize="34"
                                                       FontWeight="Black"
                                                       Foreground="{StaticResource TextBrush}" />
                                            <TextBlock Text="{Binding TransferProcessSubtitle}"
                                                       Margin="0,8,0,0"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>

                                    <Border Grid.Row="1"
                                            Background="#12101C"
                                            BorderBrush="{StaticResource LineBrush}"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Padding="18"
                                            Margin="0,30,0,22">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding TransferCurrentStep}"
                                                           FontSize="20"
                                                           FontWeight="Black"
                                                           Foreground="{StaticResource TextBrush}"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding TransferCurrentItem}"
                                                           Margin="0,6,0,0"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding TransferOverallPercent, StringFormat={}{0}%}"
                                                       Foreground="{StaticResource TextBrush}"
                                                       FontSize="26"
                                                       FontWeight="Black"
                                                       Margin="18,0,0,0"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Row="2"
                                                VerticalAlignment="Top">
                                        <TextBlock Text="Общий прогресс"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontWeight="SemiBold" />
                                        <ProgressBar Style="{StaticResource DownloadProgressBarStyle}"
                                                     Value="{Binding TransferOverallPercent, Mode=OneWay}"
                                                     Maximum="100"
                                                     Margin="0,9,0,20" />

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="18" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="Копирование файлов"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           FontWeight="SemiBold" />
                                                <ProgressBar Style="{StaticResource DownloadProgressBarStyle}"
                                                             Value="{Binding TransferCopyPercent, Mode=OneWay}"
                                                             Maximum="100"
                                                             Margin="0,9,0,8" />
                                                <TextBlock Text="{Binding TransferBytesText}"
                                                           Foreground="{StaticResource SubtleTextBrush}"
                                                           FontSize="11"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="База данных"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           FontWeight="SemiBold" />
                                                <ProgressBar Style="{StaticResource DownloadProgressBarStyle}"
                                                             Value="{Binding TransferDatabasePercent, Mode=OneWay}"
                                                             Maximum="100"
                                                             Margin="0,9,0,8" />
                                                <TextBlock Text="meta.ini переносится в instance.db"
                                                           Foreground="{StaticResource SubtleTextBrush}"
                                                           FontSize="11"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Grid>

                                        <Border Background="#2A1220"
                                                BorderBrush="#7F1D3A"
                                                BorderThickness="1"
                                                CornerRadius="10"
                                                Padding="12"
                                                Margin="0,22,0,0"
                                                Visibility="{Binding HasTransferError, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="{Binding TransferError}"
                                                       Foreground="{StaticResource ErrorBrush}"
                                                       TextWrapping="Wrap" />
                                        </Border>
                                    </StackPanel>

                                    <Grid Grid.Row="3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding TransferMessage}"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center" />
                                        <Button Grid.Column="1"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Content="Закрыть"
                                                Command="{Binding DataContext.CloseTransferPanelCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                MinWidth="112"
                                                Margin="18,0,0,0" />
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>

        <views:ModOrganizerTransferView Grid.Row="1"
                                        Margin="20,16,20,20"
                                        DataContext="{Binding TransferViewModel}"
                                        CloseCommand="{Binding DataContext.CloseTransferPanelCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                        Visibility="{Binding DataContext.IsTransferPanelOpen, RelativeSource={RelativeSource AncestorType={x:Type Window}}, Converter={StaticResource BooleanToVisibilityConverter}}" />

        <views:TransferProcessSplash Grid.Row="1"
                                     Panel.ZIndex="110"
                                     DataContext="{Binding TransferViewModel}"
                                     CloseCommand="{Binding DataContext.CloseTransferPanelCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" />

        <views:BuildDeletionProcessSplash Grid.Row="1"
                                          Panel.ZIndex="115"
                                          DataContext="{Binding BuildDeletionProcess}"
                                          CloseCommand="{Binding DataContext.CloseBuildDeletionProcessCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" />

        <views:BuildLoadingSplash Grid.Row="1"
                                  Panel.ZIndex="120" />
    </Grid>
</Window>
