<Window x:Class="Fluxora.App.Views.ConfirmDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:controls="clr-namespace:Fluxora.App.Controls"
        Title="Подтверждение"
        Width="500"
        SizeToContent="Height"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        Background="#171523"
        FontFamily="{StaticResource FluxoraFontBody}"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        RenderOptions.ClearTypeHint="Enabled"
        FontSize="13"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="16"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="1"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <SolidColorBrush x:Key="TextBrush" Color="#F7F4FF" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#C5BEDA" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#918AA8" />
        <SolidColorBrush x:Key="PanelBrush" Color="#171523" />
        <SolidColorBrush x:Key="PanelRaisedBrush" Color="#201D31" />
        <SolidColorBrush x:Key="PanelSoftBrush" Color="#11101B" />
        <SolidColorBrush x:Key="PanelHoverBrush" Color="#27223A" />
        <SolidColorBrush x:Key="LineBrush" Color="#302B46" />
        <SolidColorBrush x:Key="LineHoverBrush" Color="#55467D" />
        <SolidColorBrush x:Key="DangerBrush" Color="#E11D48" />
        <SolidColorBrush x:Key="DangerHoverBrush" Color="#F43F5E" />
        <SolidColorBrush x:Key="DangerSoftBrush" Color="#2A1622" />
        <SolidColorBrush x:Key="DangerIconBrush" Color="#FB7185" />

        <Style x:Key="CloseButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <controls:LineIcon Width="15"
                                               Height="15"
                                               Data="{StaticResource Icon.WindowClose}"
                                               Foreground="{TemplateBinding Foreground}"
                                               StrokeThickness="2" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource PanelHoverBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.72" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DialogButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="40" />
            <Setter Property="MinWidth" Value="112" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Root"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                         To="1.02"
                                                         Duration="0:0:0.14" />
                                        <DoubleAnimation Storyboard.TargetName="Root"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                         To="1.02"
                                                         Duration="0:0:0.14" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Root"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                         To="1"
                                                         Duration="0:0:0.16" />
                                        <DoubleAnimation Storyboard.TargetName="Root"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                         To="1"
                                                         Duration="0:0:0.16" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource DangerHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerDialogButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource DialogButtonStyle}">
            <Setter Property="Background" Value="{StaticResource DangerBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource DangerHoverBrush}" />
            <Setter Property="Foreground" Value="#FFF1F4" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource DangerHoverBrush}" />
                    <Setter Property="BorderBrush" Value="#FB7185" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryDialogButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource DialogButtonStyle}">
            <Setter Property="Background" Value="{StaticResource PanelRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PanelHoverBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource LineHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <!-- Drag anywhere on the card; interactive controls mark the event handled first. -->
    <Border Margin="0"
            Background="{StaticResource PanelBrush}"
            BorderBrush="{StaticResource LineBrush}"
            BorderThickness="1"
            CornerRadius="16"
            MouseLeftButtonDown="OnDragMove">
        <Grid Margin="26,18,26,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Top row: nothing but the custom close cross. -->
            <Button Grid.Row="0"
                    HorizontalAlignment="Right"
                    Margin="0,-4,-6,0"
                    Style="{StaticResource CloseButtonStyle}"
                    AutomationProperties.Name="Закрыть"
                    IsCancel="True"
                    Click="OnCancelClick" />

            <!-- Danger badge + heading -->
            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        Margin="0,2,0,0">
                <Border Width="48"
                        Height="48"
                        CornerRadius="14"
                        Background="{StaticResource DangerSoftBrush}"
                        BorderBrush="#5A2336"
                        BorderThickness="1"
                        Margin="0,0,16,0"
                        VerticalAlignment="Top">
                    <controls:LineIcon Width="24"
                                       Height="24"
                                       Data="{StaticResource Icon.AlertTriangle}"
                                       Foreground="{StaticResource DangerIconBrush}"
                                       StrokeThickness="1.9" />
                </Border>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="HeadingTextBlock"
                               FontSize="21"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}" />
                    <TextBlock x:Name="MessageTextBlock"
                               Width="318"
                               Margin="0,6,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               LineHeight="19"
                               TextWrapping="Wrap" />
                </StackPanel>
            </StackPanel>

            <!-- Detail card: the paths that will be removed -->
            <Border Grid.Row="2"
                    Margin="0,20,0,0"
                    Background="{StaticResource PanelSoftBrush}"
                    BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="16,4">
                <ItemsControl x:Name="DetailsItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Width="34"
                                        Height="34"
                                        CornerRadius="9"
                                        Background="{StaticResource PanelHoverBrush}"
                                        Margin="0,0,13,0"
                                        VerticalAlignment="Center">
                                    <controls:LineIcon Width="17"
                                                       Height="17"
                                                       Data="{Binding Icon}"
                                                       Foreground="{StaticResource TextSecondaryBrush}" />
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Label}"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBlock Text="{Binding Value}"
                                               Margin="0,2,0,0"
                                               FontSize="12.5"
                                               Foreground="{StaticResource TextBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding Value}" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <!-- Actions -->
            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,22,0,0">
                <Button x:Name="CancelButton"
                        Style="{StaticResource SecondaryDialogButtonStyle}"
                        IsCancel="True"
                        Margin="0,0,10,0"
                        Click="OnCancelClick">
                    <TextBlock x:Name="CancelTextBlock" Text="Отмена" />
                </Button>
                <Button x:Name="ConfirmButton"
                        Style="{StaticResource DangerDialogButtonStyle}"
                        IsDefault="True"
                        Click="OnConfirmClick">
                    <StackPanel Orientation="Horizontal">
                        <controls:LineIcon Width="16"
                                           Height="16"
                                           Margin="0,0,9,0"
                                           VerticalAlignment="Center"
                                           Data="{StaticResource Icon.Trash}"
                                           Foreground="#FFF1F4"
                                           StrokeThickness="1.9" />
                        <TextBlock x:Name="ConfirmTextBlock"
                                   VerticalAlignment="Center"
                                   Text="Удалить" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
