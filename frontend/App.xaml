<Application x:Class="Fluxora.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Assets/Icons.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Brand typography. Embedded TTFs (see Fonts/), full Latin + Cyrillic + German
                 so RU/EN/DE render in-brand. Segoe kept as graceful fallback.
                 Body   : Onest     — modern grotesque, excellent UI legibility.
                 Display: Unbounded — expressive headings / titles. -->
            <FontFamily x:Key="FluxoraFontBody">./Fonts/#Onest, Segoe UI Variable, Segoe UI</FontFamily>
            <FontFamily x:Key="FluxoraFontDisplay">./Fonts/#Unbounded, Segoe UI Variable, Segoe UI</FontFamily>

            <!-- Typographic system: the heaviest weight is the brand "voice" and is
                 rendered in the display face (Unbounded); everything else stays in
                 the body face (Onest). This implicit style promotes every heading
                 (FontWeight="Black") to the display face automatically. Icon glyphs and
                 list rows set FontFamily / Style locally, which outranks this trigger,
                 so they are untouched. -->
            <Style TargetType="{x:Type TextBlock}">
                <Style.Triggers>
                    <Trigger Property="FontWeight" Value="Black">
                        <Setter Property="FontFamily" Value="{StaticResource FluxoraFontDisplay}" />
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
