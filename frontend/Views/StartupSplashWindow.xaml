<Window x:Class="Fluxora.App.Views.StartupSplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fluxora"
        Width="440"
        Height="286"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="#0B0914"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/Fluxora.ico"
        FontFamily="{StaticResource FluxoraFontBody}"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        SourceInitialized="OnSourceInitialized">
    <Window.Resources>
        <SolidColorBrush x:Key="SplashTextBrush" Color="#F7F4FF" />
        <SolidColorBrush x:Key="SplashSecondaryTextBrush" Color="#C5BEDA" />
        <SolidColorBrush x:Key="SplashMutedTextBrush" Color="#928BAA" />

        <LinearGradientBrush x:Key="SplashWindowBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#21183A" Offset="0" />
            <GradientStop Color="#0B0914" Offset="0.52" />
            <GradientStop Color="#171124" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="SplashAccentBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F7F4FF" Offset="0" />
            <GradientStop Color="#C4B5FD" Offset="0.48" />
            <GradientStop Color="#7C3AED" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="StartupProgressBarStyle" TargetType="{x:Type ProgressBar}">
            <Setter Property="Height" Value="7" />
            <Setter Property="Foreground" Value="{StaticResource SplashAccentBrush}" />
            <Setter Property="Background" Value="#211B34" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ProgressBar}">
                        <Grid ClipToBounds="True">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="3.5" />
                            <Border x:Name="PART_Track"
                                    Background="Transparent"
                                    CornerRadius="3.5" />
                            <Border x:Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="3.5" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource SplashWindowBrush}"
          ClipToBounds="True">
        <Border BorderBrush="#27203B"
                BorderThickness="1" />

        <Grid Margin="36,30,36,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="18" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="18" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="20" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Image Source="pack://application:,,,/Fluxora.png"
                   Width="58"
                   Height="58"
                   Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   HorizontalAlignment="Center" />

            <TextBlock Grid.Row="2"
                       Text="{Binding AppName}"
                       FontFamily="{StaticResource FluxoraFontDisplay}"
                       FontSize="31"
                       FontWeight="Black"
                       Foreground="{StaticResource SplashTextBrush}"
                       TextAlignment="Center"
                       HorizontalAlignment="Center" />

            <StackPanel Grid.Row="4">
                <TextBlock Text="{Binding Title}"
                           FontSize="16"
                           FontWeight="Black"
                           Foreground="{StaticResource SplashTextBrush}"
                           TextAlignment="Center"
                           TextWrapping="Wrap" />
                <TextBlock Text="{Binding Detail}"
                           Margin="0,7,0,0"
                           FontSize="12.5"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource SplashSecondaryTextBrush}"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="360" />
            </StackPanel>

            <Grid Grid.Row="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="7" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid>
                    <TextBlock Text="Загрузка"
                               FontSize="11"
                               Foreground="{StaticResource SplashMutedTextBrush}"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Left" />
                    <TextBlock Text="{Binding ProgressText}"
                               FontSize="11"
                               Foreground="{StaticResource SplashSecondaryTextBrush}"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Right" />
                </Grid>
                <ProgressBar Grid.Row="2"
                             Style="{StaticResource StartupProgressBarStyle}"
                             Minimum="0"
                             Maximum="100"
                             Value="{Binding Progress, Mode=OneWay}" />
            </Grid>
        </Grid>
    </Grid>
</Window>
