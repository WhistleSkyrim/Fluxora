<Window x:Class="Fluxora.App.FomodInstallerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:controls="clr-namespace:Fluxora.App.Controls"
        xmlns:services="clr-namespace:Fluxora.App.Services"
        Title="FOMOD"
        Width="1000"
        Height="680"
        MinWidth="900"
        MinHeight="600"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        Background="#14111E"
        FontFamily="{StaticResource FluxoraFontBody}"
        FontWeight="Medium"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextHintingMode="Fixed"
        RenderOptions.ClearTypeHint="Enabled"
        FontSize="13"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="58"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <services:FomodImageSourceConverter x:Key="FomodImageSourceConverter" />
        <Geometry x:Key="Icon.Check">M20 6 9 17l-5-5</Geometry>

        <SolidColorBrush x:Key="TextBrush" Color="#F7F4FF" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#C5BEDA" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#918AA8" />
        <SolidColorBrush x:Key="AccentBrush" Color="#7C3AED" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#8B5CF6" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#241A46" />
        <SolidColorBrush x:Key="AccentLineBrush" Color="#493184" />
        <SolidColorBrush x:Key="PanelBrush" Color="#171523" />
        <SolidColorBrush x:Key="PanelRaisedBrush" Color="#211E32" />
        <SolidColorBrush x:Key="PanelSoftBrush" Color="#11101B" />
        <SolidColorBrush x:Key="PanelHoverBrush" Color="#29243D" />
        <SolidColorBrush x:Key="LineBrush" Color="#302B46" />
        <SolidColorBrush x:Key="LineHoverBrush" Color="#55467D" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#68E1D1" />
        <SolidColorBrush x:Key="ErrorBrush" Color="#FB7185" />

        <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#8B5CF6" Offset="0" />
            <GradientStop Color="#6D5DFB" Offset="0.62" />
            <GradientStop Color="#5B21B6" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="CaptionButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <controls:LineIcon Data="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"
                                               Width="15"
                                               Height="15"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{TemplateBinding Foreground}"
                                               StrokeThickness="1.8" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#F7F4FF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.72" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseCaptionButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource CaptionButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#66D83B4C" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DialogButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="38" />
            <Setter Property="MinWidth" Value="116" />
            <Setter Property="Padding" Value="15,0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              TextElement.FontWeight="{TemplateBinding FontWeight}"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.46" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryDialogButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource DialogButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
            <Setter Property="Foreground" Value="#F7F4FF" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentHoverBrush}" />
                    <Setter Property="BorderBrush" Value="#B197FC" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryDialogButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource DialogButtonStyle}">
            <Setter Property="Background" Value="{StaticResource PanelRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PanelHoverBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource LineHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Geometry x:Key="FluxoraScrollArrowUpGeometry">M 0 5 L 4 1 L 8 5 Z</Geometry>
        <Geometry x:Key="FluxoraScrollArrowDownGeometry">M 0 1 L 8 1 L 4 5 Z</Geometry>

        <Style x:Key="FluxoraVerticalScrollThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="Bar"
                                    Background="{StaticResource LineHoverBrush}"
                                    Width="7"
                                    MinHeight="34"
                                    Margin="0,1"
                                    CornerRadius="3.5"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Stretch" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bar" Property="Background" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="Bar" Property="Background" Value="{StaticResource AccentHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FluxoraScrollLineButtonStyle" TargetType="{x:Type RepeatButton}">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Delay" Value="280" />
            <Setter Property="Interval" Value="45" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <Path x:Name="Arrow"
                                  Data="{TemplateBinding Content}"
                                  Width="8"
                                  Height="5"
                                  Fill="{StaticResource MutedTextBrush}"
                                  Stretch="Uniform"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource PanelHoverBrush}" />
                                <Setter TargetName="Arrow" Property="Fill" Value="{StaticResource TextSecondaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                <Setter TargetName="Arrow" Property="Fill" Value="{StaticResource AccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Arrow" Property="Opacity" Value="0.35" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FluxoraScrollPageButtonStyle" TargetType="{x:Type RepeatButton}">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Width" Value="18" />
            <Setter Property="MinWidth" Value="18" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Background="{TemplateBinding Background}"
                              ClipToBounds="False">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="12" />
                                <RowDefinition Height="3" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="3" />
                                <RowDefinition Height="12" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="7" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <RepeatButton Grid.ColumnSpan="3"
                                          Style="{StaticResource FluxoraScrollLineButtonStyle}"
                                          Command="ScrollBar.LineUpCommand"
                                          Content="{StaticResource FluxoraScrollArrowUpGeometry}" />
                            <Track x:Name="PART_Track"
                                   Grid.Row="2"
                                   Grid.Column="1"
                                   Orientation="Vertical"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource FluxoraScrollPageButtonStyle}"
                                                  Command="ScrollBar.PageUpCommand" />
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource FluxoraScrollPageButtonStyle}"
                                                  Command="ScrollBar.PageDownCommand" />
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource FluxoraVerticalScrollThumbStyle}" />
                                </Track.Thumb>
                            </Track>
                            <RepeatButton Grid.Row="4"
                                          Grid.ColumnSpan="3"
                                          Style="{StaticResource FluxoraScrollLineButtonStyle}"
                                          Command="ScrollBar.LineDownCommand"
                                          Content="{StaticResource FluxoraScrollArrowDownGeometry}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StepItemStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{StaticResource PanelRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource SuccessBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsVisible}" Value="False">
                    <Setter Property="Background" Value="#171421" />
                    <Setter Property="BorderBrush" Value="#29233B" />
                    <Setter Property="Opacity" Value="0.46" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FomodGroupCardStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{StaticResource PanelSoftBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsValidationTarget}" Value="True">
                    <Setter Property="Background" Value="#271722" />
                    <Setter Property="BorderBrush" Value="{StaticResource ErrorBrush}" />
                    <Setter Property="BorderThickness" Value="2" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ImagePreviewButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FomodOptionToggleStyle" TargetType="{x:Type ToggleButton}">
            <Setter Property="MinHeight" Value="58" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Background" Value="{StaticResource PanelRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <TranslateTransform Y="0" />
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Root"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                         To="-1"
                                                         Duration="0:0:0.12" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Root"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                         To="0"
                                                         Duration="0:0:0.16" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource PanelHoverBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource LineHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                            </Trigger>
                            <DataTrigger Binding="{Binding WasPreviouslySelected}" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource SuccessBrush}" />
                            </DataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding WasPreviouslySelected}" Value="True" />
                                    <Condition Binding="{Binding IsSelected}" Value="True" />
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                            </MultiDataTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.56" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Border x:Name="DialogSurface"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="1"
                CornerRadius="0"
                Opacity="0">
            <Border.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="DialogSurface"
                                             Storyboard.TargetProperty="Opacity"
                                             To="1"
                                             Duration="0:0:0.16" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Border.Triggers>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Margin="24,18,18,14"
                      MouseLeftButtonDown="OnWindowDragMouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <Border Width="38"
                                Height="38"
                                CornerRadius="9"
                                Background="{StaticResource AccentGradientBrush}"
                                Margin="0,0,12,0">
                            <controls:LineIcon Data="{StaticResource Icon.Layers}"
                                               Width="18"
                                               Height="18"
                                               Foreground="#F7F4FF" />
                        </Border>
                        <StackPanel MaxWidth="780">
                            <TextBlock Text="{Binding ModuleTitle}"
                                       FontSize="19"
                                       FontWeight="Black"
                                       Foreground="{StaticResource TextBrush}"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding ModuleSubtitle}"
                                       Margin="0,3,0,0"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Style="{StaticResource CloseCaptionButtonStyle}"
                            Tag="{StaticResource Icon.WindowClose}"
                            AutomationProperties.Name="Закрыть"
                            Click="OnCancelClick" />
                </Grid>

                <Grid Grid.Row="1"
                      Margin="24,0,24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="206" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Background="{StaticResource PanelSoftBrush}"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top"
                                        Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Шаги"
                                               FontWeight="Black"
                                               Foreground="{StaticResource TextBrush}" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding StepCounterText}"
                                               Foreground="{StaticResource MutedTextBrush}" />
                                </Grid>
                            </StackPanel>

                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding NavigationSteps}"
                                              Margin="0,0,10,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource StepItemStyle}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="30" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Width="20"
                                                            Height="20"
                                                            BorderBrush="{StaticResource LineHoverBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="10"
                                                            VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding StepNumberText}"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center" />
                                                    </Border>
                                                    <StackPanel Grid.Column="1">
                                                            <TextBlock Text="{Binding Name}"
                                                                       TextWrapping="Wrap"
                                                                       Foreground="{StaticResource TextBrush}"
                                                                       FontWeight="SemiBold" />
                                                            <TextBlock Text="{Binding StatusText}"
                                                                   Margin="0,4,0,0"
                                                                   Foreground="{StaticResource MutedTextBrush}"
                                                                   FontSize="12" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Background="#162622"
                                BorderBrush="#356B68"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,12"
                                Visibility="{Binding HasPreviousSelection, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <controls:LineIcon Data="{StaticResource Icon.Refresh}"
                                                       Width="16"
                                                       Height="16"
                                                       Foreground="{StaticResource SuccessBrush}"
                                                       Margin="0,0,9,0" />
                                    <TextBlock Text="{Binding PreviousSelectionText}"
                                               Foreground="{StaticResource TextBrush}"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Style="{StaticResource SecondaryDialogButtonStyle}"
                                        Command="{Binding UsePreviousSelectionsCommand}"
                                        MinWidth="156"
                                        Margin="14,0,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <controls:LineIcon Data="{StaticResource Icon.Refresh}"
                                                           Width="14"
                                                           Height="14"
                                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                                                           Margin="0,0,8,0" />
                                        <TextBlock Text="Как в прошлый раз" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1"
                              DataContext="{Binding CurrentStep}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="{Binding Name}"
                                       FontSize="18"
                                       FontWeight="Black"
                                       Foreground="{StaticResource TextBrush}"
                                       Margin="0,0,0,12"
                                       TextWrapping="Wrap" />

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" MinWidth="330" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="306" />
                                </Grid.ColumnDefinitions>

                                <ScrollViewer x:Name="OptionsScrollViewer"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <ItemsControl x:Name="GroupItemsControl"
                                                  ItemsSource="{Binding Groups}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource FomodGroupCardStyle}">
                                                    <StackPanel>
                                                        <Grid Margin="0,0,0,10">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="{Binding Name}"
                                                                       FontWeight="Black"
                                                                       Foreground="{StaticResource TextBrush}"
                                                                       TextWrapping="Wrap" />
                                                        </Grid>
                                                        <TextBlock Text="{Binding ValidationMessage}"
                                                                   Visibility="{Binding IsValidationTarget, Converter={StaticResource BoolToVisibilityConverter}}"
                                                                   Foreground="{StaticResource ErrorBrush}"
                                                                   FontWeight="SemiBold"
                                                                   Margin="0,0,0,10"
                                                                   TextWrapping="Wrap" />

                                                        <ItemsControl ItemsSource="{Binding Options}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <ToggleButton Style="{StaticResource FomodOptionToggleStyle}"
                                                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                                  IsEnabled="{Binding CanToggle}"
                                                                                  MouseEnter="OnOptionPreview"
                                                                                  GotKeyboardFocus="OnOptionPreview">
                                                                        <Grid>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="Auto" />
                                                                                <ColumnDefinition Width="*" />
                                                                            </Grid.ColumnDefinitions>
                                                                            <Border x:Name="OptionCheck"
                                                                                    Width="24"
                                                                                    Height="24"
                                                                                    CornerRadius="6"
                                                                                    Background="{StaticResource PanelBrush}"
                                                                                    BorderBrush="{StaticResource LineBrush}"
                                                                                    BorderThickness="1"
                                                                                    Margin="0,0,12,0"
                                                                                    VerticalAlignment="Center">
                                                                                <controls:LineIcon x:Name="OptionGlyph"
                                                                                                   Data="{StaticResource Icon.Check}"
                                                                                                   Width="13"
                                                                                                   Height="13"
                                                                                                   HorizontalAlignment="Center"
                                                                                                   VerticalAlignment="Center"
                                                                                                   Foreground="#F7F4FF"
                                                                                                   Visibility="Collapsed" />
                                                                            </Border>
                                                                            <StackPanel Grid.Column="1">
                                                                                <TextBlock Text="{Binding Name}"
                                                                                           FontWeight="Black"
                                                                                           Foreground="{StaticResource TextBrush}"
                                                                                           TextWrapping="Wrap" />
                                                                                <TextBlock Text="{Binding PreviousBadgeText}"
                                                                                           Visibility="{Binding WasPreviouslySelected, Converter={StaticResource BoolToVisibilityConverter}}"
                                                                                           Foreground="{StaticResource SuccessBrush}"
                                                                                           FontWeight="SemiBold"
                                                                                           Margin="0,7,0,0" />
                                                                            </StackPanel>
                                                                        </Grid>
                                                                    </ToggleButton>
                                                                    <DataTemplate.Triggers>
                                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                            <Setter TargetName="OptionGlyph" Property="Visibility" Value="Visible" />
                                                                            <Setter TargetName="OptionCheck" Property="Background" Value="{StaticResource AccentBrush}" />
                                                                            <Setter TargetName="OptionCheck" Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                                                                        </DataTrigger>
                                                                    </DataTemplate.Triggers>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <Border Grid.Column="2"
                                        Background="{StaticResource PanelSoftBrush}"
                                        BorderBrush="{StaticResource LineBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="16"
                                        DataContext="{Binding DataContext.DetailsOption, RelativeSource={RelativeSource AncestorType={x:Type Window}}}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <Button Style="{StaticResource ImagePreviewButtonStyle}"
                                                Visibility="{Binding HasPreviewImage, Converter={StaticResource BoolToVisibilityConverter}}"
                                                Click="OnPreviewImageClick"
                                                Margin="0,0,0,14"
                                                AutomationProperties.Name="Открыть изображение FOMOD">
                                            <Grid Height="170"
                                                  ClipToBounds="True">
                                                <Border CornerRadius="8"
                                                        Background="{StaticResource PanelBrush}"
                                                        BorderBrush="{StaticResource LineBrush}"
                                                        BorderThickness="1" />
                                                <Image Source="{Binding PreviewImagePath, Converter={StaticResource FomodImageSourceConverter}, ConverterParameter=720}"
                                                       Stretch="UniformToFill"
                                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                                <Border CornerRadius="8"
                                                        Background="#99080711">
                                                    <Border.Style>
                                                        <Style TargetType="{x:Type Border}">
                                                            <Setter Property="Opacity" Value="0" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" Value="True">
                                                                    <Setter Property="Opacity" Value="1" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <controls:LineIcon Data="{StaticResource Icon.ImageExpand}"
                                                                       Width="34"
                                                                       Height="34"
                                                                       StrokeThickness="1.6"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       Foreground="#FFFFFF" />
                                                </Border>
                                            </Grid>
                                        </Button>

                                        <ScrollViewer Grid.Row="1"
                                                      VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Disabled">
                                            <TextBlock Text="{Binding DisplayDescription}"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap"
                                                       LineHeight="19" />
                                        </ScrollViewer>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>

                <Grid Grid.Row="2"
                      Margin="24,14,24,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="{Binding ValidationMessage}"
                               Foreground="{StaticResource ErrorBrush}"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap" />

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal">
                        <Button Style="{StaticResource SecondaryDialogButtonStyle}"
                                IsCancel="True"
                                Click="OnCancelClick"
                                Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal">
                                <controls:LineIcon Data="{StaticResource Icon.Back}"
                                                   Width="14"
                                                   Height="14"
                                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                                                   Margin="0,0,8,0" />
                                <TextBlock Text="Отмена" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SecondaryDialogButtonStyle}"
                                Command="{Binding PreviousStepCommand}"
                                Margin="0,0,10,0">
                            <TextBlock Text="Назад" />
                        </Button>
                        <Button Style="{StaticResource PrimaryDialogButtonStyle}"
                                IsDefault="True"
                                Click="OnPrimaryClick">
                            <StackPanel Orientation="Horizontal">
                                <controls:LineIcon Data="{StaticResource Icon.Plus}"
                                                   Width="14"
                                                   Height="14"
                                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                                                   Margin="0,0,8,0" />
                                <TextBlock Text="{Binding PrimaryButtonText}" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Grid x:Name="ImageLightboxOverlay"
              Visibility="Collapsed"
              Background="#E6080711"
              MouseLeftButtonDown="OnLightboxBackgroundMouseLeftButtonDown">
            <Image x:Name="LightboxImage"
                   Source="{Binding PreviewImagePath, Converter={StaticResource FomodImageSourceConverter}, ConverterParameter=1800}"
                   Stretch="Uniform"
                   Margin="42"
                   RenderOptions.BitmapScalingMode="HighQuality" />

            <Button x:Name="LightboxCloseButton"
                    Style="{StaticResource CloseCaptionButtonStyle}"
                    Tag="{StaticResource Icon.WindowClose}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Width="40"
                    Height="40"
                    Margin="0,22,22,0"
                    AutomationProperties.Name="Закрыть предпросмотр"
                    Click="OnLightboxCloseClick" />
        </Grid>
    </Grid>
</Window>
