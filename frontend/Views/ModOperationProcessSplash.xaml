<UserControl x:Class="Fluxora.App.Views.ModOperationProcessSplash"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:services="clr-namespace:Fluxora.App.Services"
             IsHitTestVisible="{Binding IsVisible}"
             FontFamily="{StaticResource FluxoraFontBody}"
             FontWeight="Medium"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             TextOptions.TextHintingMode="Fixed"
             RenderOptions.ClearTypeHint="Enabled"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <SolidColorBrush x:Key="OperationTextBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="OperationSecondaryTextBrush" Color="#C8D0DD" />
        <SolidColorBrush x:Key="OperationMutedTextBrush" Color="#8D99AA" />
        <SolidColorBrush x:Key="OperationErrorBrush" Color="#FB7185" />

        <LinearGradientBrush x:Key="OperationCoreBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F8FAFC" Offset="0" />
            <GradientStop Color="#67E8F9" Offset="0.42" />
            <GradientStop Color="#8B5CF6" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="OperationProgressBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#67E8F9" Offset="0" />
            <GradientStop Color="#A78BFA" Offset="0.58" />
            <GradientStop Color="#F0ABFC" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="OperationProgressBarStyle" TargetType="{x:Type ProgressBar}">
            <Setter Property="Height" Value="12" />
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="100" />
            <Setter Property="Foreground" Value="{StaticResource OperationProgressBrush}" />
            <Setter Property="Background" Value="#242A38" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ProgressBar}">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                ClipToBounds="True">
                            <Grid x:Name="PART_Track">
                                <Rectangle x:Name="PART_Indicator"
                                           HorizontalAlignment="Left"
                                           Fill="{TemplateBinding Foreground}"
                                           RadiusX="6"
                                           RadiusY="6" />
                                <Border x:Name="ProgressSheen"
                                        Width="90"
                                        HorizontalAlignment="Left"
                                        Opacity="0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#00FFFFFF" Offset="0" />
                                            <GradientStop Color="#AAFFFFFF" Offset="0.5" />
                                            <GradientStop Color="#00FFFFFF" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.RenderTransform>
                                        <TranslateTransform x:Name="ProgressSheenTranslate" X="-90" />
                                    </Border.RenderTransform>
                                </Border>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="services:ProgressAnimationService.IsActive" Value="True">
                                <Setter TargetName="ProgressSheen" Property="Opacity" Value="0.24" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard x:Name="OperationProgressStoryboard">
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetName="ProgressSheenTranslate"
                                                             Storyboard.TargetProperty="X"
                                                             From="-90"
                                                             To="430"
                                                             Duration="0:0:1.55" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <RemoveStoryboard BeginStoryboardName="OperationProgressStoryboard" />
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OperationGhostButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Background" Value="#263044" />
            <Setter Property="BorderBrush" Value="#3B465C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource OperationTextBrush}" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.FontWeight="{TemplateBinding FontWeight}"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#303B52" />
                                <Setter Property="BorderBrush" Value="#5B6B88" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1E2636" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <UserControl.Style>
        <Style TargetType="{x:Type UserControl}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsVisible}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Style>

    <Grid>
        <Grid.Triggers>
            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                <BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever">
                        <DoubleAnimation Storyboard.TargetName="OuterArcRotate"
                                         Storyboard.TargetProperty="Angle"
                                         From="-18"
                                         To="702"
                                         Duration="0:0:3.4" />
                        <DoubleAnimation Storyboard.TargetName="InnerArcRotate"
                                         Storyboard.TargetProperty="Angle"
                                         From="28"
                                         To="-692"
                                         Duration="0:0:3.4" />
                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CoreScale"
                                                       Storyboard.TargetProperty="ScaleX">
                            <SplineDoubleKeyFrame KeyTime="0:0:0" Value="0.84" />
                            <SplineDoubleKeyFrame KeyTime="0:0:1.18" Value="1.2" KeySpline="0.2,0 0.16,1" />
                            <SplineDoubleKeyFrame KeyTime="0:0:3.4" Value="0.84" KeySpline="0.28,0 0.16,1" />
                        </DoubleAnimationUsingKeyFrames>
                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CoreScale"
                                                       Storyboard.TargetProperty="ScaleY">
                            <SplineDoubleKeyFrame KeyTime="0:0:0" Value="0.84" />
                            <SplineDoubleKeyFrame KeyTime="0:0:1.18" Value="1.2" KeySpline="0.2,0 0.16,1" />
                            <SplineDoubleKeyFrame KeyTime="0:0:3.4" Value="0.84" KeySpline="0.28,0 0.16,1" />
                        </DoubleAnimationUsingKeyFrames>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Grid.Triggers>

        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F6070A12" Offset="0" />
                <GradientStop Color="#F30B101D" Offset="0.52" />
                <GradientStop Color="#F40E1426" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid Width="460"
              MaxWidth="460"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="22" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="8" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="24" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Width="118"
                  Height="118"
                  HorizontalAlignment="Center">
                <Ellipse Width="100"
                         Height="100"
                         Stroke="#273246"
                         StrokeThickness="7" />
                <Ellipse Width="100"
                         Height="100"
                         Stroke="#67E8F9"
                         StrokeThickness="7"
                         StrokeStartLineCap="Round"
                         StrokeEndLineCap="Round"
                         StrokeDashArray="5.8 14.6"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <RotateTransform x:Name="OuterArcRotate" />
                    </Ellipse.RenderTransform>
                </Ellipse>
                <Ellipse Width="66"
                         Height="66"
                         Stroke="#F0ABFC"
                         StrokeThickness="4"
                         StrokeStartLineCap="Round"
                         StrokeEndLineCap="Round"
                         StrokeDashArray="2.4 8.4"
                         Opacity="0.52"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <RotateTransform x:Name="InnerArcRotate" />
                    </Ellipse.RenderTransform>
                </Ellipse>
                <Border Width="30"
                        Height="30"
                        CornerRadius="15"
                        Background="{StaticResource OperationCoreBrush}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <ScaleTransform x:Name="CoreScale" />
                    </Border.RenderTransform>
                </Border>
            </Grid>

            <TextBlock Grid.Row="2"
                       Text="{Binding Title}"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource OperationMutedTextBrush}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center" />

            <TextBlock Grid.Row="4"
                       Text="{Binding CurrentStep}"
                       FontSize="28"
                       FontWeight="Black"
                       Foreground="{StaticResource OperationTextBrush}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       MaxWidth="460" />

            <StackPanel Grid.Row="6">
                <TextBlock Text="{Binding StatusText}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource OperationSecondaryTextBrush}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="440"
                           Margin="0,0,0,18" />

                <Grid Margin="0,0,0,9">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Прогресс"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource OperationMutedTextBrush}" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding Value, ElementName=OverallBar, StringFormat={}{0:0}%}"
                               FontSize="13"
                               FontWeight="Black"
                               Foreground="{StaticResource OperationTextBrush}" />
                </Grid>

                <ProgressBar x:Name="OverallBar"
                             Style="{StaticResource OperationProgressBarStyle}"
                             services:ProgressAnimationService.IsActive="{Binding IsRunning}"
                             services:SmoothProgressService.TargetValue="{Binding OverallPercent}" />

                <Border Background="#2A1220"
                        BorderBrush="#7F1D3A"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12"
                        Margin="0,16,0,0"
                        Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{StaticResource OperationErrorBrush}"
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                </Border>

                <Button Style="{StaticResource OperationGhostButtonStyle}"
                        Content="Закрыть"
                        HorizontalAlignment="Center"
                        MinWidth="132"
                        Margin="0,22,0,0"
                        Click="CloseButton_Click"
                        Visibility="{Binding CanClose, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
