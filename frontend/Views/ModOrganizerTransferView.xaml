<UserControl x:Class="Fluxora.App.Views.ModOrganizerTransferView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="{StaticResource FluxoraFontBody}"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             FontSize="12"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <SolidColorBrush x:Key="TextBrush" Color="#F7F4FF" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#C5BEDA" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#918AA8" />
        <SolidColorBrush x:Key="SubtleTextBrush" Color="#736D86" />
        <SolidColorBrush x:Key="AccentBrush" Color="#7C3AED" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#8B5CF6" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#241A46" />
        <SolidColorBrush x:Key="AccentLineBrush" Color="#493184" />
        <SolidColorBrush x:Key="PanelBrush" Color="#171523" />
        <SolidColorBrush x:Key="PanelRaisedBrush" Color="#201D31" />
        <SolidColorBrush x:Key="PanelSoftBrush" Color="#11101B" />
        <SolidColorBrush x:Key="PanelHoverBrush" Color="#27223A" />
        <SolidColorBrush x:Key="LineBrush" Color="#302B46" />
        <SolidColorBrush x:Key="LineHoverBrush" Color="#55467D" />
        <SolidColorBrush x:Key="ErrorBrush" Color="#FB7185" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#34D399" />

        <DropShadowEffect x:Key="PanelShadow"
                          Color="#06040D"
                          BlurRadius="22"
                          ShadowDepth="8"
                          Opacity="0.28" />

        <Style x:Key="PanelBorderStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Effect" Value="{StaticResource PanelShadow}" />
        </Style>

        <Style x:Key="InnerPanelStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{StaticResource PanelRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>

        <Style x:Key="PillBorderStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentLineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="9,5" />
        </Style>

        <Style x:Key="BaseButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Root"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                         To="1.012"
                                                         Duration="0:0:0.14" />
                                        <DoubleAnimation Storyboard.TargetName="Root"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                         To="1.012"
                                                         Duration="0:0:0.14" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Root"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                         To="1"
                                                         Duration="0:0:0.18" />
                                        <DoubleAnimation Storyboard.TargetName="Root"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                         To="1"
                                                         Duration="0:0:0.18" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.46" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentHoverBrush}" />
                    <Setter Property="BorderBrush" Value="#B197FC" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="{StaticResource PanelRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PanelHoverBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource LineHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StepNavButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="MinHeight" Value="54" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IncompleteStepCardStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="#24121B" />
            <Setter Property="BorderBrush" Value="#7F1D3A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="12,10" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="TransferTextBoxStyle" TargetType="{x:Type TextBox}">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="CaretBrush" Value="{StaticResource AccentHoverBrush}" />
            <Setter Property="Background" Value="{StaticResource PanelSoftBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                                <Setter TargetName="Root" Property="Background" Value="#151322" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.62" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TransferComboBoxStyle" TargetType="{x:Type ComboBox}">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Background" Value="{StaticResource PanelSoftBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="MaxDropDownHeight" Value="260" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="{x:Type ComboBoxItem}">
                        <Setter Property="Background" Value="#151322" />
                        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                        <Setter Property="Padding" Value="9,7" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="IsEnabled" Value="{Binding IsSelectable}" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                                    <Border x:Name="Root"
                                            Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="Root" Property="Background" Value="{StaticResource PanelHoverBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                                            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Border x:Name="Root"
                                                Background="{Binding Background, RelativeSource={RelativeSource AncestorType={x:Type ComboBox}}}"
                                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType={x:Type ComboBox}}}"
                                                BorderThickness="1"
                                                CornerRadius="9">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="30" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock x:Name="SelectedText"
                                                           Margin="{Binding Padding, RelativeSource={RelativeSource AncestorType={x:Type ComboBox}}}"
                                                           VerticalAlignment="Center"
                                                           Foreground="{StaticResource TextBrush}"
                                                           Text="{Binding SelectedItem.DisplayName, RelativeSource={RelativeSource AncestorType={x:Type ComboBox}}}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="1"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           Text="&#xE70D;"
                                                           FontSize="10"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Root" Property="Background" Value="{StaticResource PanelHoverBrush}" />
                                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource LineHoverBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="Root" Property="Opacity" Value="0.5" />
                                            </Trigger>
                                            <DataTrigger Binding="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType={x:Type ComboBox}}}" Value="{x:Null}">
                                                <Setter TargetName="SelectedText" Property="Text" Value="Выберите диск" />
                                                <Setter TargetName="SelectedText" Property="Foreground" Value="{StaticResource MutedTextBrush}" />
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Grid MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border Background="{StaticResource PanelSoftBrush}"
                                            BorderBrush="{StaticResource LineHoverBrush}"
                                            BorderThickness="1"
                                            CornerRadius="9"
                                            Padding="4"
                                            Margin="0,4,0,0">
                                        <ScrollViewer CanContentScroll="True"
                                                      HorizontalScrollBarVisibility="Disabled"
                                                      VerticalScrollBarVisibility="Auto">
                                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Border Style="{StaticResource PanelBorderStyle}"
                Padding="24">
            <Grid>
                <Grid.Style>
                    <Style TargetType="{x:Type Grid}">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsTransferProcessVisible}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="{Binding TransferStepTitle}"
                                   FontSize="31"
                                   FontWeight="Black"
                                   Foreground="{StaticResource TextBrush}" />
                        <TextBlock Text="{Binding TransferStepSubtitle}"
                                   Margin="0,7,0,0"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <Border Grid.Column="1"
                            Style="{StaticResource PillBorderStyle}"
                            VerticalAlignment="Top">
                        <TextBlock Text="{Binding TransferStepCounter}"
                                   Foreground="{StaticResource TextBrush}"
                                   FontWeight="SemiBold" />
                    </Border>
                </Grid>

                <Grid Grid.Row="1"
                      Margin="0,20,0,22">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Style="{StaticResource StepNavButtonStyle}"
                            Command="{Binding SelectTransferStepCommand}"
                            CommandParameter="0">
                        <Border>
                            <Border.Style>
                                <Style TargetType="{x:Type Border}" BasedOn="{StaticResource IncompleteStepCardStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsTransferSourceComplete}" Value="True">
                                            <Setter Property="Background" Value="#10251D" />
                                            <Setter Property="BorderBrush" Value="#2F9E68" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsTransferSourceStep}" Value="True">
                                            <Setter Property="BorderThickness" Value="2" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding TransferSourceStepIcon}"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="13"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="{x:Type TextBlock}">
                                            <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTransferSourceComplete}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Источник"
                                               Foreground="{StaticResource TextBrush}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding TransferSourceStepStatus}"
                                               Margin="0,2,0,0"
                                               FontSize="10"
                                               Foreground="{StaticResource MutedTextBrush}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Button>

                    <Button Grid.Column="2"
                            Style="{StaticResource StepNavButtonStyle}"
                            Command="{Binding SelectTransferStepCommand}"
                            CommandParameter="1">
                        <Border>
                            <Border.Style>
                                <Style TargetType="{x:Type Border}" BasedOn="{StaticResource IncompleteStepCardStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsTransferDestinationComplete}" Value="True">
                                            <Setter Property="Background" Value="#10251D" />
                                            <Setter Property="BorderBrush" Value="#2F9E68" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsTransferDestinationStep}" Value="True">
                                            <Setter Property="BorderThickness" Value="2" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding TransferDestinationStepIcon}"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="13"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="{x:Type TextBlock}">
                                            <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTransferDestinationComplete}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Назначение"
                                               Foreground="{StaticResource TextBrush}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding TransferDestinationStepStatus}"
                                               Margin="0,2,0,0"
                                               FontSize="10"
                                               Foreground="{StaticResource MutedTextBrush}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Button>

                    <Button Grid.Column="4"
                            Style="{StaticResource StepNavButtonStyle}"
                            Command="{Binding SelectTransferStepCommand}"
                            CommandParameter="2">
                        <Border>
                            <Border.Style>
                                <Style TargetType="{x:Type Border}" BasedOn="{StaticResource IncompleteStepCardStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsTransferReviewComplete}" Value="True">
                                            <Setter Property="Background" Value="#10251D" />
                                            <Setter Property="BorderBrush" Value="#2F9E68" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsTransferReviewStep}" Value="True">
                                            <Setter Property="BorderThickness" Value="2" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding TransferReviewStepIcon}"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="13"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="{x:Type TextBlock}">
                                            <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTransferReviewComplete}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Проверка"
                                               Foreground="{StaticResource TextBrush}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding TransferReviewStepStatus}"
                                               Margin="0,2,0,0"
                                               FontSize="10"
                                               Foreground="{StaticResource MutedTextBrush}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Button>
                </Grid>

                <Grid Grid.Row="2">
                    <Grid Visibility="{Binding IsTransferSourceStep, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Папка Mod Organizer 2"
                                       Style="{StaticResource FieldLabelStyle}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Style="{StaticResource TransferTextBoxStyle}"
                                         Text="{Binding SourceDirectory, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Grid.Column="2"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding BrowseSourceCommand}"
                                        MinWidth="104">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                                   Text="&#xE8B7;"
                                                   FontSize="13"
                                                   Margin="0,0,8,0" />
                                        <TextBlock Text="Выбрать" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <Border Style="{StaticResource InnerPanelStyle}"
                                    Padding="16"
                                    Margin="0,18,0,0">
                                <StackPanel>
                                    <TextBlock Text="Что будет перенесено"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextBrush}" />
                                    <TextBlock Text="C++ core проверит структуру MO2, прочитает профиль, порядок модов и подготовит перенос без удаления исходной папки."
                                               Margin="0,8,0,0"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <Grid Visibility="{Binding IsTransferDestinationStep, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="{Binding DestinationLabel}"
                                       Style="{StaticResource FieldLabelStyle}" />
                            <ComboBox Style="{StaticResource TransferComboBoxStyle}"
                                      ItemsSource="{Binding AvailableDrives}"
                                      SelectedItem="{Binding SelectedDrive}"
                                      DisplayMemberPath="DisplayName"
                                      IsEnabled="{Binding CanChangeDestination}" />
                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Style="{StaticResource TransferTextBoxStyle}"
                                         Text="{Binding DestinationRootDirectory, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding CanChangeDestination}" />
                                <Button Grid.Column="2"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding BrowseDestinationCommand}"
                                        MinWidth="104"
                                        IsEnabled="{Binding CanChangeDestination}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                                   Text="&#xE8B7;"
                                                   FontSize="13"
                                                   Margin="0,0,8,0" />
                                        <TextBlock Text="Выбрать" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <Border Style="{StaticResource InnerPanelStyle}"
                                    Padding="16"
                                    Margin="0,18,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Итоговая папка"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextBrush}" />
                                        <TextBlock Text="{Binding TransferTargetText}"
                                                   Margin="0,8,0,0"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding TransferAvailableText}"
                                               Margin="18,0,0,0"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <ScrollViewer Visibility="{Binding IsTransferReviewStep, Converter={StaticResource BooleanToVisibilityConverter}}"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="0,0,4,0">
                        <StackPanel>
                            <Border Style="{StaticResource InnerPanelStyle}"
                                    Padding="18">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding TransferProjectName}"
                                                       FontSize="22"
                                                       FontWeight="Black"
                                                       Foreground="{StaticResource TextBrush}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding TransferMessage}"
                                                       Margin="0,6,0,0"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>

                                    <ProgressBar Grid.Row="1"
                                                 Height="3"
                                                 IsIndeterminate="True"
                                                 Foreground="{StaticResource AccentHoverBrush}"
                                                 Background="#0E0C16"
                                                 BorderThickness="0"
                                                 Margin="0,14,0,0"
                                                 Visibility="{Binding IsAnalyzingTransfer, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                    <Grid Grid.Row="2"
                                          Margin="0,18,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Background="#151220"
                                                BorderBrush="{StaticResource LineBrush}"
                                                BorderThickness="1"
                                                CornerRadius="10"
                                                Padding="14">
                                            <StackPanel>
                                                <TextBlock Text="Моды"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           FontSize="12" />
                                                <TextBlock Text="{Binding TransferModCountText}"
                                                           Margin="0,5,0,0"
                                                           Foreground="{StaticResource TextBrush}"
                                                           FontWeight="Black"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="2"
                                                Background="#151220"
                                                BorderBrush="{StaticResource LineBrush}"
                                                BorderThickness="1"
                                                CornerRadius="10"
                                                Padding="14">
                                            <StackPanel>
                                                <TextBlock Text="Вес"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           FontSize="12" />
                                                <TextBlock Text="{Binding TransferSizeText}"
                                                           Margin="0,5,0,0"
                                                           Foreground="{StaticResource TextBrush}"
                                                           FontWeight="Black" />
                                                <TextBlock Text="{Binding TransferAvailableText}"
                                                           Margin="0,3,0,0"
                                                           Foreground="{StaticResource SubtleTextBrush}"
                                                           FontSize="11"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="4"
                                                Background="#151220"
                                                BorderBrush="{StaticResource LineBrush}"
                                                BorderThickness="1"
                                                CornerRadius="10"
                                                Padding="14">
                                            <StackPanel>
                                                <TextBlock Text="Профиль"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           FontSize="12" />
                                                <TextBlock Text="{Binding TransferProfileText}"
                                                           Margin="0,5,0,0"
                                                           Foreground="{StaticResource TextBrush}"
                                                           FontWeight="Black"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding TransferGameText}"
                                                           Margin="0,3,0,0"
                                                           Foreground="{StaticResource SubtleTextBrush}"
                                                           FontSize="11"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Border>

                            <Border Background="#241A12"
                                    BorderBrush="#6D4D1F"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="12"
                                    Margin="0,14,0,0"
                                    Visibility="{Binding HasTransferWarning, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="{Binding TransferWarningText}"
                                           Foreground="#FDE68A"
                                           TextWrapping="Wrap" />
                            </Border>

                            <Border Padding="12"
                                    Margin="0,14,0,0"
                                    Visibility="{Binding HasTransferAnalysis, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Border.Style>
                                    <Style TargetType="{x:Type Border}">
                                        <Setter Property="Background" Value="#2A1220" />
                                        <Setter Property="BorderBrush" Value="#7F1D3A" />
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Setter Property="CornerRadius" Value="10" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasEnoughSpace}" Value="True">
                                                <Setter Property="Background" Value="#10251D" />
                                                <Setter Property="BorderBrush" Value="#2F9E68" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding TransferDiskSpaceText}"
                                           Foreground="{StaticResource TextBrush}"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap" />
                            </Border>

                            <TextBlock Text="{Binding TransferTargetText}"
                                       Margin="0,12,0,0"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="11"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <Grid Grid.Row="3"
                      Margin="0,18,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Background="#2A1220"
                            BorderBrush="#7F1D3A"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="12"
                            Margin="0,0,0,12"
                            Visibility="{Binding HasTransferError, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="{Binding TransferError}"
                                   Foreground="{StaticResource ErrorBrush}"
                                   TextWrapping="Wrap" />
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding CancelTransferFlowCommand}"
                                Content="Отменить перенос"
                                MinWidth="142" />

                        <Button Grid.Column="2"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding PreviousTransferStepCommand}"
                                MinWidth="94">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                           Text="&#xE72B;"
                                           FontSize="12"
                                           Margin="0,0,7,0" />
                                <TextBlock Text="Назад" />
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="4"
                                Command="{Binding NextTransferStepCommand}"
                                MinWidth="126">
                            <Button.Style>
                                <Style TargetType="{x:Type Button}" BasedOn="{StaticResource PrimaryButtonStyle}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsTransferReviewStep}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding NextTransferStepText}" />
                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                           Text="&#xE72A;"
                                           FontSize="12"
                                           Margin="7,0,0,0" />
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="4"
                                Command="{Binding StartTransferCommand}"
                                MinWidth="164">
                            <Button.Style>
                                <Style TargetType="{x:Type Button}" BasedOn="{StaticResource PrimaryButtonStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsTransferReviewStep}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="{Binding StartTransferText}" />
                        </Button>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
