<UserControl x:Class="Fluxora.App.Views.BuildLoadingSplash"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             IsHitTestVisible="{Binding IsBuildLoadingSplashVisible}"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">
    <UserControl.Resources>
        <SolidColorBrush x:Key="SplashTextBrush" Color="#F7F4FF" />
        <SolidColorBrush x:Key="SplashSecondaryTextBrush" Color="#C5BEDA" />

        <LinearGradientBrush x:Key="SplashCoreBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F7F4FF" Offset="0" />
            <GradientStop Color="#C4B5FD" Offset="0.45" />
            <GradientStop Color="#8B5CF6" Offset="1" />
        </LinearGradientBrush>
    </UserControl.Resources>

    <UserControl.Style>
        <Style TargetType="{x:Type UserControl}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsBuildLoadingSplashVisible}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Style>

    <Grid>
        <Grid.Triggers>
            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                <BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever">
                        <DoubleAnimation Storyboard.TargetName="MainArcRotate"
                                         Storyboard.TargetProperty="Angle"
                                         From="-24"
                                         To="696"
                                         Duration="0:0:3.7" />

                        <DoubleAnimation Storyboard.TargetName="EchoArcRotate"
                                         Storyboard.TargetProperty="Angle"
                                         From="42"
                                         To="-678"
                                         Duration="0:0:3.7" />

                        <DoubleAnimation Storyboard.TargetName="MainArc"
                                         Storyboard.TargetProperty="StrokeDashOffset"
                                         From="0"
                                         To="-43.2"
                                         Duration="0:0:3.7" />
                        <DoubleAnimation Storyboard.TargetName="EchoArc"
                                         Storyboard.TargetProperty="StrokeDashOffset"
                                         From="0"
                                         To="23.6"
                                         Duration="0:0:3.7" />

                        <DoubleAnimation Storyboard.TargetName="CoreRotate"
                                         Storyboard.TargetProperty="Angle"
                                         From="0"
                                         To="360"
                                         Duration="0:0:3.7" />

                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CoreScale"
                                                       Storyboard.TargetProperty="ScaleX">
                            <SplineDoubleKeyFrame KeyTime="0:0:0" Value="0.82" />
                            <SplineDoubleKeyFrame KeyTime="0:0:0.92" Value="1.32" KeySpline="0.26,0 0.14,1" />
                            <SplineDoubleKeyFrame KeyTime="0:0:1.91" Value="0.88" KeySpline="0.42,0 0.16,1" />
                            <SplineDoubleKeyFrame KeyTime="0:0:2.83" Value="1.12" KeySpline="0.2,0 0.12,1" />
                            <SplineDoubleKeyFrame KeyTime="0:0:3.7" Value="0.82" KeySpline="0.26,0 0.16,1" />
                        </DoubleAnimationUsingKeyFrames>
                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CoreScale"
                                                       Storyboard.TargetProperty="ScaleY">
                            <SplineDoubleKeyFrame KeyTime="0:0:0" Value="0.82" />
                            <SplineDoubleKeyFrame KeyTime="0:0:0.92" Value="0.76" KeySpline="0.26,0 0.14,1" />
                            <SplineDoubleKeyFrame KeyTime="0:0:1.91" Value="1.18" KeySpline="0.42,0 0.16,1" />
                            <SplineDoubleKeyFrame KeyTime="0:0:2.83" Value="0.92" KeySpline="0.2,0 0.12,1" />
                            <SplineDoubleKeyFrame KeyTime="0:0:3.7" Value="0.82" KeySpline="0.26,0 0.16,1" />
                        </DoubleAnimationUsingKeyFrames>

                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="PulseScale"
                                                       Storyboard.TargetProperty="ScaleX">
                            <SplineDoubleKeyFrame KeyTime="0:0:0" Value="0.88" />
                            <SplineDoubleKeyFrame KeyTime="0:0:1.63" Value="1.18" KeySpline="0.2,0 0.16,1" />
                            <SplineDoubleKeyFrame KeyTime="0:0:3.7" Value="0.88" KeySpline="0.28,0 0.16,1" />
                        </DoubleAnimationUsingKeyFrames>
                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="PulseScale"
                                                       Storyboard.TargetProperty="ScaleY">
                            <SplineDoubleKeyFrame KeyTime="0:0:0" Value="0.88" />
                            <SplineDoubleKeyFrame KeyTime="0:0:1.63" Value="1.18" KeySpline="0.2,0 0.16,1" />
                            <SplineDoubleKeyFrame KeyTime="0:0:3.7" Value="0.88" KeySpline="0.28,0 0.16,1" />
                        </DoubleAnimationUsingKeyFrames>
                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="PulseLayer"
                                                       Storyboard.TargetProperty="Opacity">
                            <SplineDoubleKeyFrame KeyTime="0:0:0" Value="0.08" />
                            <SplineDoubleKeyFrame KeyTime="0:0:1.63" Value="0.22" KeySpline="0.2,0 0.16,1" />
                            <SplineDoubleKeyFrame KeyTime="0:0:3.7" Value="0.08" KeySpline="0.28,0 0.16,1" />
                        </DoubleAnimationUsingKeyFrames>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Grid.Triggers>

        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F7080711" Offset="0" />
                <GradientStop Color="#F40D0A18" Offset="0.52" />
                <GradientStop Color="#F5121022" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid Width="440"
              MaxWidth="440"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="26" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="8" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Width="124"
                  Height="124"
                  HorizontalAlignment="Center">
                <Ellipse Width="104"
                         Height="104"
                         Stroke="#2B2444"
                         StrokeThickness="7"
                         Opacity="0.9" />

                <Ellipse x:Name="PulseLayer"
                         Width="78"
                         Height="78"
                         Fill="#241A46"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         Opacity="0.08"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <ScaleTransform x:Name="PulseScale" />
                    </Ellipse.RenderTransform>
                </Ellipse>

                <Ellipse x:Name="MainArc"
                         Width="104"
                         Height="104"
                         Stroke="#A78BFA"
                         StrokeThickness="7"
                         StrokeStartLineCap="Round"
                         StrokeEndLineCap="Round"
                         StrokeDashCap="Round"
                         StrokeDashArray="6.4 15.2"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <RotateTransform x:Name="MainArcRotate" />
                    </Ellipse.RenderTransform>
                </Ellipse>

                <Ellipse x:Name="EchoArc"
                         Width="68"
                         Height="68"
                         Stroke="#F7F4FF"
                         StrokeThickness="4"
                         StrokeStartLineCap="Round"
                         StrokeEndLineCap="Round"
                         StrokeDashCap="Round"
                         StrokeDashArray="2.2 9.6"
                         Opacity="0.42"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <RotateTransform x:Name="EchoArcRotate" />
                    </Ellipse.RenderTransform>
                </Ellipse>

                <Border Width="28"
                        Height="28"
                        CornerRadius="14"
                        Background="{StaticResource SplashCoreBrush}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="CoreScale" />
                            <RotateTransform x:Name="CoreRotate" />
                        </TransformGroup>
                    </Border.RenderTransform>
                </Border>
            </Grid>

            <TextBlock x:Name="PhraseText"
                       Grid.Row="2"
                       FontSize="28"
                       FontWeight="Black"
                       Foreground="{StaticResource SplashTextBrush}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       RenderTransformOrigin="0.5,0.5">
                <TextBlock.RenderTransform>
                    <TranslateTransform x:Name="PhraseTranslate" />
                </TextBlock.RenderTransform>
            </TextBlock>

            <TextBlock Grid.Row="4"
                       Text="{Binding BuildLoadingSplashDetail}"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource SplashSecondaryTextBrush}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       MaxWidth="420" />
        </Grid>

        <Border Height="1"
                VerticalAlignment="Top"
                Background="#2E2550"
                Opacity="0.36" />
    </Grid>
</UserControl>
